@page "/categories/create"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Добавление категории</PageTitle>

<div class="category-form-page">
    <div class="category-form-header">
        <div>
            <h1>Добавление категории</h1>
            <p>
                Создайте новую категорию для группировки товаров в публичном каталоге.
                После добавления категория появится в списке и сможет использоваться при создании товаров.
            </p>
        </div>
    </div>

    @if (Category is null)
    {
        <div class="category-form-card">
            <p><em>Загрузка...</em></p>
        </div>
    }
    else
    {
        <div class="category-form-card">
            <EditForm method="post" Model="Category" OnValidSubmit="AddCategory" FormName="create" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="category-field">
                    <label for="category_name">
                        Название категории <span>*</span>
                    </label>

                    <InputText id="category_name"
                               @bind-Value="Category.Category_Name"
                               class="form-control"
                               aria-required="true"
                               placeholder="Например: Футболки" />

                    <ValidationMessage For="() => Category.Category_Name" class="text-danger" />
                </div>

                <div class="category-field">
                    <label for="category_description">
                        Описание категории
                    </label>

                    <InputText id="category_description"
                               @bind-Value="Category.Category_Description"
                               class="form-control"
                               placeholder="Краткое описание раздела каталога" />

                    <ValidationMessage For="() => Category.Category_Description" class="text-danger" />
                </div>

                <div class="category-form-actions">
                    <button type="submit" class="category-submit-button">
                        Добавить категорию
                    </button>

                    <a class="category-secondary-button" href="/categories">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Category Category { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanCreateAsync("Categories"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        Category ??= new();
    }

    private async Task AddCategory()
    {
        using var context = DbFactory.CreateDbContext();

        var maxDisplayOrder = await context.Categories
            .Select(category => (int?)category.Category_DisplayOrder)
            .MaxAsync() ?? 0;

        Category.Category_DisplayOrder = maxDisplayOrder + 1;

        context.Categories.Add(Category);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/categories");
    }
}
