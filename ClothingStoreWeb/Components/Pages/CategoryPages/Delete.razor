@page "/categories/delete"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Удаление категории</PageTitle>

<div class="category-form-page">
    <div class="category-form-header">
        <div>
            <h1>Удаление категории</h1>
            <p>
                Перед удалением проверьте выбранную категорию. Если категория используется товарами,
                приложение не позволит удалить её до переноса или удаления связанных товаров.
            </p>
        </div>
    </div>

    @if (category is null)
    {
        <div class="category-form-card">
            <p><em>Загрузка...</em></p>
        </div>
    }
    else
    {
        <div class="category-form-card category-delete-card">
            <div class="category-warning">
                Вы действительно хотите удалить эту категорию?
            </div>

            <div class="category-details-list">
                <div class="category-details-row">
                    <span>Название категории</span>
                    <strong>@category.Category_Name</strong>
                </div>

                <div class="category-details-row">
                    <span>Описание категории</span>
                    <strong>
                        @(string.IsNullOrWhiteSpace(category.Category_Description)
                         ? "Описание не указано"
                         : category.Category_Description)
                </strong>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(deleteError))
            {
                <div class="category-error">
                    @deleteError
                </div>
            }

            <EditForm method="post" Model="category" OnValidSubmit="DeleteCategory" FormName="delete" Enhance>
                <div class="category-form-actions">
                    <button type="submit"
                            class="category-delete-button"
                            disabled="@(category is null)">
                        Удалить категорию
                    </button>
                    <a class="category-secondary-button" href="/categories">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Category? category;
    private string? deleteError;

    [SupplyParameterFromQuery]
    private int Category_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Categories"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();
        category = await context.Categories.FirstOrDefaultAsync(m => m.Category_Id == Category_Id);

        if (category is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteCategory()
    {
        if (category is null)
        {
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var categoryFromDb = await context.Categories
            .FirstOrDefaultAsync(c => c.Category_Id == category.Category_Id);

        if (categoryFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var hasProducts = await context.Products
            .AnyAsync(product => product.Category_Id == categoryFromDb.Category_Id);

        if (hasProducts)
        {
            deleteError = "Удаление невозможно: категория используется товарами. Сначала перенесите товары в другую категорию или удалите связанные товары.";
            return;
        }

        context.Categories.Remove(categoryFromDb);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/categories");
    }
}
