@page "/categories/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр категории</PageTitle>

<div class="category-form-page">
    <div class="category-form-header">
        <div>
            <h1>Просмотр категории</h1>
            <p>
                На странице отображаются основные данные выбранной категории.
            </p>
        </div>
    </div>

    @if (category is null)
    {
        <div class="category-form-card">
            <p><em>Загрузка...</em></p>
        </div>
    }
    else
    {
        <div class="category-form-card">
            <div class="category-details-list">
                <div class="category-details-row">
                    <span>Название категории</span>
                    <strong>@category.Category_Name</strong>
                </div>

                <div class="category-details-row">
                    <span>Описание категории</span>
                    <strong>
                        @(string.IsNullOrWhiteSpace(category.Category_Description)
                                            ? "Описание не указано"
                                            : category.Category_Description)
                </strong>
            </div>
        </div>

            <div class="category-form-actions">
            @if (canEdit)
                {
                    <a class="category-submit-button category-submit-link"
                       href="@($"/categories/edit?category_id={category.Category_Id}")">
                        Изменить
                    </a>
                }

                <a class="category-secondary-button" href="/categories">
                    Вернуться к списку
                </a>
            </div>
        </div>
    }
</div>

@code {
    private Category? category;
    private bool canEdit;

    [SupplyParameterFromQuery]
    private int Category_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Categories"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Categories");

        using var context = DbFactory.CreateDbContext();
        category = await context.Categories.FirstOrDefaultAsync(m => m.Category_Id == Category_Id);

        if (category is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
