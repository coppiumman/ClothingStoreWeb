@page "/categories"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using Microsoft.AspNetCore.Components.Authorization
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime

<PageTitle>Категории</PageTitle>

<div class="category-page">
    <div class="category-header">
        <div>
            <h1>Категории</h1>
            <p>
                Управление разделами каталога: добавление, изменение порядка,
                скрытие и отображение категорий на публичной странице интернет-магазина.
            </p>
        </div>

        <div class="category-header-actions">
            <button type="button"
                    class="category-button category-button-export"
                    @onclick="ExportCategoriesToExcelAsync">
                Экспорт в Excel
            </button>

            @if (canCreate)
            {
                <a class="category-button category-button-primary" href="categories/create">
                    Добавить категорию
                </a>
            }
        </div>
    </div>

    <div class="category-table-card">
        <QuickGrid Class="table categories-table" Items="categories">
            <PropertyColumn Property="category => category.Category_Name" Title="Название категории" />
            <PropertyColumn Property="category => category.Category_Description" Title="Описание категории" />
            <PropertyColumn Property="category => category.Category_DisplayOrder" Title="Порядок" />

            <TemplateColumn Title="Статус" Context="category">
                @if (category.Category_IsHidden)
                {
                    <span class="category-status category-status-hidden">Скрыта</span>
                }
                else
                {
                    <span class="category-status category-status-visible">Отображается</span>
                }
            </TemplateColumn>

            <TemplateColumn Title="Действия" Context="category">
                <div class="category-actions">
                    @if (canEdit)
                    {
                        <button type="button"
                                class="category-icon-button"
                                title="Переместить выше"
                                @onclick="() => MoveCategoryUp(category.Category_Id)">
                            ↑
                        </button>

                        <button type="button"
                                class="category-icon-button"
                                title="Переместить ниже"
                                @onclick="() => MoveCategoryDown(category.Category_Id)">
                            ↓
                        </button>

                        <button type="button"
                                class="category-small-button"
                                @onclick="() => ToggleCategoryVisibility(category.Category_Id)">
                            @(category.Category_IsHidden ? "Показать" : "Скрыть")
                        </button>

                        <a class="category-action-button category-action-edit"
                           href="@($"categories/edit?category_id={category.Category_Id}")">
                            Изменить
                        </a>
                    }

                    @if (canDelete)
                    {
                        <a class="category-action-button category-action-delete"
                           href="@($"categories/delete?category_id={category.Category_Id}")">
                            Удалить
                        </a>
                    }
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>
</div>

@code {
    private ApplicationDbContext? context;
    private IQueryable<Category> categories = Enumerable.Empty<Category>().AsQueryable();
    private bool canCreate;
    private bool canEdit;
    private bool canDelete;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Categories"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canCreate = await AccessService.CanCreateAsync("Categories");
        canEdit = await AccessService.CanEditAsync("Categories");
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Администратор");

        canDelete = isAdmin && await AccessService.CanDeleteAsync("Categories");

        context = DbFactory.CreateDbContext();

        categories = context.Categories
            .AsNoTracking()
            .OrderBy(category => category.Category_DisplayOrder)
            .ThenBy(category => category.Category_Id);
    }

    private async Task ToggleCategoryVisibility(int categoryId)
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var category = await dbContext.Categories
            .FirstOrDefaultAsync(category => category.Category_Id == categoryId);

        if (category is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        category.Category_IsHidden = !category.Category_IsHidden;

        await dbContext.SaveChangesAsync();

        categories = context!.Categories
            .AsNoTracking()
            .OrderBy(category => category.Category_DisplayOrder)
            .ThenBy(category => category.Category_Id);

        StateHasChanged();
    }

    private async Task MoveCategoryUp(int categoryId)
    {
        await MoveCategory(categoryId, -1);
    }

    private async Task MoveCategoryDown(int categoryId)
    {
        await MoveCategory(categoryId, 1);
    }

    private async Task MoveCategory(int categoryId, int direction)
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var categoriesList = await dbContext.Categories
            .OrderBy(category => category.Category_DisplayOrder)
            .ThenBy(category => category.Category_Id)
            .ToListAsync();

        for (var index = 0; index < categoriesList.Count; index++)
        {
            categoriesList[index].Category_DisplayOrder = index + 1;
        }

        var currentIndex = categoriesList.FindIndex(category => category.Category_Id == categoryId);

        if (currentIndex < 0)
        {
            return;
        }

        var newIndex = currentIndex + direction;

        if (newIndex < 0 || newIndex >= categoriesList.Count)
        {
            return;
        }

        (categoriesList[currentIndex].Category_DisplayOrder, categoriesList[newIndex].Category_DisplayOrder) =
            (categoriesList[newIndex].Category_DisplayOrder, categoriesList[currentIndex].Category_DisplayOrder);

        await dbContext.SaveChangesAsync();

        categories = context!.Categories
            .AsNoTracking()
            .OrderBy(category => category.Category_DisplayOrder)
            .ThenBy(category => category.Category_Id);

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportCategoriesToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var categoriesForExport = await dbContext.Categories
            .AsNoTracking()
            .OrderBy(category => category.Category_DisplayOrder)
            .ThenBy(category => category.Category_Id)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Категории");

        worksheet.Cell(1, 1).Value = "Название категории";
        worksheet.Cell(1, 2).Value = "Описание категории";
        worksheet.Cell(1, 3).Value = "Порядок";
        worksheet.Cell(1, 4).Value = "Статус";

        var headerRange = worksheet.Range(1, 1, 1, 4);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var category in categoriesForExport)
        {
            worksheet.Cell(row, 1).Value = category.Category_Name;
            worksheet.Cell(row, 2).Value = category.Category_Description ?? "";
            worksheet.Cell(row, 3).Value = category.Category_DisplayOrder;
            worksheet.Cell(row, 4).Value = category.Category_IsHidden ? "Скрыта" : "Отображается";

            row++;
        }

        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "categories.xlsx");
    }
}
