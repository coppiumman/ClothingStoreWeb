@page "/employees/create"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Добавление</PageTitle>

<h1>Добавление</h1>

<h2>Сотрудник</h2>
<hr />
@if (Employee is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Employee" OnValidSubmit="AddEmployee" FormName="create" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert"/>
                <div class="mb-3">
                    <label for="user_search" class="form-label">Поиск пользователя:</label>
                    <input id="user_search"
                           @bind="userSearchText"
                           @bind:event="oninput"
                           class="form-control"
                           placeholder="Введите ФИО или email" />
                </div>

                @if (!string.IsNullOrWhiteSpace(userSearchText))
                {
                    <div class="mb-3">
                        <label class="form-label">Найденные пользователи:</label>

                        @if (FilteredUsers.Any())
                        {
                            <div class="list-group user-search-results">
                                @foreach (var user in FilteredUsers)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action"
                                            @onclick="() => SelectUser(user)">
                                        @GetUserDisplayName(user)
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                Пользователи не найдены.
                            </div>
                        }
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Выбранный пользователь:</label>
                    <input class="form-control"
                           value="@GetSelectedUserName()"
                           readonly />

                    <ValidationMessage For="() => Employee.User_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="employee_position" class="form-label">Должность:</label> 
                    <InputSelect id="employee_position" @bind-Value="Employee.Employee_Position" class="form-control" aria-required="true">
                        <option value="">Выберите должность</option>
                        @foreach (var position in EmployeePositions)
                        {
                            <option value="@position">@position</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Employee.Employee_Position" class="text-danger" /> 
                </div>        
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="employee_salary" class="form-label">Зарплата:</label> 
                    <InputNumber id="employee_salary" @bind-Value="Employee.Employee_Salary" class="form-control" aria-required="true" ParsingErrorMessage="Введите корректную зарплату"/> 
                    <ValidationMessage For="() => Employee.Employee_Salary" class="text-danger" /> 
                </div>        
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="employee_hiredate" class="form-label">Дата приёма на работу:</label> 
                    <InputDate id="employee_hiredate" @bind-Value="Employee.Employee_HireDate" class="form-control" aria-required="true" ParsingErrorMessage="Введите корректную дату приёма на работу"/> 
                    <ValidationMessage For="() => Employee.Employee_HireDate" class="text-danger" /> 
                </div>

                @if (!string.IsNullOrWhiteSpace(createError))
                {
                    <div class="alert alert-danger">
                        @createError
                    </div>
                }

                <button type="submit" class="btn btn-primary">Добавить</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/employees">Вернуться к списку</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Employee Employee { get; set; } = default!;

    private List<ApplicationUser> Users { get; set; } = new();
    
    private string userSearchText = string.Empty;
    private string? createError;

    private IEnumerable<ApplicationUser> FilteredUsers
    {
        get
        {
            if (string.IsNullOrWhiteSpace(userSearchText))
            {
                return Enumerable.Empty<ApplicationUser>();
            }

            return Users
                .Where(user =>
                    (!string.IsNullOrWhiteSpace(user.UserFullName) &&
                     user.UserFullName.Contains(userSearchText, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(user.Email) &&
                     user.Email.Contains(userSearchText, StringComparison.OrdinalIgnoreCase)))
                .Take(10);
        }
    }

    private const string EmployeeRoleName = "Сотрудник";

    private static readonly string[] EmployeePositions =
    {
        "Администратор",
        "Менеджер",
        "Кладовщик",
        "Консультант"
    };

    protected override async Task OnInitializedAsync()
    {
        Employee ??= new();

        using var context = DbFactory.CreateDbContext();

        var employeeUserIds = await context.Employees
            .AsNoTracking()
            .Select(employee => employee.User_Id)
            .ToListAsync();

        Users = await context.Users
            .AsNoTracking()
            .Where(user => !employeeUserIds.Contains(user.Id))
            .OrderBy(user => user.UserFullName)
            .ThenBy(user => user.Email)
            .ToListAsync();
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private void SelectUser(ApplicationUser user)
    {
        Employee.User_Id = user.Id;
        userSearchText = GetUserDisplayName(user);
    }

    private string GetSelectedUserName()
    {
        var selectedUser = Users.FirstOrDefault(user => user.Id == Employee.User_Id);
        return selectedUser is null ? "Пользователь не выбран" : GetUserDisplayName(selectedUser);
    }

    private async Task AddEmployee()
    {
        createError = null;

        if (string.IsNullOrWhiteSpace(Employee.User_Id))
        {
            createError = "Выберите пользователя.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var employeeAlreadyExists = await context.Employees
            .AnyAsync(employee => employee.User_Id == Employee.User_Id);

        if (employeeAlreadyExists)
        {
            createError = "Этот пользователь уже является сотрудником.";
            return;
        }

        context.Employees.Add(Employee);
        await context.SaveChangesAsync();

        var user = await UserManager.FindByIdAsync(Employee.User_Id);
        if (user is not null && !await UserManager.IsInRoleAsync(user, EmployeeRoleName))
        {
            await UserManager.AddToRoleAsync(user, EmployeeRoleName);
        }

        NavigationManager.NavigateTo("/employees");
    }
}
