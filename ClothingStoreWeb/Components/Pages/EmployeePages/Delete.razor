@page "/employees/delete"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Удаление сотрудника</PageTitle>

<div class="employee-delete-page">
    <div class="employee-delete-header">
        <h1>Удаление сотрудника</h1>
        <p>
            Перед удалением проверьте выбранного сотрудника. После удаления записи пользователь
            потеряет роль сотрудника и не сможет работать со служебными функциями приложения.
        </p>
    </div>

    @if (employee is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="employee-delete-card">
            <div class="employee-delete-warning">
                Вы действительно хотите удалить этого сотрудника?
            </div>

            <div class="employee-delete-row">
                <span>Пользователь</span>
                <strong>@GetUserDisplayName(employee.User)</strong>
            </div>

            <div class="employee-delete-row">
                <span>Email</span>
                <strong>@DisplayValue(employee.User?.Email)</strong>
            </div>

            <div class="employee-delete-row">
                <span>Должность</span>
                <strong>@employee.Employee_Position</strong>
            </div>

            <div class="employee-delete-row">
                <span>Зарплата</span>
                <strong>@employee.Employee_Salary.ToString("N2") ₽</strong>
            </div>

            <div class="employee-delete-row">
                <span>Дата приёма</span>
                <strong>@employee.Employee_HireDate.ToString("dd.MM.yyyy")</strong>
            </div>

            <EditForm method="post" Model="employee" OnValidSubmit="DeleteEmployee" FormName="delete" Enhance>
                <div class="employee-delete-actions">
                    <button type="submit"
                            class="employee-button employee-button-danger"
                            disabled="@(employee is null)">
                        Удалить сотрудника
                    </button>

                    <a class="employee-button" href="/employees">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Employee? employee;

    private const string EmployeeRoleName = "Сотрудник";
    private const string AdministratorRoleName = "Администратор";

    [SupplyParameterFromQuery]
    private int Employee_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        employee = await context.Employees
            .Include(e => e.User)
            .FirstOrDefaultAsync(m => m.Employee_Id == Employee_Id);

        if (employee is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        if (employee.User is not null &&
            await UserManager.IsInRoleAsync(employee.User, AdministratorRoleName))
        {
            NavigationManager.NavigateTo("/employees", replace: true);
            return;
        }
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Не указано" : value;
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
        {
            return "Пользователь не найден";
        }

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
        {
            return user.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            return user.Email;
        }

        return user.Id;
    }

    private async Task DeleteEmployee()
    {
        if (employee is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var employeeFromDb = await context.Employees
            .FirstOrDefaultAsync(e => e.Employee_Id == employee.Employee_Id);

        if (employeeFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var userId = employeeFromDb.User_Id;

        context.Employees.Remove(employeeFromDb);
        await context.SaveChangesAsync();

        var user = await UserManager.FindByIdAsync(userId);

        if (user is not null && await UserManager.IsInRoleAsync(user, EmployeeRoleName))
        {
            await UserManager.RemoveFromRoleAsync(user, EmployeeRoleName);
        }

        NavigationManager.NavigateTo("/employees");
    }
}