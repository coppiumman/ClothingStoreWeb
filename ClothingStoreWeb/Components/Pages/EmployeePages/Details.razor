@page "/employees/details"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Просмотр сотрудника</PageTitle>

<div class="employee-details-page">
    <div class="employee-details-header">
        <h1>Просмотр сотрудника</h1>
        <p>
            На странице отображаются данные выбранного сотрудника: привязанный пользователь,
            должность, зарплата и дата приёма на работу.
        </p>
    </div>

    @if (employee is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="employee-details-summary">
            <div>
                <span>Пользователь</span>
                <strong>@GetUserDisplayName(employee.User)</strong>
            </div>

            <div>
                <span>Должность</span>
                <strong>@employee.Employee_Position</strong>
            </div>

            <div>
                <span>Зарплата</span>
                <strong>@employee.Employee_Salary.ToString("N2") ₽</strong>
            </div>
        </div>

        <div class="employee-details-card">
            <h2>Данные сотрудника</h2>

            <div class="employee-details-row">
                <span>Пользователь</span>
                <strong>@GetUserDisplayName(employee.User)</strong>
            </div>

            <div class="employee-details-row">
                <span>Email</span>
                <strong>@DisplayValue(employee.User?.Email)</strong>
            </div>

            <div class="employee-details-row">
                <span>Должность</span>
                <strong>@employee.Employee_Position</strong>
            </div>

            <div class="employee-details-row">
                <span>Зарплата</span>
                <strong>@employee.Employee_Salary.ToString("N2") ₽</strong>
            </div>

            <div class="employee-details-row">
                <span>Дата приёма</span>
                <strong>@employee.Employee_HireDate.ToString("dd.MM.yyyy")</strong>
            </div>
        </div>

        <div class="employee-details-actions">
            <a class="employee-button employee-button-primary"
               href="@($"/employees/edit?employee_id={employee.Employee_Id}")">
                Изменить
            </a>

            <a class="employee-button" href="/employees">
                Вернуться к списку
            </a>
        </div>
    }
</div>

@code {
    private Employee? employee;

    [SupplyParameterFromQuery]
    private int Employee_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        employee = await context.Employees
            .Include(e => e.User)
            .AsNoTracking()
            .FirstOrDefaultAsync(m => m.Employee_Id == Employee_Id);

        if (employee is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Не указано" : value;
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
        {
            return "Пользователь не найден";
        }

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
        {
            return user.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            return user.Email;
        }

        return user.Id;
    }
}