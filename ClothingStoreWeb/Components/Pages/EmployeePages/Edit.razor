@page "/employees/edit"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using Microsoft.AspNetCore.Identity
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Редактирование сотрудника</PageTitle>

<div class="employee-form-page">
    <div class="employee-form-header">
        <h1>Редактирование сотрудника</h1>
        <p>
            Измените должность, зарплату и дату приёма сотрудника. Привязанный пользователь
            не изменяется, чтобы не нарушить связь с учётной записью.
        </p>
    </div>

    @if (Employee is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="employee-form-card">
            <EditForm method="post" Model="Employee" OnValidSubmit="UpdateEmployee" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" class="text-danger" />

                <input type="hidden" name="Employee.Employee_Id" value="@Employee.Employee_Id" />

                <div class="employee-form-group">
                    <label>Пользователь</label>

                    <input class="employee-form-control employee-user-readonly"
                           value="@GetSelectedUserName()"
                           readonly />

                    <div class="employee-form-note">
                        Пользователь уже привязан к записи сотрудника и не изменяется при редактировании.
                    </div>
                </div>

                <div class="employee-form-group">
                    <label for="employee_position">Должность <span>*</span></label>

                    <InputSelect id="employee_position"
                                 @bind-Value="Employee.Employee_Position"
                                 class="employee-form-control"
                                 aria-required="true">
                        <option value="">Выберите должность</option>
                        @foreach (var position in EmployeePositions)
                        {
                            <option value="@position">@position</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => Employee.Employee_Position" class="text-danger" />
                </div>

                <div class="employee-form-group">
                    <label for="employee_salary">Зарплата <span>*</span></label>

                    <InputNumber id="employee_salary"
                                 @bind-Value="Employee.Employee_Salary"
                                 class="employee-form-control"
                                 aria-required="true"
                                 ParsingErrorMessage="Введите корректную зарплату" />

                    <ValidationMessage For="() => Employee.Employee_Salary" class="text-danger" />
                </div>

                <div class="employee-form-group">
                    <label for="employee_hiredate">Дата приёма на работу <span>*</span></label>

                    <InputDate id="employee_hiredate"
                               @bind-Value="Employee.Employee_HireDate"
                               class="employee-form-control"
                               aria-required="true"
                               ParsingErrorMessage="Введите корректную дату приёма на работу" />

                    <ValidationMessage For="() => Employee.Employee_HireDate" class="text-danger" />
                </div>

                <div class="employee-form-actions">
                    <button type="submit" class="employee-button employee-button-primary">
                        Сохранить изменения
                    </button>

                    <a class="employee-button" href="/employees">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int Employee_Id { get; set; }

    [SupplyParameterFromForm]
    private Employee? Employee { get; set; }

    private List<ApplicationUser> Users { get; set; } = new();

    private const string AdministratorRoleName = "Администратор";

    private static readonly string[] EmployeePositions =
    {
        "Менеджер",
        "Кладовщик",
        "Консультант"
    };

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        Employee ??= await context.Employees
            .FirstOrDefaultAsync(employee => employee.Employee_Id == Employee_Id);

        Users = await context.Users
            .AsNoTracking()
            .OrderBy(user => user.UserFullName)
            .ThenBy(user => user.Email)
            .ToListAsync();

        if (Employee is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var selectedUser = Users.FirstOrDefault(user => user.Id == Employee.User_Id);

        if (selectedUser is not null &&
            await UserManager.IsInRoleAsync(selectedUser, AdministratorRoleName))
        {
            NavigationManager.NavigateTo("/employees", replace: true);
            return;
        }
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
        {
            return "";
        }

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
        {
            return user.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            return user.Email;
        }

        return user.Id;
    }

    private string GetSelectedUserName()
    {
        var selectedUser = Users.FirstOrDefault(user => user.Id == Employee?.User_Id);
        return selectedUser is null ? "Пользователь не выбран" : GetUserDisplayName(selectedUser);
    }

    private async Task UpdateEmployee()
    {
        if (Employee is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var employeeFromDb = await context.Employees
            .FirstOrDefaultAsync(employee => employee.Employee_Id == Employee.Employee_Id);

        if (employeeFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        employeeFromDb.Employee_Position = Employee.Employee_Position;
        employeeFromDb.Employee_Salary = Employee.Employee_Salary;
        employeeFromDb.Employee_HireDate = Employee.Employee_HireDate;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!EmployeeExists(Employee.Employee_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo("/employees");
    }

    private bool EmployeeExists(int employee_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Employees.Any(employee => employee.Employee_Id == employee_id);
    }
}