@page "/employees"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory

<PageTitle>Сотрудники</PageTitle>

<h1>Сотрудники</h1>

<p>
    <a href="employees/create">Добавить</a>
</p>

<QuickGrid Class="table" Items="employees">
    <TemplateColumn Title="Пользователь">
        @GetUserDisplayName(context.User)
    </TemplateColumn>
    <PropertyColumn Property="employee => employee.Employee_Position" Title="Должность" />
    <PropertyColumn Property="employee => employee.Employee_Salary" Title="Зарплата" />
    <PropertyColumn Property="employee => employee.Employee_HireDate" Title="Дата приёма на работу" />

    <TemplateColumn Context="employee">
        <a href="@($"employees/edit?employee_id={employee.Employee_Id}")">Изменить</a> |
        <a href="@($"employees/details?employee_id={employee.Employee_Id}")">Подробнее</a> |
        <a href="@($"employees/delete?employee_id={employee.Employee_Id}")">Удалить</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private ApplicationDbContext context = default!;
    private IQueryable<Employee> employees = Enumerable.Empty<Employee>().AsQueryable();

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
        employees = context.Employees
            .Include(employee => employee.User)
            .AsNoTracking()
            .OrderBy(employee => employee.Employee_Id);
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }
}
