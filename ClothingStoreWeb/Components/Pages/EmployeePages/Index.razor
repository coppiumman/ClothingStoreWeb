@page "/employees"
@attribute [Authorize(Roles = "Администратор")]
@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using ClosedXML.Excel
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Identity
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Сотрудники</PageTitle>

<div class="employees-page">
    <div class="employees-header">
        <div>
            <h1>Сотрудники</h1>
            <p>
                В разделе выполняется управление сотрудниками интернет-магазина. Администратор может
                назначить зарегистрированного пользователя сотрудником, указать должность, зарплату
                и дату приёма на работу.
            </p>
        </div>

        <div class="employees-header-actions">
            <button type="button"
                    class="employees-button employees-button-secondary"
                    @onclick="ExportEmployeesToExcelAsync">
                Экспорт в Excel
            </button>

            <a class="employees-button employees-button-primary"
               href="/employees/create">
                Добавить сотрудника
            </a>
        </div>
    </div>

    <div class="employees-filter-panel">
        <label for="employee-search">Поиск сотрудника</label>

        <div class="employees-search-row">
            <input id="employee-search"
                   type="search"
                   class="employees-search-input"
                   @bind="searchText"
                   @bind:event="oninput"
                   placeholder="Введите ФИО, email, должность или дату" />

            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <button type="button"
                        class="employees-button"
                        @onclick="ClearSearch">
                    Очистить
                </button>
            }
        </div>

        <div class="employees-filter-hint">
            Например: <strong>Менеджер</strong>, <strong>admin@admin.ru</strong> или <strong>24.05.2026</strong>.
        </div>
    </div>

    <div class="employees-table-card">
        <QuickGrid Class="employees-table" Items="FilteredEmployees">
            <TemplateColumn Title="Пользователь" Context="employee">
                <div class="employee-user-cell">
                    <strong>@GetUserDisplayName(employee.User)</strong>
                    <span>@(employee.User?.Email ?? "Email не указан")</span>
                </div>
            </TemplateColumn>

            <TemplateColumn Title="Должность" Context="employee">
                <span class="employee-position @(employee.IsAdministrator ? "employee-position-admin" : "")">
                    @employee.Position
                </span>
            </TemplateColumn>

            <TemplateColumn Title="Зарплата" Context="employee">
                @if (employee.IsAdministrator && employee.EmployeeId is null)
                {
                    <span class="employee-muted">Не применяется</span>
                }
                else
                {
                    @($"{employee.Salary:N2} ₽")
                }
            </TemplateColumn>

            <TemplateColumn Title="Дата приёма" Context="employee">
                @if (employee.HireDate.HasValue)
                {
                    @employee.HireDate.Value.ToString("dd.MM.yyyy")
                }
                else
                {
                    <span class="employee-muted">Не применяется</span>
                }
            </TemplateColumn>

            <TemplateColumn Title="Действия" Context="employee">
                <div class="employees-actions">
                    @if (employee.EmployeeId.HasValue)
                    {
                        @if (!employee.IsAdministrator)
                        {
                            <a class="employees-action-button"
                               href="@($"/employees/edit?employee_id={employee.EmployeeId}")">
                                Изменить
                            </a>
                        }

                        <a class="employees-action-button"
                           href="@($"/employees/details?employee_id={employee.EmployeeId}")">
                            Подробнее
                        </a>

                        @if (!employee.IsAdministrator)
                        {
                            <a class="employees-action-button employees-action-danger"
                               href="@($"/employees/delete?employee_id={employee.EmployeeId}")">
                                Удалить
                            </a>
                        }
                    }
                    else
                    {
                        <span class="employees-action-muted">
                            Защищённая роль
                        </span>
                    }
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>
</div>

@code {
    private ApplicationDbContext context = default!;
    private List<EmployeeRow> employees = new();

    private const string AdministratorRoleName = "Администратор";

    private string searchText = string.Empty;

    private IQueryable<EmployeeRow> FilteredEmployees => GetFilteredEmployees();

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();

        var employeeList = await context.Employees
            .Include(employee => employee.User)
            .AsNoTracking()
            .OrderBy(employee => employee.Employee_Position)
            .ThenBy(employee => employee.User!.UserFullName)
            .ThenBy(employee => employee.User!.Email)
            .ToListAsync();

        employees = employeeList
            .Select(employee => new EmployeeRow
            {
                EmployeeId = employee.Employee_Id,
                User = employee.User,
                Position = employee.Employee_Position,
                Salary = employee.Employee_Salary,
                HireDate = employee.Employee_HireDate,
                IsAdministrator = false
            })
            .ToList();

        var administratorUsers = await UserManager.GetUsersInRoleAsync(AdministratorRoleName);

        foreach (var administratorUser in administratorUsers)
        {
            var existingRow = employees.FirstOrDefault(row => row.User?.Id == administratorUser.Id);

            if (existingRow is not null)
            {
                existingRow.IsAdministrator = true;
                existingRow.Position = AdministratorRoleName;
                continue;
            }

            employees.Add(new EmployeeRow
            {
                EmployeeId = null,
                User = administratorUser,
                Position = AdministratorRoleName,
                Salary = 0,
                HireDate = null,
                IsAdministrator = true
            });
        }

        employees = employees
            .OrderByDescending(row => row.IsAdministrator)
            .ThenBy(row => row.Position)
            .ThenBy(row => GetUserDisplayName(row.User))
            .ToList();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();

    private IQueryable<EmployeeRow> GetFilteredEmployees()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return employees.AsQueryable();
        }

        var value = searchText.Trim();

        DateTime? hireDate = null;

        if (DateTime.TryParseExact(
                value,
                new[] { "dd.MM.yyyy", "d.M.yyyy", "yyyy-MM-dd" },
                CultureInfo.GetCultureInfo("ru-RU"),
                DateTimeStyles.None,
                out var parsedDate))
        {
            hireDate = parsedDate.Date;
        }

        var filteredEmployees = employees
            .Where(employee =>
                employee.Position.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                GetUserDisplayName(employee.User).Contains(value, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(employee.User?.Email) &&
                    employee.User.Email.Contains(value, StringComparison.OrdinalIgnoreCase)) ||
                (hireDate.HasValue &&
                    employee.HireDate.HasValue &&
                    employee.HireDate.Value.Date == hireDate.Value.Date)
            );

        return filteredEmployees.AsQueryable();
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
        {
            return "Пользователь не найден";
        }

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
        {
            return user.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            return user.Email;
        }

        return user.Id;
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportEmployeesToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var employeesForExport = await dbContext.Employees
            .Include(employee => employee.User)
            .AsNoTracking()
            .OrderBy(employee => employee.Employee_Position)
            .ThenBy(employee => employee.User!.UserFullName)
            .ThenBy(employee => employee.User!.Email)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Сотрудники");

        worksheet.Cell(1, 1).Value = "Пользователь";
        worksheet.Cell(1, 2).Value = "Email";
        worksheet.Cell(1, 3).Value = "Должность";
        worksheet.Cell(1, 4).Value = "Зарплата";
        worksheet.Cell(1, 5).Value = "Дата приёма на работу";

        var headerRange = worksheet.Range(1, 1, 1, 5);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var employee in employeesForExport)
        {
            worksheet.Cell(row, 1).Value = GetUserDisplayName(employee.User);
            worksheet.Cell(row, 2).Value = employee.User?.Email ?? "";
            worksheet.Cell(row, 3).Value = employee.Employee_Position;
            worksheet.Cell(row, 4).Value = employee.Employee_Salary;
            worksheet.Cell(row, 5).Value = employee.Employee_HireDate;

            row++;
        }

        worksheet.Column(5).Style.DateFormat.Format = "dd.MM.yyyy";
        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "employees.xlsx");
    }

    private sealed class EmployeeRow
    {
        public int? EmployeeId { get; set; }

        public ApplicationUser? User { get; set; }

        public string Position { get; set; } = "";

        public decimal Salary { get; set; }

        public DateTime? HireDate { get; set; }

        public bool IsAdministrator { get; set; }
    }
}