@page "/orderitems/delete"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@inject NavigationManager NavigationManager

<PageTitle>Удаление недоступно</PageTitle>

@code {
    protected override Task OnInitializedAsync()
    {
        NavigationManager.NavigateTo("/orderitems", replace: true);
        return Task.CompletedTask;
    }
}