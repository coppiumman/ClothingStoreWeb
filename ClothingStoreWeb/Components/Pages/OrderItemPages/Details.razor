@page "/orderitems/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр позиции заказа</PageTitle>

<div class="orderitem-details-page">
    <div class="orderitem-details-header">
        <h1>Просмотр позиции заказа</h1>
        <p>
            На странице отображается отдельная позиция заказа: номер заказа,
            статус, товар, выбранный размер, количество и стоимость позиции.
        </p>
    </div>

    @if (orderitem is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="orderitem-details-summary">
            <div>
                <span>Заказ</span>
                <strong>@(orderitem.Order is null ? $"Заказ №{orderitem.Order_Id}" : GetOrderDisplayName(orderitem.Order))</strong>
            </div>

            <div>
                <span>Статус заказа</span>
                <strong class="orderitem-status @GetOrderStatusCssClass(orderitem.Order?.Order_Status)">
                    @GetOrderStatusName(orderitem.Order?.Order_Status)
                </strong>
            </div>

            <div>
                <span>Цена позиции</span>
                <strong>@orderitem.OrderItem_Price.ToString("N2") ₽</strong>
            </div>
        </div>

        <div class="orderitem-details-card">
            <h2>Данные позиции</h2>

            <div class="orderitem-details-row">
                <span>Товар</span>
                <strong>@(orderitem.Product?.Product_Name ?? orderitem.Product_Id.ToString())</strong>
            </div>

            <div class="orderitem-details-row">
                <span>Размер</span>
                <strong>@(orderitem.Size?.Size_Name ?? orderitem.Size_Id.ToString())</strong>
            </div>

            <div class="orderitem-details-row">
                <span>Количество</span>
                <strong>@orderitem.OrderItem_Quantity</strong>
            </div>

            <div class="orderitem-details-row">
                <span>Цена позиции</span>
                <strong>@orderitem.OrderItem_Price.ToString("N2") ₽</strong>
            </div>
        </div>

        <div class="orderitem-details-actions">
            <a class="orderitem-button" href="/orderitems">
                Вернуться к списку
            </a>

            <a class="orderitem-button" href="@($"/orders/details?id={orderitem.Order_Id}")">
                Открыть заказ
            </a>
        </div>
    }
</div>

@code {
    private OrderItem? orderitem;

    [SupplyParameterFromQuery]
    private int OrderItem_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("OrderItems"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        orderitem = await context.OrderItems
            .Include(oi => oi.Order)
            .Include(oi => oi.Product)
            .Include(oi => oi.Size)
            .AsNoTracking()
            .FirstOrDefaultAsync(m => m.OrderItem_Id == OrderItem_Id);

        if (orderitem is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private string GetOrderDisplayName(Order order)
    {
        return $"Заказ №{order.Order_Id} от {order.Order_Date:dd.MM.yyyy HH:mm}";
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetOrderStatusCssClass(string? status)
    {
        return status switch
        {
            "new" => "orderitem-status-new",
            "confirmed" => "orderitem-status-confirmed",
            "paid" => "orderitem-status-paid",
            "processing" => "orderitem-status-processing",
            "shipped" => "orderitem-status-shipped",
            "delivered" => "orderitem-status-delivered",
            "done" => "orderitem-status-done",
            "cancelled" => "orderitem-status-cancelled",
            "returned" => "orderitem-status-returned",
            _ => "orderitem-status-default"
        };
    }
}