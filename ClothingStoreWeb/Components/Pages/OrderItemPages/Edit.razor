@page "/orderitems/edit"
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Редактирование</PageTitle>

<h1>Редактирование</h1>

<h2>Позиция заказа</h2>
<hr />
@if (OrderItem is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="OrderItem" OnValidSubmit="UpdateOrderItem" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="OrderItem.OrderItem_Id" value="@OrderItem.OrderItem_Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="order_id" class="form-label">Заказ:</label>
                    <InputNumber id="order_id" @bind-Value="OrderItem.Order_Id" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => OrderItem.Order_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="product_id" class="form-label">Товар:</label>
                    <InputNumber id="product_id" @bind-Value="OrderItem.Product_Id" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => OrderItem.Product_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="size_id" class="form-label">Размер:</label>
                    <InputNumber id="size_id" @bind-Value="OrderItem.Size_Id" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => OrderItem.Size_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="orderitem_quantity" class="form-label">Количество:</label>
                    <InputNumber id="orderitem_quantity" @bind-Value="OrderItem.OrderItem_Quantity" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => OrderItem.OrderItem_Quantity" class="text-danger" />
                </div>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="orderitem_price" class="form-label">Цена позиции:</label>
                    <InputNumber id="orderitem_price" @bind-Value="OrderItem.OrderItem_Price" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => OrderItem.OrderItem_Price" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/orderitems">Вернуться к списку</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int OrderItem_Id { get; set; }

    [SupplyParameterFromForm]
    private OrderItem? OrderItem { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        OrderItem ??= await context.OrderItems.FirstOrDefaultAsync(m => m.OrderItem_Id == OrderItem_Id);

        if (OrderItem is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateOrderItem()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(OrderItem!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!OrderItemExists(OrderItem!.OrderItem_Id))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/orderitems");
    }

    private bool OrderItemExists(int orderitem_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.OrderItems.Any(e => e.OrderItem_Id == orderitem_id);
    }
}
