@page "/orderitems"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Позиции заказа</PageTitle>

<div class="orderitems-page">
    <div class="orderitems-header">
        <div>
            <h1>Позиции заказа</h1>
            <p>
                В разделе отображается состав заказов: выбранные товары, размеры,
                количество и цена каждой позиции. Данные используются для проверки
                содержимого заказа и выгрузки информации в Excel.
            </p>
        </div>

        <div class="orderitems-header-actions">
            <button type="button"
                    class="orderitems-button orderitems-button-secondary"
                    @onclick="ExportOrderItemsToExcelAsync">
                Экспорт в Excel
            </button>
        </div>
    </div>

    <div class="orderitems-filter-panel">
        <label for="orderitem-search">Поиск позиции</label>

        <div class="orderitems-search-row">
            <input id="orderitem-search"
                   type="search"
                   class="orderitems-search-input"
                   @bind="searchText"
                   @bind:event="oninput"
                   placeholder="Введите № заказа, товар, размер или статус" />

            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <button type="button"
                        class="orderitems-button"
                        @onclick="ClearSearch">
                    Очистить
                </button>
            }
        </div>

        <div class="orderitems-filter-hint">
            Например: <strong>24</strong>, <strong>VELD</strong>, <strong>36</strong> или <strong>Отменён</strong>.
        </div>
    </div>

    <div class="orderitems-table-card">
        <QuickGrid Class="orderitems-table" Items="FilteredOrderItems">
            <TemplateColumn Title="Заказ" Context="orderitem">
                Заказ №@orderitem.Order_Id
            </TemplateColumn>

            <TemplateColumn Title="Статус заказа" Context="orderitem">
                <span class="orderitems-status @GetOrderStatusCssClass(orderitem.Order?.Order_Status)">
                    @GetOrderStatusName(orderitem.Order?.Order_Status)
                </span>
            </TemplateColumn>

            <TemplateColumn Title="Товар" Context="orderitem">
                @(orderitem.Product?.Product_Name ?? orderitem.Product_Id.ToString())
            </TemplateColumn>

            <TemplateColumn Title="Размер" Context="orderitem">
                @(orderitem.Size?.Size_Name ?? orderitem.Size_Id.ToString())
            </TemplateColumn>

            <PropertyColumn Property="orderitem => orderitem.OrderItem_Quantity" Title="Количество" />

            <TemplateColumn Title="Цена позиции" Context="orderitem">
                @orderitem.OrderItem_Price.ToString("N2") ₽
            </TemplateColumn>

            <TemplateColumn Title="Действия" Context="orderitem">
                <div class="orderitems-actions">
                    <a class="orderitems-action-button"
                       href="@($"/orderitems/details?orderitem_id={orderitem.OrderItem_Id}")">
                        Подробнее
                    </a>
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>
</div>

@code {
    private ApplicationDbContext? context;
    private IQueryable<OrderItem> orderItems = Enumerable.Empty<OrderItem>().AsQueryable();

    private string searchText = string.Empty;

    private IQueryable<OrderItem> FilteredOrderItems => GetFilteredOrderItems();

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("OrderItems"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        context = DbFactory.CreateDbContext();

        orderItems = context.OrderItems
            .Include(orderItem => orderItem.Order)
            .Include(orderItem => orderItem.Product)
            .Include(orderItem => orderItem.Size)
            .AsNoTracking()
            .OrderByDescending(orderItem => orderItem.Order_Id)
            .ThenBy(orderItem => orderItem.OrderItem_Id);
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private IQueryable<OrderItem> GetFilteredOrderItems()
    {
        var query = orderItems;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return query;
        }

        var value = searchText.Trim();

        int? number = null;
        var onlyDigits = new string(value.Where(char.IsDigit).ToArray());

        if (int.TryParse(onlyDigits, out var parsedNumber))
        {
            number = parsedNumber;
        }

        var statusValues = GetSearchStatusValues(value);

        return query.Where(orderItem =>
            (number.HasValue &&
                (
                    orderItem.Order_Id == number.Value ||
                    orderItem.OrderItem_Quantity == number.Value
                )
            ) ||
            (orderItem.Product != null &&
                orderItem.Product.Product_Name.Contains(value)) ||
            (orderItem.Size != null &&
                orderItem.Size.Size_Name.Contains(value)) ||
            (orderItem.Order != null &&
             orderItem.Order.Order_Status != null &&
                (
                    orderItem.Order.Order_Status.Contains(value) ||
                    statusValues.Contains(orderItem.Order.Order_Status)
                )
            )
        );
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    private static string[] GetSearchStatusValues(string value)
    {
        var lowerValue = value
            .Trim()
            .ToLowerInvariant()
            .Replace("ё", "е");

        if (lowerValue.Contains("нов"))
        {
            return new[] { "new", "Новый" };
        }

        if (lowerValue.Contains("подтверж"))
        {
            return new[] { "confirmed", "Подтверждён", "Подтвержден" };
        }

        if (lowerValue.Contains("оплач"))
        {
            return new[] { "paid", "Оплачен" };
        }

        if (lowerValue.Contains("обработ"))
        {
            return new[] { "processing", "В обработке" };
        }

        if (lowerValue.Contains("отправ"))
        {
            return new[] { "shipped", "Отправлен" };
        }

        if (lowerValue.Contains("достав"))
        {
            return new[] { "delivered", "Доставлен" };
        }

        if (lowerValue.Contains("заверш"))
        {
            return new[] { "done", "Завершён", "Завершен" };
        }

        if (lowerValue.Contains("отмен"))
        {
            return new[] { "cancelled", "Отменён", "Отменен" };
        }

        if (lowerValue.Contains("возврат"))
        {
            return new[] { "returned", "Возврат" };
        }

        return Array.Empty<string>();
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetOrderStatusCssClass(string? status)
    {
        return status switch
        {
            "new" => "orderitems-status-new",
            "confirmed" => "orderitems-status-confirmed",
            "paid" => "orderitems-status-paid",
            "processing" => "orderitems-status-processing",
            "shipped" => "orderitems-status-shipped",
            "delivered" => "orderitems-status-delivered",
            "done" => "orderitems-status-done",
            "cancelled" => "orderitems-status-cancelled",
            "returned" => "orderitems-status-returned",
            _ => "orderitems-status-default"
        };
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportOrderItemsToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var orderItemsForExport = await dbContext.OrderItems
            .Include(orderItem => orderItem.Order)
            .Include(orderItem => orderItem.Product)
            .Include(orderItem => orderItem.Size)
            .AsNoTracking()
            .OrderBy(orderItem => orderItem.Order_Id)
            .ThenBy(orderItem => orderItem.OrderItem_Id)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Позиции заказа");

        worksheet.Cell(1, 1).Value = "Номер заказа";
        worksheet.Cell(1, 2).Value = "Статус заказа";
        worksheet.Cell(1, 3).Value = "Товар";
        worksheet.Cell(1, 4).Value = "Размер";
        worksheet.Cell(1, 5).Value = "Количество";
        worksheet.Cell(1, 6).Value = "Цена позиции";

        var headerRange = worksheet.Range(1, 1, 1, 6);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var orderItem in orderItemsForExport)
        {
            worksheet.Cell(row, 1).Value = $"Заказ №{orderItem.Order_Id}";
            worksheet.Cell(row, 2).Value = GetOrderStatusName(orderItem.Order?.Order_Status);
            worksheet.Cell(row, 3).Value = orderItem.Product?.Product_Name ?? "";
            worksheet.Cell(row, 4).Value = orderItem.Size?.Size_Name ?? "";
            worksheet.Cell(row, 5).Value = orderItem.OrderItem_Quantity;
            worksheet.Cell(row, 6).Value = orderItem.OrderItem_Price;

            row++;
        }

        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "orderitems.xlsx");
    }
}