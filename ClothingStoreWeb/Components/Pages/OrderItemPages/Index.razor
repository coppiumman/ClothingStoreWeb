@page "/orderitems"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Позиции заказа</PageTitle>

<h1>Позиции заказа</h1>

<div class="mb-3">
    <button type="button"
            class="btn btn-outline-success"
            @onclick="ExportOrderItemsToExcelAsync">
        Экспорт в Excel
    </button>
</div>

<QuickGrid Class="table" Items="orderItems">
    <TemplateColumn Title="Заказ">
        Заказ №@context.Order_Id
    </TemplateColumn>

    <TemplateColumn Title="Статус заказа">
        @GetOrderStatusName(context.Order?.Order_Status)
    </TemplateColumn>

    <TemplateColumn Title="Товар">
        @(context.Product?.Product_Name ?? context.Product_Id.ToString())
    </TemplateColumn>

    <TemplateColumn Title="Размер">
        @(context.Size?.Size_Name ?? context.Size_Id.ToString())
    </TemplateColumn>

    <PropertyColumn Property="orderitem => orderitem.OrderItem_Quantity" Title="Количество" />
    <PropertyColumn Property="orderitem => orderitem.OrderItem_Price" Title="Цена позиции" />

    <TemplateColumn Context="orderitem">
        <a href="@($"orderitems/details?orderitem_id={orderitem.OrderItem_Id}")">Подробнее</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private ApplicationDbContext? context;
    private IQueryable<OrderItem> orderItems = Enumerable.Empty<OrderItem>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("OrderItems"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        context = DbFactory.CreateDbContext();
        orderItems = context.OrderItems
            .Include(orderItem => orderItem.Order)
            .Include(orderItem => orderItem.Product)
            .Include(orderItem => orderItem.Size)
            .AsNoTracking()
            .OrderBy(orderItem => orderItem.OrderItem_Id);
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportOrderItemsToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var orderItemsForExport = await dbContext.OrderItems
            .Include(orderItem => orderItem.Order)
            .Include(orderItem => orderItem.Product)
            .Include(orderItem => orderItem.Size)
            .AsNoTracking()
            .OrderBy(orderItem => orderItem.Order_Id)
            .ThenBy(orderItem => orderItem.OrderItem_Id)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Позиции заказа");

        worksheet.Cell(1, 1).Value = "Номер заказа";
        worksheet.Cell(1, 2).Value = "Статус заказа";
        worksheet.Cell(1, 3).Value = "Товар";
        worksheet.Cell(1, 4).Value = "Размер";
        worksheet.Cell(1, 5).Value = "Количество";
        worksheet.Cell(1, 6).Value = "Цена позиции";

        var headerRange = worksheet.Range(1, 1, 1, 6);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var orderItem in orderItemsForExport)
        {
            worksheet.Cell(row, 1).Value = $"Заказ №{orderItem.Order_Id}";
            worksheet.Cell(row, 2).Value = GetOrderStatusName(orderItem.Order?.Order_Status);
            worksheet.Cell(row, 3).Value = orderItem.Product?.Product_Name ?? "";
            worksheet.Cell(row, 4).Value = orderItem.Size?.Size_Name ?? "";
            worksheet.Cell(row, 5).Value = orderItem.OrderItem_Quantity;
            worksheet.Cell(row, 6).Value = orderItem.OrderItem_Price;

            row++;
        }

        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "orderitems.xlsx");
    }
}
