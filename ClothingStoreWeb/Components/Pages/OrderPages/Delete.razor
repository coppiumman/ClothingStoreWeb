@page "/orders/delete"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Отмена заказа</PageTitle>

<div class="order-cancel-page">
    <div class="order-cancel-header">
        <h1>Отмена заказа</h1>
        <p>
            Перед отменой проверьте выбранный заказ. При отмене заказа приложение возвращает
            количество товаров на склад и меняет статус заказа на «Отменён».
        </p>
    </div>

    @if (order is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="order-cancel-card">
            <div class="order-cancel-warning">
                Вы действительно хотите отменить этот заказ?
            </div>

            <div class="order-cancel-row">
                <span>Номер заказа</span>
                <strong>Заказ №@order.Order_Id</strong>
            </div>

            <div class="order-cancel-row">
                <span>Пользователь</span>
                <strong>@GetUserDisplayName(order.User)</strong>
            </div>

            <div class="order-cancel-row">
                <span>Дата заказа</span>
                <strong>@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div class="order-cancel-row">
                <span>Статус заказа</span>
                <strong>@GetOrderStatusName(order.Order_Status)</strong>
            </div>

            <div class="order-cancel-row">
                <span>Сумма заказа</span>
                <strong>@order.Order_TotalAmount.ToString("N2") ₽</strong>
            </div>

            @if (!CanCancelOrder(order.Order_Status))
            {
                <div class="order-cancel-blocked">
                    Этот заказ нельзя отменить, потому что он уже закрыт или находится в финальном статусе.
                </div>
            }

            <EditForm method="post" Model="order" OnValidSubmit="CancelOrder" FormName="cancel" Enhance>
                <div class="order-cancel-actions">
                    <button type="submit"
                            class="order-button order-button-danger"
                            disabled="@(!CanCancelOrder(order.Order_Status))">
                        Отменить заказ
                    </button>

                    <a class="order-button" href="/orders">
                        Назад
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Order? order;

    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        order = await context.Orders
            .Include(o => o.User)
            .AsNoTracking()
            .FirstOrDefaultAsync(m => m.Order_Id == Order_Id);

        if (order is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private static bool CanCancelOrder(string? status)
    {
        return status == "new" ||
               status == "confirmed" ||
               status == "paid" ||
               status == "processing";
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "Пользователь не найден";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private async Task CancelOrder()
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        var orderFromDb = await context.Orders
            .Include(o => o.OrderItems)
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id);

        if (orderFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        if (!CanCancelOrder(orderFromDb.Order_Status))
        {
            NavigationManager.NavigateTo("/orders");
            return;
        }

        foreach (var orderItem in orderFromDb.OrderItems)
        {
            var stock = await context.Stocks
                .FirstOrDefaultAsync(s =>
                    s.Product_Id == orderItem.Product_Id &&
                    s.Size_Id == orderItem.Size_Id);

            if (stock is not null)
            {
                stock.Stock_Quantity += orderItem.OrderItem_Quantity;
            }
        }

        orderFromDb.Order_Status = "cancelled";
        orderFromDb.Order_StatusChangedAt = DateTime.Now;

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/orders");
    }
}