@page "/orders/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр</PageTitle>

<h1>Просмотр</h1>

<div>
    <h2>Заказ</h2>
    <hr />
    @if (order is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-3">Номер заказа</dt>
            <dd class="col-sm-9">Заказ №@order.Order_Id</dd>

            <dt class="col-sm-3">Пользователь</dt>
            <dd class="col-sm-9">@GetUserDisplayName(order.User)</dd>

            <dt class="col-sm-3">Дата заказа</dt>
            <dd class="col-sm-9">@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</dd>

            <dt class="col-sm-3">Статус заказа</dt>
            <dd class="col-sm-9">@GetOrderStatusName(order.Order_Status)</dd>

            <dt class="col-sm-3">Сумма заказа</dt>
            <dd class="col-sm-9">@order.Order_TotalAmount.ToString("N2") ₽</dd>
        </dl>

        <h3>Данные получателя</h3>
        <dl class="row">
            <dt class="col-sm-3">ФИО</dt>
            <dd class="col-sm-9">@GetTextOrEmpty(order.Order_RecipientName)</dd>

            <dt class="col-sm-3">Телефон</dt>
            <dd class="col-sm-9">@GetTextOrEmpty(order.Order_RecipientPhone)</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@GetTextOrEmpty(order.Order_RecipientEmail)</dd>
        </dl>

        <h3>Доставка и оплата</h3>
        <dl class="row">
            <dt class="col-sm-3">Способ доставки</dt>
            <dd class="col-sm-9">@GetDeliveryMethodName(order.Order_DeliveryMethod)</dd>

            <dt class="col-sm-3">Адрес доставки</dt>
            <dd class="col-sm-9">@GetTextOrEmpty(order.Order_DeliveryAddress)</dd>

            <dt class="col-sm-3">Стоимость доставки</dt>
            <dd class="col-sm-9">@order.Order_DeliveryAmount.ToString("N2") ₽</dd>

            <dt class="col-sm-3">Способ оплаты</dt>
            <dd class="col-sm-9">@GetPaymentMethodName(order.Order_PaymentMethod)</dd>

            <dt class="col-sm-3">Комментарий</dt>
            <dd class="col-sm-9">@GetTextOrEmpty(order.Order_Comment)</dd>
        </dl>

        <h3>Позиции заказа</h3>

        @if (order.OrderItems.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Размер</th>
                        <th>Количество</th>
                        <th>Цена позиции</th>
                        <th>Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in order.OrderItems)
                    {
                        <tr>
                            <td>@(item.Product?.Product_Name ?? item.Product_Id.ToString())</td>
                            <td>@(item.Size?.Size_Name ?? item.Size_Id.ToString())</td>
                            <td>@item.OrderItem_Quantity</td>
                            <td>@item.OrderItem_Price.ToString("N2") ₽</td>
                            <td>@((item.OrderItem_Quantity * item.OrderItem_Price).ToString("N2")) ₽</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>Позиции заказа не найдены.</p>
        }

        <div>
            @if (canEdit)
            {
                <a href="@($"/orders/edit?id={order.Order_Id}")">Изменить</a>
                <span> | </span>
            }
            <a href="/orders">Вернуться к списку</a>
        </div>
    }
</div>

@code {
    private Order? order;
    private bool canEdit;

    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Orders");

        using var context = DbFactory.CreateDbContext();
        order = await context.Orders
            .Include(o => o.User)
            .Include(o => o.OrderItems)
                .ThenInclude(orderItem => orderItem.Product)
            .Include(o => o.OrderItems)
                .ThenInclude(orderItem => orderItem.Size)
            .FirstOrDefaultAsync(m => m.Order_Id == Order_Id);

        if (order is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetTextOrEmpty(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "Не указано"
            : value;
    }

    private static string GetDeliveryMethodName(string? deliveryMethod)
    {
        return deliveryMethod switch
        {
            "pickup" => "Самовывоз",
            "courier" => "Курьерская доставка",
            "point" => "Пункт выдачи",
            _ => "Не указано"
        };
    }

    private static string GetPaymentMethodName(string? paymentMethod)
    {
        return paymentMethod switch
        {
            "cash" => "Оплата при получении",
            "card" => "Банковской картой при получении",
            _ => "Не указано"
        };
    }
}
