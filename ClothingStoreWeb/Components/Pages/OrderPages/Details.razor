@page "/orders/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр заказа</PageTitle>

<div class="order-details-page">
    <div class="order-details-header">
        <h1>Просмотр заказа</h1>
        <p>
            На странице отображаются основные данные заказа, информация о получателе,
            доставке, оплате и составе заказа.
        </p>
    </div>

    @if (order is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="order-details-summary">
            <div>
                <span>Номер заказа</span>
                <strong>Заказ №@order.Order_Id</strong>
            </div>

            <div>
                <span>Статус</span>
                <strong class="order-status @GetOrderStatusCssClass(order.Order_Status)">
                    @GetOrderStatusName(order.Order_Status)
                </strong>
            </div>

            <div>
                <span>Сумма заказа</span>
                <strong>@order.Order_TotalAmount.ToString("N2") ₽</strong>
            </div>
        </div>

        <div class="order-details-card">
            <h2>Основная информация</h2>

            <div class="order-details-row">
                <span>Пользователь</span>
                <strong>@GetUserDisplayName(order.User)</strong>
            </div>

            <div class="order-details-row">
                <span>Дата заказа</span>
                <strong>@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div class="order-details-row">
                <span>Получатель</span>
                <strong>@DisplayValue(order.Order_RecipientName)</strong>
            </div>

            <div class="order-details-row">
                <span>Телефон</span>
                <strong>@DisplayValue(order.Order_RecipientPhone)</strong>
            </div>

            <div class="order-details-row">
                <span>Email</span>
                <strong>@DisplayValue(order.Order_RecipientEmail)</strong>
            </div>
        </div>

        <div class="order-details-card">
            <h2>Доставка и оплата</h2>

            <div class="order-details-row">
                <span>Способ доставки</span>
                <strong>@DisplayValue(order.Order_DeliveryMethod)</strong>
            </div>

            <div class="order-details-row">
                <span>Адрес доставки</span>
                <strong>@DisplayValue(order.Order_DeliveryAddress)</strong>
            </div>

            <div class="order-details-row">
                <span>Стоимость доставки</span>
                <strong>@order.Order_DeliveryAmount.ToString("N2") ₽</strong>
            </div>

            <div class="order-details-row">
                <span>Способ оплаты</span>
                <strong>@DisplayValue(order.Order_PaymentMethod)</strong>
            </div>

            <div class="order-details-row">
                <span>Комментарий</span>
                <strong>@DisplayValue(order.Order_Comment)</strong>
            </div>
        </div>

        <div class="order-details-card">
            <h2>Состав заказа</h2>

            @if (order.OrderItems is null || !order.OrderItems.Any())
            {
                <div class="order-details-empty">
                    В заказе нет позиций.
                </div>
            }
            else
            {
                <div class="order-items-table-wrap">
                    <table class="order-items-table">
                        <thead>
                            <tr>
                                <th>Товар</th>
                                <th>Размер</th>
                                <th>Количество</th>
                                <th>Цена позиции</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td>@(item.Product?.Product_Name ?? "Товар не найден")</td>
                                    <td>@(item.Size?.Size_Name ?? "Размер не найден")</td>
                                    <td>@item.OrderItem_Quantity</td>
                                    <td>@item.OrderItem_Price.ToString("N2") ₽</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="order-details-actions">
            <a class="order-button order-button-primary" href="/orders">
                Вернуться к списку
            </a>
        </div>
    }
</div>

@code {
    private Order? order;

    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        order = await context.Orders
            .Include(o => o.User)
            .Include(o => o.OrderItems)
                .ThenInclude(item => item.Product)
            .Include(o => o.OrderItems)
                .ThenInclude(item => item.Size)
            .AsNoTracking()
            .FirstOrDefaultAsync(m => m.Order_Id == Order_Id);

        if (order is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Не указано" : value;
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "Пользователь не найден";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetOrderStatusCssClass(string? status)
    {
        return status switch
        {
            "new" => "order-status-new",
            "confirmed" => "order-status-confirmed",
            "paid" => "order-status-paid",
            "processing" => "order-status-processing",
            "shipped" => "order-status-shipped",
            "delivered" => "order-status-delivered",
            "done" => "order-status-done",
            "cancelled" => "order-status-cancelled",
            "returned" => "order-status-returned",
            _ => "order-status-default"
        };
    }
}