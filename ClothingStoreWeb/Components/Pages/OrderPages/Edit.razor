@* @page "/orders/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование заказа</PageTitle>

<div class="order-form-page">
    <div class="order-form-header">
        <h1>Редактирование заказа</h1>
        <p>
            Измените статус заказа и основные служебные данные. Если заказ уже закрыт,
            его статус нельзя изменить вручную.
        </p>
    </div>

    @if (Order is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="order-form-card">
            <EditForm method="post" Model="Order" OnValidSubmit="UpdateOrder" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" class="text-danger" />

                <input type="hidden" name="Order.Order_Id" value="@Order.Order_Id" />

                @if (!string.IsNullOrWhiteSpace(statusChangeError))
                {
                    <div class="order-form-alert">
                        @statusChangeError
                    </div>
                }

                <div class="order-form-info">
                    <div class="order-form-info-row">
                        <span>Номер заказа</span>
                        <strong>Заказ №@Order.Order_Id</strong>
                    </div>

                    <div class="order-form-info-row">
                        <span>Текущий статус</span>
                        <strong>@GetOrderStatusName(Order.Order_Status)</strong>
                    </div>
                </div>

                <div class="order-form-group">
                    <label for="user_id">Пользователь</label>

                    <InputSelect id="user_id"
                                 @bind-Value="Order.User_Id"
                                 class="order-form-control"
                                 aria-required="true">
                        <option value="">Выберите пользователя</option>
                        @foreach (var user in Users)
                        {
                            <option value="@user.Id">@GetUserDisplayName(user)</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => Order.User_Id" class="text-danger" />
                </div>

                <div class="order-form-group">
                    <label for="order_date">Дата заказа <span>*</span></label>

                    <InputDate id="order_date"
                               @bind-Value="Order.Order_Date"
                               class="order-form-control"
                               aria-required="true"
                               ParsingErrorMessage="Введите корректную дату заказа" />

                    <ValidationMessage For="() => Order.Order_Date" class="text-danger" />
                </div>

                <div class="order-form-group">
                    <label for="order_status">Статус заказа <span>*</span></label>

                    <InputSelect id="order_status"
                                 @bind-Value="Order.Order_Status"
                                 class="order-form-control"
                                 aria-required="true"
                                 disabled="@isFinalStatus">
                        <option value="">Выберите статус</option>
                        @foreach (var status in OrderStatuses)
                        {
                            <option value="@status.Value">@status.Name</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => Order.Order_Status" class="text-danger" />

                    @if (isFinalStatus)
                    {
                        <div class="order-form-note">
                            Статус закрытого заказа зафиксирован и недоступен для ручного изменения.
                        </div>
                    }
                </div>

                <div class="order-form-group">
                    <label for="order_totalamount">Сумма заказа <span>*</span></label>

                    <InputNumber id="order_totalamount"
                                 @bind-Value="Order.Order_TotalAmount"
                                 class="order-form-control"
                                 aria-required="true"
                                 ParsingErrorMessage="Введите корректную сумму заказа" />

                    <ValidationMessage For="() => Order.Order_TotalAmount" class="text-danger" />
                </div>

                <div class="order-form-actions">
                    <button type="submit" class="order-button order-button-primary">
                        Сохранить изменения
                    </button>

                    <a class="order-button" href="/orders">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    [SupplyParameterFromForm]
    private Order? Order { get; set; }

    private List<ApplicationUser> Users { get; set; } = new();

    private string? statusChangeError;
    private bool isFinalStatus;

    private static readonly (string Value, string Name)[] OrderStatuses =
    {
        ("new", "Новый"),
        ("confirmed", "Подтверждён"),
        ("paid", "Оплачен"),
        ("processing", "В обработке"),
        ("shipped", "Отправлен"),
        ("delivered", "Доставлен"),
        ("done", "Завершён"),
        ("cancelled", "Отменён"),
        ("returned", "Возврат")
    };

    private static string NormalizeStatus(string? status)
    {
        return status switch
        {
            "Новый" => "new",
            "Подтверждён" => "confirmed",
            "Оплачен" => "paid",
            "В обработке" => "processing",
            "Отправлен" => "shipped",
            "Доставлен" => "delivered",
            "Завершён" => "done",
            "Отменён" => "cancelled",
            "Возврат" => "returned",
            _ => status ?? ""
        };
    }

    private static bool IsFinalStatus(string? status)
    {
        return status is "cancelled" or "shipped" or "delivered" or "done" or "returned";
    }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        Order ??= await context.Orders
            .FirstOrDefaultAsync(m => m.Order_Id == Order_Id);

        if (Order is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        Order.Order_Status = NormalizeStatus(Order.Order_Status);
        isFinalStatus = IsFinalStatus(Order.Order_Status);

        Users = await context.Users
            .OrderBy(user => user.UserFullName)
            .ThenBy(user => user.Email)
            .ToListAsync();
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private async Task UpdateOrder()
    {
        if (Order is null)
            return;

        statusChangeError = null;

        await using var context = await DbFactory.CreateDbContextAsync();

        var orderFromDb = await context.Orders
            .Include(o => o.OrderItems)
            .FirstOrDefaultAsync(o => o.Order_Id == Order.Order_Id);

        if (orderFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var oldStatus = NormalizeStatus(orderFromDb.Order_Status);
        var newStatus = NormalizeStatus(Order.Order_Status);

        if (IsFinalStatus(oldStatus) && oldStatus != newStatus)
        {
            statusChangeError = "Статус закрытого заказа нельзя изменить.";
            Order.Order_Status = oldStatus;
            isFinalStatus = true;
            return;
        }

        if (oldStatus != "cancelled" && newStatus == "cancelled")
        {
            foreach (var orderItem in orderFromDb.OrderItems)
            {
                var stock = await context.Stocks
                    .FirstOrDefaultAsync(stock =>
                        stock.Product_Id == orderItem.Product_Id &&
                        stock.Size_Id == orderItem.Size_Id);

                if (stock is not null)
                {
                    stock.Stock_Quantity += orderItem.OrderItem_Quantity;
                }
            }
        }

        orderFromDb.User_Id = Order.User_Id;
        orderFromDb.Order_Date = Order.Order_Date;
        orderFromDb.Order_Status = newStatus;
        orderFromDb.Order_TotalAmount = Order.Order_TotalAmount;
        orderFromDb.Order_StatusChangedAt = DateTime.Now;

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/orders");
    }
} *@