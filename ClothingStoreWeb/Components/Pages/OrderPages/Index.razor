@page "/orders"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Заказы</PageTitle>

<h1>Заказы</h1>

<div class="mb-3">
    <button type="button"
            class="btn btn-outline-success"
            @onclick="ExportOrdersToExcelAsync">
        Экспорт в Excel
    </button>
</div>

<QuickGrid Class="table" Items="orders">
    <TemplateColumn Title="Номер заказа">
        Заказ №@context.Order_Id
    </TemplateColumn>
    <TemplateColumn Title="Пользователь">
        @GetUserDisplayName(context.User)
    </TemplateColumn>
    <PropertyColumn Property="order => order.Order_Date" Title="Дата заказа" />
    <TemplateColumn Title="Статус заказа">
        @GetOrderStatusName(context.Order_Status)
    </TemplateColumn>
    <PropertyColumn Property="order => order.Order_TotalAmount" Title="Сумма заказа" />

    <TemplateColumn Context="order">
        <td class="table-actions">
            @if (canEdit)
            {
                <a href="@($"/orders/edit?id={order.Order_Id}")">Изменить</a>
                <span> | </span>
            }

            <a href="@($"/orders/details?id={order.Order_Id}")">Подробнее</a>

            @if (canEdit)
            {
                @if (CanCancelOrder(order.Order_Status))
                {
                    <span> | </span>
                    <a href="@($"/orders/delete?id={order.Order_Id}")">Отменить</a>
                }
                else
                {
                    <span class="text-muted">Отмена недоступна</span>
                }
            }
        </td>
    </TemplateColumn>
</QuickGrid>

@code {
    private ApplicationDbContext? context;
    private IQueryable<Order> orders = Enumerable.Empty<Order>().AsQueryable();
    private bool canCreate;
    private bool canEdit;
    private bool canDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canCreate = await AccessService.CanCreateAsync("Orders");
        canEdit = await AccessService.CanEditAsync("Orders");
        canDelete = await AccessService.CanDeleteAsync("Orders");

        context = DbFactory.CreateDbContext();
        orders = context.Orders
            .Include(order => order.User)
            .AsNoTracking()
            .OrderBy(order => order.Order_Id);
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
            return "";

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
            return user.UserFullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        return user.Id;
    }

    private static bool CanCancelOrder(string? status)
    {
        return status == "new" ||
               status == "confirmed" ||
               status == "paid" ||
               status == "processing";
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportOrdersToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var ordersForExport = await dbContext.Orders
            .Include(order => order.User)
            .AsNoTracking()
            .OrderBy(order => order.Order_Id)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Заказы");

        worksheet.Cell(1, 1).Value = "Номер заказа";
        worksheet.Cell(1, 2).Value = "Пользователь";
        worksheet.Cell(1, 3).Value = "Дата заказа";
        worksheet.Cell(1, 4).Value = "Статус заказа";
        worksheet.Cell(1, 5).Value = "Сумма заказа";
        worksheet.Cell(1, 6).Value = "Получатель";
        worksheet.Cell(1, 7).Value = "Телефон";
        worksheet.Cell(1, 8).Value = "Email";
        worksheet.Cell(1, 9).Value = "Способ доставки";
        worksheet.Cell(1, 10).Value = "Адрес доставки";
        worksheet.Cell(1, 11).Value = "Стоимость доставки";
        worksheet.Cell(1, 12).Value = "Способ оплаты";
        worksheet.Cell(1, 13).Value = "Комментарий";

        var headerRange = worksheet.Range(1, 1, 1, 13);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var order in ordersForExport)
        {
            worksheet.Cell(row, 1).Value = $"Заказ №{order.Order_Id}";
            worksheet.Cell(row, 2).Value = GetUserDisplayName(order.User);
            worksheet.Cell(row, 3).Value = order.Order_Date;
            worksheet.Cell(row, 4).Value = GetOrderStatusName(order.Order_Status);
            worksheet.Cell(row, 5).Value = order.Order_TotalAmount;
            worksheet.Cell(row, 6).Value = order.Order_RecipientName ?? "";
            worksheet.Cell(row, 7).Value = order.Order_RecipientPhone ?? "";
            worksheet.Cell(row, 8).Value = order.Order_RecipientEmail ?? "";
            worksheet.Cell(row, 9).Value = order.Order_DeliveryMethod ?? "";
            worksheet.Cell(row, 10).Value = order.Order_DeliveryAddress ?? "";
            worksheet.Cell(row, 11).Value = order.Order_DeliveryAmount;
            worksheet.Cell(row, 12).Value = order.Order_PaymentMethod ?? "";
            worksheet.Cell(row, 13).Value = order.Order_Comment ?? "";

            row++;
        }

        worksheet.Column(3).Style.DateFormat.Format = "dd.MM.yyyy HH:mm";
        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "orders.xlsx");
    }
}
