@page "/orders"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Заказы</PageTitle>

<div class="orders-page">
    <div class="orders-header">
        <div>
            <h1>Заказы</h1>
            <p>
                В разделе отображаются заказы покупателей. Сотрудник может найти нужный заказ,
                посмотреть состав заказа, изменить статус или отменить заказ, если его обработка ещё не завершена.
            </p>
        </div>

        <div class="orders-header-actions">
            <button type="button"
                    class="orders-button orders-button-secondary"
                    @onclick="ExportOrdersToExcelAsync">
                Экспорт в Excel
            </button>
        </div>
    </div>

    <div class="orders-filter-panel">
        <label for="order-search">Поиск заказа</label>

        <div class="orders-search-row">
            <input id="order-search"
                   type="search"
                   class="orders-search-input"
                   @bind="searchText"
                   @bind:event="oninput"
                   placeholder="Введите № заказа, ФИО, email или дату" />

            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <button type="button"
                        class="orders-button"
                        @onclick="ClearSearch">
                    Очистить
                </button>
            }
        </div>

        <div class="orders-filter-hint">
            Например: <strong>24</strong>, <strong>Иванов</strong>, <strong>admin@admin.ru</strong> или <strong>24.05.2026</strong>.
        </div>
    </div>

    <div class="orders-table-card">
        <QuickGrid Class="orders-table" Items="FilteredOrders">
            <TemplateColumn Title="Номер заказа" Context="order">
                Заказ №@order.Order_Id
            </TemplateColumn>

            <TemplateColumn Title="Пользователь" Context="order">
                @GetUserDisplayName(order.User)
            </TemplateColumn>

            <TemplateColumn Title="Дата заказа" Context="order">
                @order.Order_Date.ToString("dd.MM.yyyy HH:mm")
            </TemplateColumn>

            <TemplateColumn Title="Статус" Context="order">
                <span class="orders-status @GetOrderStatusCssClass(order.Order_Status)">
                    @GetOrderStatusName(order.Order_Status)
                </span>
            </TemplateColumn>

            <TemplateColumn Title="Сумма заказа" Context="order">
                @order.Order_TotalAmount.ToString("N2") ₽
            </TemplateColumn>

            <TemplateColumn Title="Действия" Context="order">
                <div class="orders-actions">
                    <a class="orders-action-button"
                       href="@($"/orders/details?id={order.Order_Id}")">
                        Подробнее
                    </a>

                    @if (canDelete && CanCancelOrder(order.Order_Status))
                    {
                        <a class="orders-action-button orders-action-danger"
                           href="@($"/orders/delete?id={order.Order_Id}")">
                            Отменить
                        </a>
                    }
                    else if (canDelete)
                    {
                        <span class="orders-action-muted">
                            Отмена недоступна
                        </span>
                    }
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>
</div>

@code {
    private ApplicationDbContext? context;
    private IQueryable<Order> orders = Enumerable.Empty<Order>().AsQueryable();

    private bool canDelete;

    private string searchText = string.Empty;

    private IQueryable<Order> FilteredOrders => GetFilteredOrders();

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Orders"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canDelete = await AccessService.CanDeleteAsync("Orders");

        context = DbFactory.CreateDbContext();

        orders = context.Orders
            .Include(order => order.User)
            .AsNoTracking()
            .OrderByDescending(order => order.Order_Date)
            .ThenByDescending(order => order.Order_Id);
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private IQueryable<Order> GetFilteredOrders()
    {
        var query = orders;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return query;
        }

        var value = searchText.Trim();

        int? orderId = null;
        var onlyDigits = new string(value.Where(char.IsDigit).ToArray());

        if (int.TryParse(onlyDigits, out var parsedOrderId))
        {
            orderId = parsedOrderId;
        }

        DateTime? orderDate = null;

        if (DateTime.TryParseExact(
                value,
                new[] { "dd.MM.yyyy", "d.M.yyyy", "yyyy-MM-dd" },
                CultureInfo.GetCultureInfo("ru-RU"),
                DateTimeStyles.None,
                out var parsedDate))
        {
            orderDate = parsedDate.Date;
        }

        var dateStart = orderDate;
        var dateEnd = orderDate?.AddDays(1);

        return query.Where(order =>
            (orderId.HasValue && order.Order_Id == orderId.Value) ||
            (order.User != null &&
                (
                    (order.User.UserFullName != null && order.User.UserFullName.Contains(value)) ||
                    (order.User.Email != null && order.User.Email.Contains(value))
                )
            ) ||
            (dateStart.HasValue &&
                order.Order_Date >= dateStart.Value &&
                order.Order_Date < dateEnd!.Value)
        );
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    private static string GetUserDisplayName(ApplicationUser? user)
    {
        if (user is null)
        {
            return "";
        }

        if (!string.IsNullOrWhiteSpace(user.UserFullName))
        {
            return user.UserFullName;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            return user.Email;
        }

        return user.Id;
    }

    private static bool CanCancelOrder(string? status)
    {
        return status == "new" ||
               status == "confirmed" ||
               status == "paid" ||
               status == "processing";
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetOrderStatusCssClass(string? status)
    {
        return status switch
        {
            "new" => "orders-status-new",
            "confirmed" => "orders-status-confirmed",
            "paid" => "orders-status-paid",
            "processing" => "orders-status-processing",
            "shipped" => "orders-status-shipped",
            "delivered" => "orders-status-delivered",
            "done" => "orders-status-done",
            "cancelled" => "orders-status-cancelled",
            "returned" => "orders-status-returned",
            _ => "orders-status-default"
        };
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportOrdersToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var ordersForExport = await dbContext.Orders
            .Include(order => order.User)
            .AsNoTracking()
            .OrderByDescending(order => order.Order_Date)
            .ThenByDescending(order => order.Order_Id)
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Заказы");

        worksheet.Cell(1, 1).Value = "Номер заказа";
        worksheet.Cell(1, 2).Value = "Пользователь";
        worksheet.Cell(1, 3).Value = "Дата заказа";
        worksheet.Cell(1, 4).Value = "Статус заказа";
        worksheet.Cell(1, 5).Value = "Сумма заказа";
        worksheet.Cell(1, 6).Value = "Получатель";
        worksheet.Cell(1, 7).Value = "Телефон";
        worksheet.Cell(1, 8).Value = "Email";
        worksheet.Cell(1, 9).Value = "Способ доставки";
        worksheet.Cell(1, 10).Value = "Адрес доставки";
        worksheet.Cell(1, 11).Value = "Стоимость доставки";
        worksheet.Cell(1, 12).Value = "Способ оплаты";
        worksheet.Cell(1, 13).Value = "Комментарий";

        var headerRange = worksheet.Range(1, 1, 1, 13);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var order in ordersForExport)
        {
            worksheet.Cell(row, 1).Value = $"Заказ №{order.Order_Id}";
            worksheet.Cell(row, 2).Value = GetUserDisplayName(order.User);
            worksheet.Cell(row, 3).Value = order.Order_Date;
            worksheet.Cell(row, 4).Value = GetOrderStatusName(order.Order_Status);
            worksheet.Cell(row, 5).Value = order.Order_TotalAmount;
            worksheet.Cell(row, 6).Value = order.Order_RecipientName ?? "";
            worksheet.Cell(row, 7).Value = order.Order_RecipientPhone ?? "";
            worksheet.Cell(row, 8).Value = order.Order_RecipientEmail ?? "";
            worksheet.Cell(row, 9).Value = order.Order_DeliveryMethod ?? "";
            worksheet.Cell(row, 10).Value = order.Order_DeliveryAddress ?? "";
            worksheet.Cell(row, 11).Value = order.Order_DeliveryAmount;
            worksheet.Cell(row, 12).Value = order.Order_PaymentMethod ?? "";
            worksheet.Cell(row, 13).Value = order.Order_Comment ?? "";

            row++;
        }

        worksheet.Column(3).Style.DateFormat.Format = "dd.MM.yyyy HH:mm";
        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "orders.xlsx");
    }
}