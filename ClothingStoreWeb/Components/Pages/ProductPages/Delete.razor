@page "/products/delete"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Удаление товара</PageTitle>

<div class="product-details-page">
    <div class="product-details-header">
        <div>
            <h1>Удаление товара</h1>
            <p>
                Перед удалением проверьте выбранный товар. Если товар используется в заказах
                или складских записях, приложение не позволит удалить его из базы данных.
            </p>
        </div>
    </div>

    @if (product is null)
    {
        <div class="product-details-card">
            <p><em>Загрузка...</em></p>
        </div>
    }
    else
    {
        <div class="product-details-card">
            <div class="product-delete-warning">
                Вы действительно хотите удалить этот товар?
            </div>

            <div class="product-details-grid">
                <div class="product-details-info">
                    <div class="product-details-row">
                        <span>Категория</span>
                        <strong>@product.Category?.Category_Name</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Название товара</span>
                        <strong>@product.Product_Name</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Описание товара</span>
                        <strong>
                            @(string.IsNullOrWhiteSpace(product.Product_Description)
                                                    ? "Описание не указано"
                                                    : product.Product_Description)
                                                                              </strong>
                                                                          </div>

                    <div class="product-details-row">
                        <span>Цена</span>
                        <strong>@product.Product_Price.ToString("N2") ₽</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Цвет</span>
                        <strong>
                            @(string.IsNullOrWhiteSpace(product.Product_Coloring)
                                                    ? "Цвет не указан"
                                                    : product.Product_Coloring)
                    </strong>
                </div>

                    <div class="product-details-row">
                        <span>Статус</span>
                    @if (product.Product_IsHidden)
                        {
                            <strong class="product-status product-status-hidden">Скрыт</strong>
                        }
                        else
                        {
                            <strong class="product-status product-status-visible">Отображается</strong>
                        }
                    </div>
                </div>

                <div class="product-details-image">
                    @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath))
                    {
                        <img src="@product.Product_ImagePath"
                             alt="@product.Product_Name" />
                    }
                    else
                    {
                        <span>Изображение не загружено</span>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(deleteError))
            {
                <div class="product-delete-error">
                    @deleteError
                </div>
            }

            <EditForm method="post" Model="product" OnValidSubmit="DeleteProduct" FormName="delete" Enhance>
                <div class="product-form-actions">
                    <button type="submit"
                            class="product-delete-button"
                            disabled="@(product is null)">
                        Удалить товар
                    </button>

                    <a class="product-secondary-button" href="/products">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Product? product;
    private string? deleteError;

    [SupplyParameterFromQuery]
    private int Product_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Products"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();
        product = await context.Products
            .Include(p => p.Category)
            .FirstOrDefaultAsync(m => m.Product_Id == Product_Id);

        if (product is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteProduct()
    {
        if (product is null)
        {
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var productFromDb = await context.Products
            .FirstOrDefaultAsync(p => p.Product_Id == product.Product_Id);

        if (productFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var isUsedInOrders = await context.OrderItems
            .AnyAsync(orderItem => orderItem.Product_Id == productFromDb.Product_Id);

        if (isUsedInOrders)
        {
            deleteError = "Удаление невозможно: товар уже используется в заказах. Скройте товар вместо удаления.";
            return;
        }

        var hasStocks = await context.Stocks
            .AnyAsync(stock => stock.Product_Id == productFromDb.Product_Id);

        if (hasStocks)
        {
            deleteError = "Удаление невозможно: для товара существуют складские записи. Скройте товар вместо удаления.";
            return;
        }

        context.Products.Remove(productFromDb);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/products");
    }
}
