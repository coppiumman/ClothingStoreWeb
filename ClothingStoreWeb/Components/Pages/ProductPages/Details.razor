@page "/products/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр товара</PageTitle>

<div class="product-details-page">
    <div class="product-details-header">
        <div>
            <h1>Просмотр товара</h1>
            <p>
                На странице отображаются основные данные товара, его статус и изображение.
            </p>
        </div>
    </div>

    @if (product is null)
    {
        <div class="product-details-card">
            <p><em>Загрузка...</em></p>
        </div>
    }
    else
    {
        <div class="product-details-card">
            <div class="product-details-grid">
                <div class="product-details-info">
                    <div class="product-details-row">
                        <span>Категория</span>
                        <strong>@product.Category?.Category_Name</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Название товара</span>
                        <strong>@product.Product_Name</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Описание товара</span>
                        <strong>
                            @(string.IsNullOrWhiteSpace(product.Product_Description)
                                                    ? "Описание не указано"
                                                    : product.Product_Description)
                                                                              </strong>
                                                                          </div>

                    <div class="product-details-row">
                        <span>Цена</span>
                        <strong>@product.Product_Price.ToString("N2") ₽</strong>
                    </div>

                    <div class="product-details-row">
                        <span>Цвет</span>
                        <strong>
                            @(string.IsNullOrWhiteSpace(product.Product_Coloring)
                                                    ? "Цвет не указан"
                                                    : product.Product_Coloring)
                    </strong>
                </div>

                    <div class="product-details-row">
                        <span>Статус</span>
                    @if (product.Product_IsHidden)
                        {
                            <strong class="product-status product-status-hidden">Скрыт</strong>
                        }
                        else
                        {
                            <strong class="product-status product-status-visible">Отображается</strong>
                        }
                    </div>
                </div>

                <div class="product-details-images-grid">
                    <div class="product-details-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath))
                        {
                            <img src="@product.Product_ImagePath" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>

                    <div class="product-details-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath2))
                        {
                            <img src="@product.Product_ImagePath2" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>

                    <div class="product-details-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath3))
                        {
                            <img src="@product.Product_ImagePath3" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>

                    <div class="product-details-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath4))
                        {
                            <img src="@product.Product_ImagePath4" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>
                </div>
            </div>

            <div class="product-form-actions">
                @if (canEdit)
                {
                    <a class="product-submit-button product-submit-link"
                       href="@($"/products/edit?product_id={product.Product_Id}")">
                        Изменить
                    </a>
                }

                <a class="product-secondary-button" href="/products">
                    Вернуться к списку
                </a>
            </div>
        </div>
    }
</div>

@code {
    private Product? product;
    private bool canEdit;

    [SupplyParameterFromQuery]
    private int Product_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Products"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Products");

        using var context = DbFactory.CreateDbContext();

        product = await context.Products
            .Include(p => p.Category)
            .FirstOrDefaultAsync(m => m.Product_Id == Product_Id);

        if (product is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}