@page "/products/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Forms
@inject IWebHostEnvironment Environment

<PageTitle>Редактирование</PageTitle>

<h1>Редактирование</h1>

<h2>Товар</h2>
<hr />
@if (Product is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="product-edit-page">
            <EditForm method="post" Model="Product" OnValidSubmit="UpdateProduct" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />
                <input type="hidden" name="Product.Product_Id" value="@Product.Product_Id" />

                <div class="product-edit-layout">
                    <div class="product-edit-fields">
                        <div class="mb-3">
                            <label for="category_id" class="form-label">Категория</label>
                            <InputSelect id="category_id" @bind-Value="Product.Category_Id" class="form-control" aria-required="true">
                                <option value="0">Выберите категорию</option>
                                @foreach (var category in Categories)
                                {
                                    <option value="@category.Category_Id">@category.Category_Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => Product.Category_Id" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <span class="text-danger">*</span>
                            <label for="product_name" class="form-label">Название товара:</label>
                            <InputText id="product_name" @bind-Value="Product.Product_Name" class="form-control" aria-required="true" />
                            <ValidationMessage For="() => Product.Product_Name" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label for="product_description" class="form-label">Описание товара:</label>
                            <InputText id="product_description" @bind-Value="Product.Product_Description" class="form-control" />
                            <ValidationMessage For="() => Product.Product_Description" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <span class="text-danger">*</span>
                            <label for="product_price" class="form-label">Цена:</label>
                            <InputNumber id="product_price" @bind-Value="Product.Product_Price" class="form-control" aria-required="true" ParsingErrorMessage="Введите корректную цену" />
                            <ValidationMessage For="() => Product.Product_Price" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label for="product_coloring" class="form-label">Цвет:</label>
                            <InputText id="product_coloring" @bind-Value="Product.Product_Coloring" class="form-control" />
                            <ValidationMessage For="() => Product.Product_Coloring" class="text-danger" />
                        </div>

                        <button type="submit" class="btn btn-primary">Сохранить</button>

                        <div class="mt-2">
                            <a href="/products">Вернуться к списку</a>
                        </div>
                    </div>

                    <div class="product-edit-images-panel">
                        <h3>Изображения товара</h3>

                        <div class="product-images-grid">
                            <div class="product-image-edit-block">
                                <label for="product_image1" class="form-label">Основное изображение:</label>
                                <InputFile id="product_image1" OnChange="UploadMainImage" class="form-control" accept="image/*" />

                            <div class="product-image-preview">
                                @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath))
                                {
                                    <img src="@Product.Product_ImagePath" alt="Основное изображение товара" />
                                }
                                else
                                {
                                    <span class="product-no-preview">Изображение не загружено</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath))
                            {
                                <div class="product-image-actions">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Product.Product_ImagePath"
                                       download>
                                        Скачать изображение
                                    </a>

                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearMainImage">
                                        Удалить изображение
                                    </button>
                                </div>
                            }

                                <ValidationMessage For="() => Product.Product_ImagePath" class="text-danger" />
                            </div>

                            <div class="product-image-edit-block">
                                <label for="product_image2" class="form-label">Дополнительное изображение 1:</label>
                                <InputFile id="product_image2" OnChange="UploadImage2" class="form-control" accept="image/*" />

                            <div class="product-image-preview">
                                @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath2))
                                {
                                    <img src="@Product.Product_ImagePath2" alt="Дополнительное изображение 1" />
                                }
                                else
                                {
                                    <span class="product-no-preview">Изображение не загружено</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath2))
                            {
                                <div class="product-image-actions">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Product.Product_ImagePath2"
                                       download>
                                        Скачать изображение
                                    </a>

                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearImage2">
                                        Удалить изображение
                                    </button>
                                </div>
                            }

                                <ValidationMessage For="() => Product.Product_ImagePath2" class="text-danger" />
                            </div>

                            <div class="product-image-edit-block">
                                <label for="product_image3" class="form-label">Дополнительное изображение 2:</label>
                                <InputFile id="product_image3" OnChange="UploadImage3" class="form-control" accept="image/*" />

                            <div class="product-image-preview">
                                @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath3))
                                {
                                    <img src="@Product.Product_ImagePath3" alt="Дополнительное изображение 2" />
                                }
                                else
                                {
                                    <span class="product-no-preview">Изображение не загружено</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath3))
                            {
                                <div class="product-image-actions">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Product.Product_ImagePath3"
                                       download>
                                        Скачать изображение
                                    </a>

                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearImage3">
                                        Удалить изображение
                                    </button>
                                </div>
                            }

                                <ValidationMessage For="() => Product.Product_ImagePath3" class="text-danger" />
                            </div>

                            <div class="product-image-edit-block">
                                <label for="product_image4" class="form-label">Дополнительное изображение 3:</label>
                                <InputFile id="product_image4" OnChange="UploadImage4" class="form-control" accept="image/*" />

                            <div class="product-image-preview">
                                @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath4))
                                {
                                    <img src="@Product.Product_ImagePath4" alt="Дополнительное изображение 3" />
                                }
                                else
                                {
                                    <span class="product-no-preview">Изображение не загружено</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Product.Product_ImagePath4))
                            {
                                <div class="product-image-actions">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Product.Product_ImagePath4"
                                       download>
                                        Скачать изображение
                                    </a>

                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearImage4">
                                        Удалить изображение
                                    </button>
                                </div>
                            }

                                <ValidationMessage For="() => Product.Product_ImagePath4" class="text-danger" />
                            </div>
                        </div>
                    </div>
                </div>
            </EditForm>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    private int Product_Id { get; set; }

    [SupplyParameterFromForm]
    private Product? Product { get; set; }

    private List<Category> Categories { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Products"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();

        Categories = await context.Categories.ToListAsync();

        Product ??= await context.Products.FirstOrDefaultAsync(m => m.Product_Id == Product_Id);

        if (Product is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }
    }

    private async Task UpdateProduct()
    {
        if (Product is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var productFromDb = await context.Products
            .FirstOrDefaultAsync(product => product.Product_Id == Product.Product_Id);

        if (productFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var oldCategoryId = productFromDb.Category_Id;
        var newCategoryId = Product.Category_Id;
        var categoryChanged = oldCategoryId != newCategoryId;

        productFromDb.Category_Id = Product.Category_Id;
        productFromDb.Product_Name = Product.Product_Name;
        productFromDb.Product_Description = Product.Product_Description;
        productFromDb.Product_Price = Product.Product_Price;
        productFromDb.Product_Coloring = Product.Product_Coloring;

        productFromDb.Product_ImagePath = Product.Product_ImagePath;
        productFromDb.Product_ImagePath2 = Product.Product_ImagePath2;
        productFromDb.Product_ImagePath3 = Product.Product_ImagePath3;
        productFromDb.Product_ImagePath4 = Product.Product_ImagePath4;

        if (categoryChanged)
        {
            var maxDisplayOrder = await context.Products
                .Where(product =>
                    product.Category_Id == newCategoryId &&
                    product.Product_Id != productFromDb.Product_Id)
                .MaxAsync(product => (int?)product.Product_DisplayOrder) ?? 0;

            productFromDb.Product_DisplayOrder = maxDisplayOrder + 1;
        }

        try
        {
            await context.SaveChangesAsync();

            if (categoryChanged)
            {
                await NormalizeProductOrderAsync(context, oldCategoryId);
                await NormalizeProductOrderAsync(context, newCategoryId);
            }
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!ProductExists(Product.Product_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo("/products");
    }

    private async Task NormalizeProductOrderAsync(ClothingStoreWeb.Data.ApplicationDbContext context, int categoryId)
    {
        var products = await context.Products
            .Where(product => product.Category_Id == categoryId)
            .OrderBy(product => product.Product_DisplayOrder)
            .ThenBy(product => product.Product_Id)
            .ToListAsync();

        for (var i = 0; i < products.Count; i++)
        {
            products[i].Product_DisplayOrder = i + 1;
        }

        await context.SaveChangesAsync();
    }

    private bool ProductExists(int product_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Products.Any(e => e.Product_Id == product_id);
    }

    private void ClearMainImage()
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath = null;
    }

    private void ClearImage2()
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath2 = null;
    }

    private void ClearImage3()
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath3 = null;
    }

    private void ClearImage4()
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath4 = null;
    }

    private async Task UploadMainImage(InputFileChangeEventArgs e)
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath = await SaveImageAsync(e);
    }

    private async Task UploadImage2(InputFileChangeEventArgs e)
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath2 = await SaveImageAsync(e);
    }

    private async Task UploadImage3(InputFileChangeEventArgs e)
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath3 = await SaveImageAsync(e);
    }

    private async Task UploadImage4(InputFileChangeEventArgs e)
    {
        if (Product is null)
        {
            return;
        }

        Product.Product_ImagePath4 = await SaveImageAsync(e);
    }

    private async Task<string?> SaveImageAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file is null)
        {
            return null;
        }

        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!allowedExtensions.Contains(extension))
        {
            return null;
        }

        var uploadsFolder = Path.Combine(Environment.WebRootPath, "images", "products");

        if (!Directory.Exists(uploadsFolder))
        {
            Directory.CreateDirectory(uploadsFolder);
        }

        var fileName = $"{Guid.NewGuid()}{extension}";
        var filePath = Path.Combine(uploadsFolder, fileName);

        await using var stream = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(stream);

        return $"/images/products/{fileName}";
    }
}
