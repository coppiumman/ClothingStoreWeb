@page "/cart"
@layout PublicLayout
@using ClothingStoreWeb.Services
@inject CartService CartService
@implements IDisposable

<PageTitle>Корзина</PageTitle>

<div class="cart-page">
    <h1>Корзина</h1>

    @if (!CartService.Items.Any())
    {
        <div class="cart-empty">
            <h2>Корзина пока пуста</h2>
            <p>Добавьте товары из каталога, чтобы перейти к оформлению заказа.</p>

            <div class="cart-empty-actions">
                <a class="cart-button cart-button-primary" href="/catalog">
                    Перейти в каталог
                </a>

                <span class="cart-button cart-button-disabled">
                    Перейти к оформлению
                </span>
            </div>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-products">
                <table class="cart-table">
                    <colgroup>
                        <col class="cart-col-product" />
                        <col class="cart-col-size" />
                        <col class="cart-col-price" />
                        <col class="cart-col-quantity" />
                        <col class="cart-col-total" />
                        <col class="cart-col-remove" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th>Размер</th>
                            <th>Цена</th>
                            <th>Количество</th>
                            <th>Сумма</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in CartService.Items)
                        {
                            <tr>
                                <td>
                                    <div class="cart-product-name">
                                        @item.Product_Name
                                    </div>
                                </td>

                                <td class="cart-size-cell">
                                    @item.Size_Name
                                </td>

                                <td>
                                    @item.Product_Price.ToString("N2") ₽
                                </td>

                                <td>
                                    <div class="cart-quantity">
                                        <button type="button"
                                                class="cart-quantity-button"
                                                @onclick="() => DecreaseQuantity(item.Product_Id, item.Size_Id)">
                                            −
                                        </button>

                                        <span class="cart-quantity-value">
                                            @item.Quantity
                                        </span>

                                        <button type="button"
                                                class="cart-quantity-button"
                                                @onclick="() => IncreaseQuantity(item.Product_Id, item.Size_Id)">
                                            +
                                        </button>
                                    </div>
                                </td>

                                <td>
                                    <strong>@item.TotalPrice.ToString("N2") ₽</strong>
                                </td>

                                <td class="cart-remove-cell">
                                    <button type="button"
                                            class="cart-remove-button"
                                            @onclick="() => RemoveItem(item.Product_Id, item.Size_Id)">
                                        Удалить
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <aside class="cart-summary">
                <h2>Ваш заказ</h2>

                <div class="cart-summary-row">
                    <span>Товаров</span>
                    <strong>@GetTotalQuantity()</strong>
                </div>

                <div class="cart-summary-row">
                    <span>Сумма</span>
                    <strong>@CartService.GetTotalPrice().ToString("N2") ₽</strong>
                </div>

                <div class="cart-summary-total">
                    <span>Итого</span>
                    <strong>@CartService.GetTotalPrice().ToString("N2") ₽</strong>
                </div>

                <div class="cart-actions">
                    <a class="cart-button cart-button-primary" href="/checkout">
                        Перейти к оформлению
                    </a>

                    <a class="cart-button cart-button-secondary" href="/catalog">
                        Продолжить покупки
                    </a>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        CartService.OnChange += OnCartChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartService.LoadCartAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnCartChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveItem(int productId, int sizeId)
    {
        await CartService.RemoveItemAsync(productId, sizeId);
    }

    private async Task IncreaseQuantity(int productId, int sizeId)
    {
        await CartService.IncreaseQuantityAsync(productId, sizeId);
    }

    private async Task DecreaseQuantity(int productId, int sizeId)
    {
        await CartService.DecreaseQuantityAsync(productId, sizeId);
    }

    private int GetTotalQuantity()
    {
        return CartService.Items.Sum(item => item.Quantity);
    }

    public void Dispose()
    {
        CartService.OnChange -= OnCartChanged;
    }
}