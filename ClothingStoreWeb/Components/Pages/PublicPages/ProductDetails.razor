@page "/catalog/product/{ProductId:int}"
@layout PublicLayout

@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject CartService CartService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(product?.Product_Name ?? "Товар")</PageTitle>

@if (isProductUnavailableForPublic)
{
    <section class="product-unavailable">
        <h1>Товар не найден или временно недоступен</h1>
        <p>
            Возможно, товар был скрыт или временно недоступен для просмотра.
        </p>

        <a class="product-unavailable-button" href="/catalog">
            Вернуться в каталог
        </a>
    </section>
}
else if (product is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    @if (isEmployeeOrAdmin && IsCurrentProductHiddenFromPublic())
    {
        <div class="product-hidden-warning">
            <strong>Страница скрыта.</strong>
            Этот товар недоступен обычным пользователям в публичной части сайта.

            @if (product.Product_IsHidden)
            {
                <div>Причина: товар скрыт в служебном разделе.</div>
            }

            @if (product.Category?.Category_IsHidden == true)
            {
                <div>Причина: категория товара скрыта в служебном разделе.</div>
            }
        </div>
    }

    <div class="product-details">
        <div class="product-details-images">
            @{
                var productImages = GetProductImages();
            }

            @if (productImages.Any())
            {
                <div class="product-gallery-column">
                    @for (var i = 0; i < productImages.Count; i++)
                    {
                        var imageIndex = i;

                        <button type="button"
                                class="product-gallery-button @(selectedImageIndex == imageIndex ? "active" : "")"
                                @onclick="() => SelectImage(imageIndex)">
                            <img src="@productImages[imageIndex]"
                                 alt="@product.Product_Name"
                                 class="product-gallery-image" />
                        </button>
                    }
                </div>

                <div class="product-main-image">
                    <img src="@productImages[selectedImageIndex]"
                         alt="@product.Product_Name"
                         class="main-image-slide @slideDirection"
                         @key="selectedImageIndex"
                         @onclick="OpenImageViewer" />

                    @if (productImages.Count > 1)
                    {
                        <button type="button"
                                class="gallery-arrow gallery-arrow-left"
                                @onclick="ShowPreviousImage"
                                @onclick:stopPropagation="true">
                            ‹
                        </button>

                        <button type="button"
                                class="gallery-arrow gallery-arrow-right"
                                @onclick="ShowNextImage"
                                @onclick:stopPropagation="true">
                            ›
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="product-main-image product-main-image-empty">
                    <div class="product-no-image">Нет изображения</div>
                </div>
            }
        </div>

        <div class="product-details-info">

            <h1>@product.Product_Name</h1>

            <div class="product-meta">
                <span>Категория: @product.Category?.Category_Name</span>
                <span>Цвет: @product.Product_Coloring</span>
            </div>

            <p class="product-price">
                @product.Product_Price.ToString("N0") ₽
            </p>

            <div class="product-size-block">
                <div class="product-size-title">
                    <span>Размер</span>

                    @if (stocks.Any(stock => stock.Stock_Quantity > 0))
                    {
                        <span class="product-size-count">
                            В наличии: @stocks.Sum(stock => stock.Stock_Quantity)
                        </span>
                    }
                </div>

                @if (stocks.Count == 0 || !stocks.Any(stock => stock.Stock_Quantity > 0))
                {
                    <p class="product-no-stock">
                        Товар временно отсутствует в наличии.
                    </p>

                    @if (stocks.Count > 0)
                    {
                        <div class="product-size-list">
                            @foreach (var stock in stocks)
                            {
                                <button type="button"
                                        class="product-size-button unavailable"
                                        disabled>
                                    @stock.Size?.Size_Name
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="product-size-list">
                        @foreach (var stock in stocks)
                        {
                            var isAvailable = stock.Stock_Quantity > 0;

                            <button type="button"
                                    class="product-size-button @(selectedStockId == stock.Stock_Id ? "active" : "") @(isAvailable ? "" : "unavailable")"
                                    disabled="@(!isAvailable)"
                                    @onclick="() => selectedStockId = stock.Stock_Id">
                                @stock.Size?.Size_Name
                            </button>
                        }
                    </div>

                    @if (selectedStockId is not null)
                    {
                        var selectedStock = stocks.FirstOrDefault(stock => stock.Stock_Id == selectedStockId.Value);

                        if (selectedStock is not null)
                        {
                            <div class="selected-stock-info">
                                В наличии: <strong>@selectedStock.Stock_Quantity</strong> шт.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="selected-stock-info muted">
                            Выберите доступный размер, чтобы посмотреть точное количество на складе.
                        </div>
                    }
                }
            </div>

            <div class="product-actions">
                <button class="product-cart-button"
                        disabled="@(!CanAddSelectedStockToCart())"
                        @onclick="AddToCart">
                    В корзину
                </button>

                <a class="product-return-link" href="@GetReturnCatalogUrl()">
                    Вернуться в каталог
                </a>
            </div>

            <div class="product-info-accordion">
                <details open>
                    <summary>Описание</summary>
                    <p>@product.Product_Description</p>
                </details>

                <details>
                    <summary>Доставка</summary>
                    <p>
                        Способ доставки выбирается при оформлении заказа.
                        После оформления заказ можно посмотреть в личном кабинете.
                    </p>
                </details>

                <details>
                    <summary>Оплата</summary>
                    <p>
                        Доступные способы оплаты указываются на странице оформления заказа.
                        Платёжные реквизиты банковских карт в системе не сохраняются.
                    </p>
                </details>
                        </div>
        </div>
    </div>

    @if (recommendedProducts.Any())
    {
        <section class="recommended-products">
            <div class="recommended-products-header">
                <h2>Вам может понравиться</h2>
            </div>

            <div class="recommended-products-grid">
                @foreach (var item in recommendedProducts)
                {
                    <a class="recommended-product-card"
                       href="@($"/catalog/product/{item.Product_Id}")">
                        <div class="recommended-product-image">
                            @if (!string.IsNullOrWhiteSpace(item.Product_ImagePath))
                            {
                                <img src="@item.Product_ImagePath"
                                     alt="@item.Product_Name" />
                            }
                            else
                            {
                                <span>Нет изображения</span>
                            }
                        </div>

                        <div class="recommended-product-name">
                            @item.Product_Name
                        </div>

                        <div class="recommended-product-price">
                            @item.Product_Price.ToString("N0") ₽
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (isImageViewerOpen)
        {
            var viewerImages = GetProductImages();

            <div class="image-viewer-overlay" @onclick="CloseImageViewer">
                <div class="image-viewer-box" @onclick:stopPropagation="true">
                    <img src="@viewerImages[selectedImageIndex]"
                         alt="@product.Product_Name"
                         class="image-viewer-content @(isModalImageZoomed ? "zoomed" : "") @(isDraggingImage ? "dragging" : "")"
                         style="@GetViewerImageStyle()"
                         draggable="false"
                         @key="selectedImageIndex"
                         @onclick="ToggleModalImageZoom"
                         @onclick:stopPropagation="true"
                         @ondragstart:preventDefault="true"
                         @onpointerdown="StartImageDrag"
                         @onpointermove="MoveImageDrag"
                         @onpointerup="StopImageDrag"
                         @onpointerleave="StopImageDrag" />
                </div>

                @if (viewerImages.Count > 1)
                {
                    <button type="button"
                            class="viewer-arrow viewer-arrow-left"
                            @onclick="ShowPreviousImage"
                            @onclick:stopPropagation="true">
                        ‹
                    </button>

                    <button type="button"
                            class="viewer-arrow viewer-arrow-right"
                            @onclick="ShowNextImage"
                            @onclick:stopPropagation="true">
                        ›
                    </button>
                }
            </div>
        }

        @if (isAddToCartModalOpen)
        {
            <div class="add-cart-modal-backdrop">
                <div class="add-cart-modal">
                    <button type="button"
                            class="add-cart-modal-close"
                            @onclick="CloseAddToCartModal">
                        ×
                    </button>

                    <h2>Товар добавлен в корзину</h2>

                    @if (!string.IsNullOrWhiteSpace(addedProductImagePath))
                    {
                        <img src="@addedProductImagePath"
                             alt="@addedProductName"
                             class="add-cart-modal-image" />
                    }

                    <div class="add-cart-modal-name">
                        @addedProductName
                    </div>

                    <div class="add-cart-modal-size">
                        Размер @addedProductSizeName
                    </div>

                    <div class="add-cart-modal-actions">
                        <a class="add-cart-modal-button add-cart-modal-button-primary"
                           href="/cart">
                            Перейти в корзину
                        </a>

                        <button type="button"
                                class="add-cart-modal-button"
                                @onclick="CloseAddToCartModal">
                            Продолжить покупки
                        </button>
                    </div>
                </div>
            </div>
        }
}

@code {
    [Parameter]
    public int ProductId { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private Product? product;
    private bool isEmployeeOrAdmin;
    private bool isProductUnavailableForPublic;
    private List<Stock> stocks = new();
    private List<Product> recommendedProducts = new();
    private int? selectedStockId;
    private int selectedImageIndex;
    private int previousImageIndex;
    private string slideDirection = "next";
    private bool isImageViewerOpen;
    private bool isModalImageZoomed;
    private bool isDraggingImage;
    private bool wasImageDragged;
    private double dragStartX;
    private double dragStartY;
    private double pointerDownX;
    private double pointerDownY;
    private double imageOffsetX;
    private double imageOffsetY;
    private bool isAddToCartModalOpen;
    private string? addedProductName;
    private string? addedProductImagePath;
    private string? addedProductSizeName;

    private const double MaxImageOffsetX = 500;
    private const double MaxImageOffsetY = 500;

    protected override async Task OnParametersSetAsync()
    {
        selectedStockId = null;
        selectedImageIndex = 0;
        previousImageIndex = 0;
        slideDirection = "next";
        isImageViewerOpen = false;
        isAddToCartModalOpen = false;
        ResetModalImageZoom();

        await using var context = await DbFactory.CreateDbContextAsync();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isEmployeeOrAdmin =
            user.IsInRole("Сотрудник") ||
            user.IsInRole("Администратор");

        isProductUnavailableForPublic = false;

        product = await context.Products
            .Include(product => product.Category)
            .AsNoTracking()
            .FirstOrDefaultAsync(product => product.Product_Id == ProductId);

        if (product is null)
        {
            isProductUnavailableForPublic = true;
            return;
        }

        if ((product.Product_IsHidden || product.Category?.Category_IsHidden == true) && !isEmployeeOrAdmin)
        {
            product = null;
            isProductUnavailableForPublic = true;
            return;
        }
        stocks = await context.Stocks
            .Include(stock => stock.Size)
            .AsNoTracking()
            .Where(stock => stock.Product_Id == ProductId)
            .OrderBy(stock => stock.Size!.Size_Name)
            .ToListAsync();

        recommendedProducts = await context.Products
            .Include(product => product.Category)
            .AsNoTracking()
            .Where(item =>
                item.Product_Id != ProductId &&
                !item.Product_IsHidden &&
                item.Category != null &&
                !item.Category.Category_IsHidden &&
                !string.IsNullOrWhiteSpace(item.Product_ImagePath))
            .OrderBy(item => Guid.NewGuid())
            .Take(4)
            .ToListAsync();
    }

    private string GetReturnCatalogUrl()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl) &&
            ReturnUrl.StartsWith("/") &&
            !ReturnUrl.StartsWith("//"))
        {
            return ReturnUrl;
        }

        return "/catalog";
    }

    private bool CanAddSelectedStockToCart()
    {
        if (selectedStockId is null)
        {
            return false;
        }

        var selectedStock = stocks.FirstOrDefault(stock => stock.Stock_Id == selectedStockId.Value);

        return selectedStock is not null && selectedStock.Stock_Quantity > 0;
    }

    private async Task AddToCart()
    {
        if (product is null || selectedStockId is null)
        {
            return;
        }

        var selectedStock = stocks.FirstOrDefault(stock => stock.Stock_Id == selectedStockId.Value);

        if (selectedStock is null ||
            selectedStock.Size is null ||
            selectedStock.Stock_Quantity <= 0)
        {
            return;
        }

        await CartService.AddItemAsync(new CartItem
        {
            Product_Id = product.Product_Id,
            Product_Name = product.Product_Name,
            Product_Price = product.Product_Price,
            Product_ImagePath = product.Product_ImagePath,
            Size_Id = selectedStock.Size_Id,
            Size_Name = selectedStock.Size.Size_Name,
            Quantity = 1,
            AvailableQuantity = selectedStock.Stock_Quantity
        });

        addedProductName = product.Product_Name;
        addedProductImagePath = product.Product_ImagePath;
        addedProductSizeName = selectedStock.Size.Size_Name;

        isAddToCartModalOpen = true;
    }

    private void CloseAddToCartModal()
    {
        isAddToCartModalOpen = false;
    }

    private List<string> GetProductImages()
    {
        var images = new List<string>();

        if (product is null)
        {
            return images;
        }

        if (!string.IsNullOrWhiteSpace(product.Product_ImagePath))
        {
            images.Add(product.Product_ImagePath);
        }

        if (!string.IsNullOrWhiteSpace(product.Product_ImagePath2))
        {
            images.Add(product.Product_ImagePath2);
        }

        if (!string.IsNullOrWhiteSpace(product.Product_ImagePath3))
        {
            images.Add(product.Product_ImagePath3);
        }

        if (!string.IsNullOrWhiteSpace(product.Product_ImagePath4))
        {
            images.Add(product.Product_ImagePath4);
        }

        return images;
    }

    private void SelectImage(int imageIndex)
    {
        if (imageIndex == selectedImageIndex)
        {
            return;
        }

        previousImageIndex = selectedImageIndex;
        slideDirection = imageIndex > selectedImageIndex ? "next" : "prev";
        selectedImageIndex = imageIndex;
    }

    private void ShowPreviousImage()
    {
        var images = GetProductImages();

        if (!images.Any())
        {
            return;
        }

        previousImageIndex = selectedImageIndex;
        slideDirection = "prev";

        selectedImageIndex--;

        if (selectedImageIndex < 0)
        {
            selectedImageIndex = images.Count - 1;
        }

        ResetModalImageZoom();

        isModalImageZoomed = false;
    }

    private void ShowNextImage()
    {
        var images = GetProductImages();

        if (!images.Any())
        {
            return;
        }

        previousImageIndex = selectedImageIndex;
        slideDirection = "next";

        selectedImageIndex++;

        if (selectedImageIndex >= images.Count)
        {
            selectedImageIndex = 0;
        }

        ResetModalImageZoom();

        isModalImageZoomed = false;
    }

    private void OpenImageViewer()
    {
        isImageViewerOpen = true;
        ResetModalImageZoom();
    }

    private void CloseImageViewer()
    {
        isImageViewerOpen = false;
        ResetModalImageZoom();
    }

    private void ToggleModalImageZoom()
    {
        if (wasImageDragged)
        {
            wasImageDragged = false;
            return;
        }

        isModalImageZoomed = !isModalImageZoomed;

        if (!isModalImageZoomed)
        {
            imageOffsetX = 0;
            imageOffsetY = 0;
            isDraggingImage = false;
        }
    }

    private void StartImageDrag(PointerEventArgs e)
    {
        if (!isModalImageZoomed)
        {
            return;
        }

        isDraggingImage = true;
        wasImageDragged = false;

        pointerDownX = e.ClientX;
        pointerDownY = e.ClientY;

        dragStartX = e.ClientX - imageOffsetX;
        dragStartY = e.ClientY - imageOffsetY;
    }

    private void MoveImageDrag(PointerEventArgs e)
    {
        if (!isModalImageZoomed || !isDraggingImage)
        {
            return;
        }

        var movedX = Math.Abs(e.ClientX - pointerDownX);
        var movedY = Math.Abs(e.ClientY - pointerDownY);

        if (movedX > 3 || movedY > 3)
        {
            wasImageDragged = true;
        }

        imageOffsetX = e.ClientX - dragStartX;
        imageOffsetY = e.ClientY - dragStartY;
    }

    private void StopImageDrag()
    {
        if (isDraggingImage && wasImageDragged)
        {
            var isOutsideAllowedArea =
                Math.Abs(imageOffsetX) > MaxImageOffsetX ||
                Math.Abs(imageOffsetY) > MaxImageOffsetY;

            if (isOutsideAllowedArea)
            {
                imageOffsetX = 0;
                imageOffsetY = 0;
            }
        }

        isDraggingImage = false;
    }

    private string GetViewerImageStyle()
    {
        if (!isModalImageZoomed)
        {
            return string.Empty;
        }

        return $"transform: translate({imageOffsetX}px, {imageOffsetY}px) scale(1.6);";
    }

    private void ResetModalImageZoom()
    {
        isModalImageZoomed = false;
        isDraggingImage = false;
        wasImageDragged = false;
        imageOffsetX = 0;
        imageOffsetY = 0;
    }

    private bool IsCurrentProductHiddenFromPublic()
    {
        return product?.Product_IsHidden == true ||
               product?.Category?.Category_IsHidden == true;
    }

}