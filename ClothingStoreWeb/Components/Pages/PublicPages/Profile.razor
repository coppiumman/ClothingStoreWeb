@page "/profile"
@layout PublicLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using Microsoft.EntityFrameworkCore
@using System.Net.Mail
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Личный кабинет</PageTitle>

<div class="profile-page">
    <nav class="profile-tabs">
        <button type="button"
                class="profile-tab @(activeTab == "current" ? "active" : "")"
                @onclick='() => SelectTab("current")'>
            Текущие заказы
        </button>

        <button type="button"
                class="profile-tab @(activeTab == "history" ? "active" : "")"
                @onclick='() => SelectTab("history")'>
            История заказов
        </button>

        <button type="button"
                class="profile-tab @(activeTab == "profile" ? "active" : "")"
                @onclick='() => SelectTab("profile")'>
            Профиль
        </button>

        <form action="/Account/Logout" method="post" class="profile-tab-logout-form">
            <AntiforgeryToken />
            <button type="submit" class="profile-tab logout">
                Выход
            </button>
        </form>
    </nav>

    @if (activeTab == "profile")
    {
        <section class="profile-section">
            <h2>Персональные данные</h2>

            @if (userEmail is null)
            {
                <p class="profile-muted"><em>Загрузка...</em></p>
            }
            else
            {
                <div class="profile-data">
                    <div class="profile-data-row">
                        <span class="profile-data-label">ФИО:</span>
                        <span class="profile-data-value">@GetDisplayFullName()</span>
                    </div>

                    <div class="profile-data-row">
                        <span class="profile-data-label">Email:</span>
                        <span class="profile-data-value">@userEmail</span>
                    </div>

                    <div class="profile-data-row">
                        <span class="profile-data-label">Телефон:</span>
                        <span class="profile-data-value">@GetDisplayPhoneNumber()</span>
                    </div>
                </div>

                <div class="profile-actions">
                    <button type="button"
                            class="profile-action-button"
                            @onclick="OpenPasswordModal">
                        Изменить пароль
                    </button>

                    <button type="button"
                            class="profile-action-button"
                            @onclick="OpenEmailModal">
                        Изменить почту
                    </button>

                    <button type="button"
                            class="profile-action-button"
                            @onclick="OpenPersonalDataModal">
                        Изменить личные данные
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(accountSuccessMessage))
                {
                    <div class="profile-account-success">
                        @accountSuccessMessage
                    </div>
                }
            }
        </section>
    }

    @if (activeTab == "current")
    {
        <section class="profile-section">
            @if (!CurrentOrders.Any())
            {
                <div class="profile-empty">
                    <div class="profile-empty-title">Текущих заказов нет</div>
                    <div class="profile-empty-text">После оформления заказа он появится в этом разделе.</div>
                </div>
            }
            else
            {
                <div class="orders-history-scroll">
                    <table class="profile-orders-table">
                        <thead>
                            <tr>
                                <th>Номер заказа</th>
                                <th>Дата заказа</th>
                                <th>Статус</th>
                                <th>Сумма</th>
                                <th>Действия</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in CurrentOrders)
                            {
                                <tr>
                                    <td>Заказ №@order.Order_Id</td>
                                    <td>@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="profile-status @GetOrderStatusCssClass(order.Order_Status)">
                                            @GetOrderStatusName(order.Order_Status)
                                        </span>
                                    </td>
                                    <td>@order.Order_TotalAmount.ToString("N2") ₽</td>
                                    <td>
                                        <div class="profile-order-actions">
                                            <a class="profile-small-button"
                                               href="@($"/profile/order?id={order.Order_Id}&returnTab=current")">
                                                Подробнее
                                            </a>

                                            @if (CanUserCancelOrder(order.Order_Status))
                                            {
                                                <button type="button"
                                                        class="profile-small-button danger"
                                                        @onclick="() => OpenCancelModal(order)">
                                                    Отменить
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (activeTab == "history")
    {
        <section class="profile-section">
            @if (!HistoryOrders.Any())
            {
                <div class="profile-empty">
                    <div class="profile-empty-title">История заказов пуста</div>
                    <div class="profile-empty-text">Завершённые, отменённые и возвращённые заказы появятся здесь.</div>
                </div>
            }
            else
            {
                <div class="orders-history-scroll">
                    <table class="profile-orders-table">
                        <thead>
                            <tr>
                                <th>Номер заказа</th>
                                <th>Дата изменения</th>
                                <th>Статус</th>
                                <th>Сумма</th>
                                <th>Действия</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in HistoryOrders)
                            {
                                <tr>
                                    <td>Заказ №@order.Order_Id</td>
                                    <td>@((order.Order_StatusChangedAt ?? order.Order_Date).ToString("dd.MM.yyyy HH:mm"))</td>
                                    <td>
                                        <span class="profile-status @GetOrderStatusCssClass(order.Order_Status)">
                                            @GetOrderStatusName(order.Order_Status)
                                        </span>
                                    </td>
                                    <td>@order.Order_TotalAmount.ToString("N2") ₽</td>
                                    <td>
                                        <div class="profile-order-actions">
                                            <a class="profile-small-button"
                                               href="@($"/profile/order?id={order.Order_Id}&returnTab=history")">
                                                Подробнее
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (isCancelModalOpen && orderToCancel is not null)
    {
        <div class="profile-modal-backdrop">
            <div class="profile-cancel-modal" @onclick:stopPropagation="true">
                <button type="button"
                        class="profile-modal-close"
                        @onclick="CloseCancelModal">
                    ×
                </button>

                <h2>Отмена заказа</h2>

                <div class="profile-modal-warning">
                    Вы уверены, что хотите отменить заказ?
                </div>

                <div class="profile-modal-summary">
                    <div>
                        <span>Номер заказа</span>
                        <strong>Заказ №@orderToCancel.Order_Id</strong>
                    </div>

                    <div>
                        <span>Дата заказа</span>
                        <strong>@orderToCancel.Order_Date.ToString("dd.MM.yyyy HH:mm")</strong>
                    </div>

                    <div>
                        <span>Статус</span>
                        <strong>@GetOrderStatusName(orderToCancel.Order_Status)</strong>
                    </div>

                    <div>
                        <span>Сумма заказа</span>
                        <strong>@orderToCancel.Order_TotalAmount.ToString("N2") ₽</strong>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(cancelError))
                {
                    <div class="profile-modal-error">
                        @cancelError
                    </div>
                }

                <div class="profile-modal-actions">
                    <button type="button"
                            class="profile-modal-button danger"
                            @onclick="ConfirmCancelOrderAsync">
                        Отменить заказ
                    </button>

                    <button type="button"
                            class="profile-modal-button"
                            @onclick="CloseCancelModal">
                        Вернуться
                    </button>
                </div>
            </div>
        </div>
    }

    @if (isPersonalDataModalOpen)
    {
        <div class="profile-modal-backdrop">
            <div class="profile-edit-modal" @onclick:stopPropagation="true">
                <button type="button"
                        class="profile-modal-close"
                        @onclick="ClosePersonalDataModal">
                    ×
                </button>

                <h2>Изменение личных данных</h2>

                <div class="profile-edit-form">
                    <div class="profile-edit-field">
                        <label>ФИО</label>
                        <input type="text"
                               class="profile-edit-input"
                               @bind="editFullName"
                               placeholder="Введите ФИО" />
                    </div>

                    <div class="profile-edit-field">
                        <label>Телефон</label>

                        <div class="profile-phone-row">
                            <select class="profile-phone-code"
                                    value="@editPhoneCountryCode"
                                    @onchange="ChangePhoneCountryCode">
                                @foreach (var rule in phoneRules)
                                {
                                    <option value="@rule.Code">@rule.Code</option>
                                }
                            </select>

                            <input type="text"
                                   class="profile-edit-input profile-phone-input"
                                   @bind="editPhoneLocalNumber"
                                   placeholder="@GetPhonePlaceholder()" />
                        </div>

                        <div class="profile-phone-preview">
                            Пример: @GetPhoneExample()
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(profileEditError))
                {
                    <div class="profile-modal-error">
                        @profileEditError
                    </div>
                }

                <div class="profile-modal-actions">
                    <button type="button"
                            class="profile-modal-button"
                            @onclick="SavePersonalDataAsync">
                        Сохранить
                    </button>

                    <button type="button"
                            class="profile-modal-button"
                            @onclick="ClosePersonalDataModal">
                        Отмена
                    </button>
                </div>
            </div>
        </div>
    }

    @if (isEmailModalOpen)
    {
        <div class="profile-modal-backdrop">
            <div class="profile-edit-modal" @onclick:stopPropagation="true">
                <button type="button"
                        class="profile-modal-close"
                        @onclick="CloseEmailModal">
                    ×
                </button>

                <h2>Изменение почты</h2>

                <div class="profile-edit-form">
                    <div class="profile-edit-field">
                        <label>Текущая почта</label>
                        <input type="text"
                               class="profile-edit-input"
                               value="@userEmail"
                               disabled />
                    </div>

                    <div class="profile-edit-field">
                        <label>Новая почта</label>
                        <input type="email"
                               class="profile-edit-input"
                               @bind="editEmail"
                               placeholder="example@mail.ru" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(emailEditError))
                {
                    <div class="profile-modal-error">
                        @emailEditError
                    </div>
                }

                <div class="profile-modal-actions">
                    <button type="button"
                            class="profile-modal-button"
                            @onclick="SaveEmailAsync">
                        Сохранить
                    </button>

                    <button type="button"
                            class="profile-modal-button"
                            @onclick="CloseEmailModal">
                        Отмена
                    </button>
                </div>
            </div>
        </div>
    }

    @if (isPasswordModalOpen)
    {
        <div class="profile-modal-backdrop">
            <div class="profile-edit-modal" @onclick:stopPropagation="true">
                <button type="button"
                        class="profile-modal-close"
                        @onclick="ClosePasswordModal">
                    ×
                </button>

                <h2>Изменение пароля</h2>

                <div class="profile-edit-form">
                    <div class="profile-edit-field">
                        <label>Текущий пароль</label>
                        <input type="password"
                               class="profile-edit-input"
                               @bind="currentPassword"
                               placeholder="Введите текущий пароль" />
                    </div>

                    <div class="profile-edit-field">
                        <label>Новый пароль</label>
                        <input type="password"
                               class="profile-edit-input"
                               @bind="newPassword"
                               placeholder="Введите новый пароль" />
                    </div>

                    <div class="profile-edit-field">
                        <label>Повторите новый пароль</label>
                        <input type="password"
                               class="profile-edit-input"
                               @bind="confirmNewPassword"
                               placeholder="Повторите новый пароль" />
                    </div>
                </div>

                <div class="profile-phone-preview">
                    Пароль должен содержать не менее 8 символов, хотя бы одну букву и одну цифру.
                </div>

                @if (!string.IsNullOrWhiteSpace(passwordEditError))
                {
                    <div class="profile-modal-error">
                        @passwordEditError
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(passwordEditSuccess))
                {
                    <div class="profile-modal-success">
                        @passwordEditSuccess
                    </div>
                }

                <div class="profile-modal-actions">
                    <button type="button"
                            class="profile-modal-button"
                            @onclick="SavePasswordAsync">
                        Сохранить
                    </button>

                    <button type="button"
                            class="profile-modal-button"
                            @onclick="ClosePasswordModal">
                        Отмена
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private string activeTab = "profile";

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    private string? userEmail;
    private string? userFullName;
    private string? userPhoneNumber;

    private List<Order> userOrders = new();
    private bool isCancelModalOpen;
    private Order? orderToCancel;
    private string? cancelError;
    private bool isPersonalDataModalOpen;
    private string? editFullName;
    private string editPhoneCountryCode = "+7";
    private string? editPhoneLocalNumber;
    private string? profileEditError;
    private bool isEmailModalOpen;
    private string? editEmail;
    private string? emailEditError;
    private bool isPasswordModalOpen;
    private string? currentPassword;
    private string? newPassword;
    private string? confirmNewPassword;
    private string? passwordEditError;
    private string? passwordEditSuccess;
    private string? accountSuccessMessage;
    private int accountSuccessMessageVersion;

    protected override void OnParametersSet()
    {
        if (Tab is "current" or "history" or "profile")
        {
            activeTab = Tab;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var appUser = await context.Users
            .AsNoTracking()
            .FirstOrDefaultAsync(applicationUser => applicationUser.Id == userId);

        userEmail = appUser?.Email ?? user.Identity?.Name;
        userFullName = appUser?.UserFullName;
        userPhoneNumber = appUser?.PhoneNumber;

        userOrders = await context.Orders
            .AsNoTracking()
            .Where(order => order.User_Id == userId)
            .OrderByDescending(order => order.Order_Date)
            .ToListAsync();
    }

    private IEnumerable<Order> CurrentOrders =>
        userOrders
            .Where(order => IsCurrentOrder(order.Order_Status))
            .OrderByDescending(order => order.Order_Date);

    private IEnumerable<Order> HistoryOrders =>
        userOrders
            .Where(order => !IsCurrentOrder(order.Order_Status))
            .OrderByDescending(order => order.Order_StatusChangedAt ?? order.Order_Date);

    private void SelectTab(string tab)
    {
        activeTab = tab;
    }

    private static bool IsCurrentOrder(string? status)
    {
        return status is "new" or "confirmed" or "paid" or "processing" or "shipped";
    }

    private string GetDisplayFullName()
    {
        return string.IsNullOrWhiteSpace(userFullName)
            ? "Не указано"
            : userFullName;
    }

    private string GetDisplayPhoneNumber()
    {
        return string.IsNullOrWhiteSpace(userPhoneNumber)
            ? "Не указан"
            : FormatPhoneNumberForDisplay(userPhoneNumber);
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetOrderStatusCssClass(string? status)
    {
        return status switch
        {
            "new" => "new",
            "confirmed" => "confirmed",
            "paid" => "paid",
            "processing" => "processing",
            "shipped" => "shipped",
            "delivered" => "delivered",
            "done" => "done",
            "cancelled" => "cancelled",
            "returned" => "returned",
            _ => "default"
        };
    }

    private void OpenCancelModal(Order order)
    {
        cancelError = null;
        orderToCancel = order;
        isCancelModalOpen = true;
    }

    private void CloseCancelModal()
    {
        cancelError = null;
        orderToCancel = null;
        isCancelModalOpen = false;
    }

    private async Task ConfirmCancelOrderAsync()
    {
        if (orderToCancel is null)
        {
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            cancelError = "Не удалось определить пользователя.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var orderFromDb = await context.Orders
            .Include(order => order.OrderItems)
            .FirstOrDefaultAsync(order =>
                order.Order_Id == orderToCancel.Order_Id &&
                order.User_Id == currentUserId);

        if (orderFromDb is null)
        {
            cancelError = "Заказ не найден.";
            return;
        }

        if (!CanUserCancelOrder(orderFromDb.Order_Status))
        {
            cancelError = "Этот заказ уже нельзя отменить.";
            return;
        }

        foreach (var orderItem in orderFromDb.OrderItems)
        {
            var stock = await context.Stocks
                .FirstOrDefaultAsync(stock =>
                    stock.Product_Id == orderItem.Product_Id &&
                    stock.Size_Id == orderItem.Size_Id);

            if (stock is not null)
            {
                stock.Stock_Quantity += orderItem.OrderItem_Quantity;
            }
        }

        orderFromDb.Order_Status = "cancelled";
        orderFromDb.Order_StatusChangedAt = DateTime.Now;

        await context.SaveChangesAsync();

        var localOrder = userOrders.FirstOrDefault(order => order.Order_Id == orderFromDb.Order_Id);

        if (localOrder is not null)
        {
            localOrder.Order_Status = "cancelled";
            localOrder.Order_StatusChangedAt = orderFromDb.Order_StatusChangedAt;
        }

        CloseCancelModal();
    }

    private void OpenPersonalDataModal()
    {
        profileEditError = null;

        editFullName = userFullName;

        var parsedPhone = ParsePhoneNumber(userPhoneNumber);
        editPhoneCountryCode = parsedPhone.CountryCode;
        editPhoneLocalNumber = parsedPhone.LocalNumber;

        isPersonalDataModalOpen = true;
    }

    private void ClosePersonalDataModal()
    {
        profileEditError = null;

        editFullName = null;
        editPhoneCountryCode = "+7";
        editPhoneLocalNumber = null;

        isPersonalDataModalOpen = false;
    }

    private async Task SavePersonalDataAsync()
    {
        profileEditError = null;

        var normalizedFullName = editFullName?.Trim();
        var normalizedPhoneNumber = BuildPhoneNumber();

        if (string.IsNullOrWhiteSpace(normalizedFullName))
        {
            profileEditError = "Укажите ФИО.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(editPhoneLocalNumber) && normalizedPhoneNumber is null)
        {
            var rule = GetPhoneRule(editPhoneCountryCode);

            profileEditError = rule.MinLength == rule.MaxLength
                ? $"Для кода {rule.Code} номер должен содержать {rule.MinLength} цифр."
                : $"Для кода {rule.Code} номер должен содержать от {rule.MinLength} до {rule.MaxLength} цифр.";

            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            profileEditError = "Не удалось определить пользователя.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var appUser = await context.Users
            .FirstOrDefaultAsync(applicationUser => applicationUser.Id == userId);

        if (appUser is null)
        {
            profileEditError = "Пользователь не найден.";
            return;
        }

        appUser.UserFullName = normalizedFullName;
        appUser.PhoneNumber = normalizedPhoneNumber;

        await context.SaveChangesAsync();

        userFullName = appUser.UserFullName;
        userPhoneNumber = appUser.PhoneNumber;

        ClosePersonalDataModal();
        _ = ShowAccountSuccessMessageAsync("Данные аккаунта успешно обновлены.");
    }

    private string? BuildPhoneNumber()
    {
        var localNumber = ExtractDigits(editPhoneLocalNumber);

        if (string.IsNullOrWhiteSpace(localNumber))
        {
            return null;
        }

        var rule = GetPhoneRule(editPhoneCountryCode);
        var codeDigits = editPhoneCountryCode.TrimStart('+');

        if (localNumber.StartsWith(codeDigits) && localNumber.Length > rule.MaxLength)
        {
            localNumber = localNumber[codeDigits.Length..];
        }

        if (localNumber.Length < rule.MinLength || localNumber.Length > rule.MaxLength)
        {
            return null;
        }

        return $"{editPhoneCountryCode}{localNumber}";
    }

    private static (string CountryCode, string? LocalNumber) ParsePhoneNumber(string? phoneNumber)
    {
        if (string.IsNullOrWhiteSpace(phoneNumber))
        {
            return ("+7", null);
        }

        var trimmedPhone = phoneNumber.Trim();
        var onlyDigits = ExtractDigits(trimmedPhone);

        foreach (var rule in phoneRules.OrderByDescending(rule => rule.Code.Length))
        {
            if (trimmedPhone.StartsWith(rule.Code))
            {
                var localNumber = ExtractDigits(trimmedPhone[rule.Code.Length..]);
                return (rule.Code, localNumber);
            }

            var codeDigits = rule.Code.TrimStart('+');

            if (onlyDigits.StartsWith(codeDigits) && onlyDigits.Length > codeDigits.Length)
            {
                var localNumber = onlyDigits[codeDigits.Length..];
                return (rule.Code, localNumber);
            }
        }

        return ("+7", onlyDigits);
    }

    private sealed record PhoneRule(
    string Code,
    int MinLength,
    int MaxLength,
    string Placeholder
);

    private static readonly List<PhoneRule> phoneRules = new()
{
    new("+7", 10, 10, "800 600-55-44"),
    new("+375", 9, 9, "29 123-45-67"),
    new("+370", 8, 8, "612 34567"),
    new("+371", 8, 8, "12 345 678"),
    new("+372", 7, 8, "5123 4567"),
    new("+380", 9, 9, "50 123-45-67"),
    new("+48", 9, 9, "123 456 789"),
    new("+49", 10, 11, "151 12345678"),
    new("+1", 10, 10, "(555) 123-4567")
};

    private void ChangePhoneCountryCode(ChangeEventArgs e)
    {
        editPhoneCountryCode = e.Value?.ToString() ?? "+7";
        profileEditError = null;
    }

    private string GetPhonePlaceholder()
    {
        return GetPhoneRule(editPhoneCountryCode).Placeholder;
    }

    private string GetPhoneExample()
    {
        var rule = GetPhoneRule(editPhoneCountryCode);
        return $"{rule.Code} {rule.Placeholder}";
    }

    private static PhoneRule GetPhoneRule(string countryCode)
    {
        return phoneRules.FirstOrDefault(rule => rule.Code == countryCode)
            ?? phoneRules.First(rule => rule.Code == "+7");
    }

    private static string ExtractDigits(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsDigit).ToArray());
    }

    private static string FormatPhoneNumberForDisplay(string? phoneNumber)
    {
        if (string.IsNullOrWhiteSpace(phoneNumber))
        {
            return string.Empty;
        }

        var parsedPhone = ParsePhoneNumber(phoneNumber);
        var localNumber = ExtractDigits(parsedPhone.LocalNumber);

        if (string.IsNullOrWhiteSpace(localNumber))
        {
            return phoneNumber;
        }

        var formattedLocalNumber = FormatLocalPhoneNumber(parsedPhone.CountryCode, localNumber);

        return $"{parsedPhone.CountryCode} {formattedLocalNumber}";
    }

    private static string FormatLocalPhoneNumber(string countryCode, string digits)
    {
        return countryCode switch
        {
            "+7" when digits.Length == 10 =>
                $"{digits[..3]} {digits[3..6]}-{digits[6..8]}-{digits[8..10]}",

            "+1" when digits.Length == 10 =>
                $"({digits[..3]}) {digits[3..6]}-{digits[6..10]}",

            "+375" when digits.Length == 9 =>
                $"{digits[..2]} {digits[2..5]}-{digits[5..7]}-{digits[7..9]}",

            "+370" when digits.Length == 8 =>
                $"{digits[..3]} {digits[3..8]}",

            "+371" when digits.Length == 8 =>
                $"{digits[..2]} {digits[2..5]} {digits[5..8]}",

            "+372" when digits.Length == 7 =>
                $"{digits[..3]} {digits[3..7]}",

            "+372" when digits.Length == 8 =>
                $"{digits[..4]} {digits[4..8]}",

            "+380" when digits.Length == 9 =>
                $"{digits[..2]} {digits[2..5]}-{digits[5..7]}-{digits[7..9]}",

            "+48" when digits.Length == 9 =>
                $"{digits[..3]} {digits[3..6]} {digits[6..9]}",

            "+49" when digits.Length >= 10 =>
                $"{digits[..3]} {digits[3..]}",

            _ => digits
        };
    }

    private void OpenEmailModal()
    {
        emailEditError = null;
        editEmail = userEmail;
        isEmailModalOpen = true;
    }

    private void CloseEmailModal()
    {
        emailEditError = null;
        editEmail = null;
        isEmailModalOpen = false;
    }

    private async Task SaveEmailAsync()
    {
        emailEditError = null;

        var normalizedEmail = editEmail?.Trim();

        if (string.IsNullOrWhiteSpace(normalizedEmail))
        {
            emailEditError = "Укажите новую почту.";
            return;
        }

        if (!IsValidEmail(normalizedEmail))
        {
            emailEditError = "Укажите корректный адрес электронной почты.";
            return;
        }

        if (string.Equals(normalizedEmail, userEmail, StringComparison.OrdinalIgnoreCase))
        {
            emailEditError = "Новая почта совпадает с текущей.";
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            emailEditError = "Не удалось определить пользователя.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var emailAlreadyExists = await context.Users
            .AnyAsync(applicationUser =>
                applicationUser.Id != userId &&
                applicationUser.Email != null &&
                applicationUser.Email.ToLower() == normalizedEmail.ToLower());

        if (emailAlreadyExists)
        {
            emailEditError = "Пользователь с такой почтой уже существует.";
            return;
        }

        var appUser = await context.Users
            .FirstOrDefaultAsync(applicationUser => applicationUser.Id == userId);

        if (appUser is null)
        {
            emailEditError = "Пользователь не найден.";
            return;
        }

        appUser.Email = normalizedEmail;
        appUser.NormalizedEmail = normalizedEmail.ToUpper();

        appUser.UserName = normalizedEmail;
        appUser.NormalizedUserName = normalizedEmail.ToUpper();

        await context.SaveChangesAsync();

        userEmail = normalizedEmail;

        CloseEmailModal();
        _ = ShowAccountSuccessMessageAsync("Данные аккаунта успешно обновлены.");
    }

    private static bool IsValidEmail(string email)
    {
        try
        {
            var address = new MailAddress(email);
            return address.Address == email;
        }
        catch
        {
            return false;
        }
    }

    private void OpenPasswordModal()
    {
        passwordEditError = null;
        passwordEditSuccess = null;

        currentPassword = null;
        newPassword = null;
        confirmNewPassword = null;

        isPasswordModalOpen = true;
    }

    private void ClosePasswordModal()
    {
        passwordEditError = null;
        passwordEditSuccess = null;

        currentPassword = null;
        newPassword = null;
        confirmNewPassword = null;

        isPasswordModalOpen = false;
    }

    private static bool IsStrongPassword(string password)
    {
        if (password.Length < 8)
        {
            return false;
        }

        var hasLetter = password.Any(char.IsLetter);
        var hasDigit = password.Any(char.IsDigit);

        return hasLetter && hasDigit;
    }

    private async Task SavePasswordAsync()
    {
        passwordEditError = null;
        passwordEditSuccess = null;

        if (string.IsNullOrWhiteSpace(currentPassword))
        {
            passwordEditError = "Введите текущий пароль.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordEditError = "Введите новый пароль.";
            return;
        }

        if (!IsStrongPassword(newPassword))
        {
            passwordEditError = "Новый пароль должен содержать не менее 8 символов, хотя бы одну букву и хотя бы одну цифру.";
            return;
        }

        if (newPassword != confirmNewPassword)
        {
            passwordEditError = "Новый пароль и подтверждение не совпадают.";
            return;
        }

        if (currentPassword == newPassword)
        {
            passwordEditError = "Новый пароль не должен совпадать с текущим.";
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            passwordEditError = "Не удалось определить пользователя.";
            return;
        }

        var appUser = await UserManager.FindByIdAsync(userId);

        if (appUser is null)
        {
            passwordEditError = "Пользователь не найден.";
            return;
        }

        var result = await UserManager.ChangePasswordAsync(appUser, currentPassword, newPassword);

        if (!result.Succeeded)
        {
            passwordEditError = GetPasswordChangeError(result);
            return;
        }

        ClosePasswordModal();
        _ = ShowAccountSuccessMessageAsync("Данные аккаунта успешно обновлены.");
    }

    private static string GetPasswordChangeError(IdentityResult result)
    {
        var errorCodes = result.Errors
            .Select(error => error.Code)
            .ToList();

        if (errorCodes.Contains("PasswordMismatch"))
        {
            return "Текущий пароль указан неверно.";
        }

        if (errorCodes.Contains("PasswordTooShort"))
        {
            return "Новый пароль слишком короткий.";
        }

        if (errorCodes.Contains("PasswordRequiresDigit"))
        {
            return "Новый пароль должен содержать хотя бы одну цифру.";
        }

        if (errorCodes.Contains("PasswordRequiresLower"))
        {
            return "Новый пароль должен содержать строчную букву.";
        }

        if (errorCodes.Contains("PasswordRequiresUpper"))
        {
            return "Новый пароль должен содержать заглавную букву.";
        }

        if (errorCodes.Contains("PasswordRequiresNonAlphanumeric"))
        {
            return "Новый пароль должен содержать специальный символ.";
        }

        return "Не удалось изменить пароль. Проверьте введённые данные.";
    }

    private async Task ShowAccountSuccessMessageAsync(string message)
    {
        accountSuccessMessage = message;
        accountSuccessMessageVersion++;

        var currentVersion = accountSuccessMessageVersion;

        await InvokeAsync(StateHasChanged);

        await Task.Delay(5000);

        if (currentVersion == accountSuccessMessageVersion)
        {
            accountSuccessMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool CanUserCancelOrder(string? status)
    {
        return status is "new" or "confirmed" or "paid";
    }
