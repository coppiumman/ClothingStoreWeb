@page "/profile/order-cancel"
@layout PublicLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Отмена заказа</PageTitle>

<div class="order-cancel-page">
    <h1>Отмена заказа</h1>

    @if (order is null)
    {
        <p class="order-cancel-muted"><em>Загрузка...</em></p>
    }
    else
    {
        <section class="order-cancel-warning">
            <div class="order-cancel-warning-title">
                Вы уверены, что хотите отменить заказ?
            </div>
        </section>

        <section class="order-cancel-summary">
            <div>
                <div class="order-cancel-label">Номер заказа</div>
                <div class="order-cancel-value">Заказ №@order.Order_Id</div>
            </div>

            <div>
                <div class="order-cancel-label">Дата заказа</div>
                <div class="order-cancel-value">@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</div>
            </div>

            <div>
                <div class="order-cancel-label">Статус</div>
                <div class="order-cancel-value">@GetOrderStatusName(order.Order_Status)</div>
            </div>

            <div>
                <div class="order-cancel-label">Сумма заказа</div>
                <div class="order-cancel-value">@order.Order_TotalAmount.ToString("N2") ₽</div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(cancelError))
        {
            <div class="order-cancel-error">
                @cancelError
            </div>
        }

        <EditForm method="post"
                  Model="order"
                  OnValidSubmit="CancelOrder"
                  FormName="cancel-user-order"
                  Enhance>
            <div class="order-cancel-actions">
                <button type="submit" class="order-cancel-button danger">
                    Отменить заказ
                </button>

                <a class="order-cancel-button" href="@GetReturnProfileUrl()">
                    Вернуться в личный кабинет
                </a>
            </div>
        </EditForm>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    [SupplyParameterFromQuery(Name = "returnTab")]
    private string? ReturnTab { get; set; }

    private Order? order;
    private string? userId;
    private string? cancelError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        order = await context.Orders
            .AsNoTracking()
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id && o.User_Id == userId);

        if (order is null)
        {
            NavigationManager.NavigateTo(GetReturnProfileUrl());
            return;
        }

        if (!CanUserCancelOrder(order.Order_Status))
        {
            NavigationManager.NavigateTo(GetReturnProfileUrl());
            return;
        }
    }

    private async Task CancelOrder()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            NavigationManager.NavigateTo(GetReturnProfileUrl());
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var orderFromDb = await context.Orders
            .Include(o => o.OrderItems)
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id && o.User_Id == userId);

        if (orderFromDb is null)
        {
            NavigationManager.NavigateTo("/profile");
            return;
        }

        if (!CanUserCancelOrder(orderFromDb.Order_Status))
        {
            cancelError = "Этот заказ уже нельзя отменить.";
            order = orderFromDb;
            return;
        }

        foreach (var orderItem in orderFromDb.OrderItems)
        {
            var stock = await context.Stocks
                .FirstOrDefaultAsync(s =>
                    s.Product_Id == orderItem.Product_Id &&
                    s.Size_Id == orderItem.Size_Id);

            if (stock is not null)
            {
                stock.Stock_Quantity += orderItem.OrderItem_Quantity;
            }
        }

        orderFromDb.Order_Status = "cancelled";
        orderFromDb.Order_StatusChangedAt = DateTime.Now;

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo(GetReturnProfileUrl());
    }

    private string GetReturnProfileUrl()
    {
        return ReturnTab switch
        {
            "current" => "/profile?tab=current",
            "history" => "/profile?tab=history",
            _ => "/profile?tab=current"
        };
    }

    private static bool CanUserCancelOrder(string? status)
    {
        return status is "new" or "confirmed" or "paid";
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }
}