@page "/profile/order-cancel"
@layout PublicLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Отмена заказа</PageTitle>

<h1>Отмена заказа</h1>

@if (order is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="profile-card">
        <h3>Заказ №@order.Order_Id</h3>

        <p>Вы уверены, что хотите отменить этот заказ?</p>

        <p>
            <strong>Дата заказа:</strong>
            @order.Order_Date.ToString("dd.MM.yyyy HH:mm")
        </p>

        <p>
            <strong>Статус:</strong>
            @GetOrderStatusName(order.Order_Status)
        </p>

        <p>
            <strong>Сумма заказа:</strong>
            @order.Order_TotalAmount.ToString("N2") ₽
        </p>

        @if (!string.IsNullOrWhiteSpace(cancelError))
        {
            <div class="alert alert-danger">
                @cancelError
            </div>
        }

        <EditForm method="post" Model="order" OnValidSubmit="CancelOrder" FormName="cancel-user-order" Enhance>
            <button type="submit" class="btn btn-danger">
                Отменить заказ
            </button>

            <a class="btn btn-outline-secondary" href="/profile">
                Вернуться в личный кабинет
            </a>
        </EditForm>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    private Order? order;
    private string? userId;
    private string? cancelError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        order = await context.Orders
            .AsNoTracking()
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id && o.User_Id == userId);

        if (order is null)
        {
            NavigationManager.NavigateTo("/profile");
            return;
        }

        if (!CanUserCancelOrder(order.Order_Status))
        {
            NavigationManager.NavigateTo("/profile");
            return;
        }
    }

    private async Task CancelOrder()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var orderFromDb = await context.Orders
            .Include(o => o.OrderItems)
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id && o.User_Id == userId);

        if (orderFromDb is null)
        {
            NavigationManager.NavigateTo("/profile");
            return;
        }

        if (!CanUserCancelOrder(orderFromDb.Order_Status))
        {
            cancelError = "Этот заказ уже нельзя отменить.";
            order = orderFromDb;
            return;
        }

        foreach (var orderItem in orderFromDb.OrderItems)
        {
            var stock = await context.Stocks
                .FirstOrDefaultAsync(s =>
                    s.Product_Id == orderItem.Product_Id &&
                    s.Size_Id == orderItem.Size_Id);

            if (stock is not null)
            {
                stock.Stock_Quantity += orderItem.OrderItem_Quantity;
            }
        }

        orderFromDb.Order_Status = "cancelled";

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/profile");
    }

    private static bool CanUserCancelOrder(string? status)
    {
        return status is "new" or "confirmed" or "paid";
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }
}