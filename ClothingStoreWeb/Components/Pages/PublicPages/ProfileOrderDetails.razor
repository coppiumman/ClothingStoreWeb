@page "/profile/order"
@layout PublicLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Подробности заказа</PageTitle>

<div class="order-details-page">
    <h1>Подробности заказа</h1>

    @if (order is null)
    {
        <p class="order-details-muted"><em>Загрузка...</em></p>
    }
    else
    {
        <section class="order-details-summary">
            <div>
                <div class="order-details-label">Номер заказа</div>
                <div class="order-details-value">Заказ №@order.Order_Id</div>
            </div>

            <div>
                <div class="order-details-label">Дата заказа</div>
                <div class="order-details-value">@order.Order_Date.ToString("dd.MM.yyyy HH:mm")</div>
            </div>

            <div>
                <div class="order-details-label">Статус</div>
                <div class="order-details-value">@GetOrderStatusName(order.Order_Status)</div>
            </div>

            <div>
                <div class="order-details-label">Сумма заказа</div>
                <div class="order-details-value">@order.Order_TotalAmount.ToString("N2") ₽</div>
            </div>
        </section>

        <section class="order-details-section">
            <h2>Данные оформления</h2>

            <div class="order-checkout-info">
                <div class="order-checkout-info-item">
                    <span>ФИО получателя</span>
                    <strong>@GetDisplayValue(order.Order_RecipientName)</strong>
                </div>

                <div class="order-checkout-info-item">
                    <span>Телефон</span>
                    <strong>@GetDisplayValue(order.Order_RecipientPhone)</strong>
                </div>

                <div class="order-checkout-info-item">
                    <span>Email</span>
                    <strong>@GetDisplayValue(order.Order_RecipientEmail)</strong>
                </div>

                <div class="order-checkout-info-item">
                    <span>Способ доставки</span>
                    <strong>@GetDeliveryMethodName(order.Order_DeliveryMethod)</strong>
                </div>

                <div class="order-checkout-info-item">
                    <span>Адрес доставки</span>
                    <strong>@GetDisplayValue(order.Order_DeliveryAddress)</strong>
                </div>

                <div class="order-checkout-info-item">
                    <span>Способ оплаты</span>
                    <strong>@GetPaymentMethodName(order.Order_PaymentMethod)</strong>
                </div>

                <div class="order-checkout-info-item order-checkout-info-item-wide">
                    <span>Комментарий к заказу</span>
                    <strong>@GetDisplayValue(order.Order_Comment)</strong>
                </div>
            </div>
        </section>

        <section class="order-details-section">
            <h2>Состав заказа</h2>

            @if (!order.OrderItems.Any())
            {
                <p class="order-details-muted">В заказе нет позиций.</p>
            }
            else
            {
                <div class="order-items-scroll">
                    <table class="order-items-table">
                        <thead>
                            <tr>
                                <th>Товар</th>
                                <th>Размер</th>
                                <th>Количество</th>
                                <th>Цена</th>
                                <th>Сумма</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td>@item.Product?.Product_Name</td>
                                    <td>@item.Size?.Size_Name</td>
                                    <td>@item.OrderItem_Quantity</td>
                                    <td>@item.OrderItem_Price.ToString("N2") ₽</td>
                                    <td>@((item.OrderItem_Price * item.OrderItem_Quantity).ToString("N2")) ₽</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <p class="order-details-back">
            <a class="order-details-button" href="@GetReturnProfileUrl()">
                Вернуться в личный кабинет
            </a>
        </p>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    private int Order_Id { get; set; }

    [SupplyParameterFromQuery(Name = "returnTab")]
    private string? ReturnTab { get; set; }

    private Order? order;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        order = await context.Orders
            .AsNoTracking()
            .Include(o => o.OrderItems)
                .ThenInclude(oi => oi.Product)
            .Include(o => o.OrderItems)
                .ThenInclude(oi => oi.Size)
            .FirstOrDefaultAsync(o => o.Order_Id == Order_Id && o.User_Id == userId);

        if (order is null)
        {
            NavigationManager.NavigateTo("/profile");
        }
    }

    private static string GetOrderStatusName(string? status)
    {
        return status switch
        {
            "new" => "Новый",
            "confirmed" => "Подтверждён",
            "paid" => "Оплачен",
            "processing" => "В обработке",
            "shipped" => "Отправлен",
            "delivered" => "Доставлен",
            "done" => "Завершён",
            "cancelled" => "Отменён",
            "returned" => "Возврат",
            _ => status ?? ""
        };
    }

    private static string GetDisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "Не указано"
            : value;
    }

    private static string GetDeliveryMethodName(string? deliveryMethod)
    {
        return deliveryMethod switch
        {
            "pickup" => "Самовывоз",
            "courier" => "Курьерская доставка",
            "point" => "Пункт выдачи",
            _ => string.IsNullOrWhiteSpace(deliveryMethod) ? "Не указано" : deliveryMethod
        };
    }

    private static string GetPaymentMethodName(string? paymentMethod)
    {
        return paymentMethod switch
        {
            "cash" => "Оплата при получении",
            "card" => "Банковской картой при получении",
            _ => string.IsNullOrWhiteSpace(paymentMethod) ? "Не указано" : paymentMethod
        };
    }

    private string GetReturnProfileUrl()
    {
        return ReturnTab switch
        {
            "current" => "/profile?tab=current",
            "history" => "/profile?tab=history",
            _ => "/profile?tab=profile"
        };
    }
}