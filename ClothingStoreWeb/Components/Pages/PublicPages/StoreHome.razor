@page "/store"
@layout PublicLayout
@implements IDisposable

@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Data
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Интернет-магазин одежды</PageTitle>

<section class="store-hero">
    @if (heroSlides.Count > 0)
    {
        <div class="store-hero-slider @slideDirectionClass">
            @for (var i = 0; i < heroSlides.Count; i++)
            {
                var slide = heroSlides[i];

                <div class="store-hero-slide @(i == currentSlideIndex ? "active" : "")">
                    <div class="store-hero-image">
                        @if (!string.IsNullOrWhiteSpace(slide.ImagePath))
                        {
                            <img src="@slide.ImagePath" alt="@slide.Title" />
                        }
                        else
                        {
                            <div class="store-hero-placeholder">
                                <span>Интернет-магазин одежды</span>
                            </div>
                        }
                    </div>

                    <div class="store-hero-overlay">
                        @if (!string.IsNullOrWhiteSpace(slide.Label))
                        {
                            <p class="store-hero-label">@slide.Label</p>
                        }

                        <h1>@slide.Title</h1>

                        @if (!string.IsNullOrWhiteSpace(slide.Description))
                        {
                            <p>@slide.Description</p>
                        }

                        <a class="store-hero-link" href="@slide.Link">
                            @slide.ButtonText
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (heroSlides.Count > 1)
        {
            <button type="button"
                    class="store-hero-arrow store-hero-arrow-left"
                    @onclick="PreviousSlide"
                    aria-label="Предыдущий слайд">
                ‹
            </button>

            <button type="button"
                    class="store-hero-arrow store-hero-arrow-right"
                    @onclick="NextSlide"
                    aria-label="Следующий слайд">
                ›
            </button>

            <div class="store-hero-dots">
                @for (var i = 0; i < heroSlides.Count; i++)
                {
                    var slideIndex = i;

                    <button type="button"
                            class="store-hero-dot @(slideIndex == currentSlideIndex ? "active" : "")"
                            @onclick="() => SetSlide(slideIndex)"
                            aria-label="@($"Слайд {slideIndex + 1}")">
                    </button>
                }
            </div>
        }
    }
    else
    {
        <div class="store-hero-empty">
            <h1>Интернет-магазин одежды</h1>
            <p>Подберите товары, просмотрите размеры и оформите заказ онлайн.</p>
            <a class="store-hero-link" href="/catalog">Смотреть каталог</a>
        </div>
    }
</section>

<section class="store-products-section">
    <div class="store-section-header">
        <h2>@newProductsTitle</h2>
        <a href="@newProductsLink">@newProductsLinkText</a>
    </div>

    @if (newProducts.Count > 0)
    {
        <div class="store-product-grid">
            @foreach (var product in newProducts)
            {
                <a class="store-product-card" href="@($"/catalog/product/{product.Product_Id}")">
                    <div class="store-product-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath))
                        {
                            <img src="@product.Product_ImagePath" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>

                    <div class="store-product-info">
                        <h3>@product.Product_Name</h3>
                        <p>@product.Product_Price.ToString("N2") ₽</p>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <p class="store-muted">Товары для отображения пока отсутствуют.</p>
    }
</section>

@if (posterBlock is not null)
{
    <section class="store-category-poster @(string.IsNullOrWhiteSpace(posterBlock.HomeBanner_ImagePath) ? "" : "has-image")"
             style="@GetPosterBackgroundStyle()">
        <div class="store-category-poster-content">
            @if (!string.IsNullOrWhiteSpace(posterBlock.HomeBanner_Label))
            {
                <p>@posterBlock.HomeBanner_Label</p>
            }

            <h2>@posterBlock.HomeBanner_Title</h2>

            @if (!string.IsNullOrWhiteSpace(posterBlock.HomeBanner_ButtonText))
            {
                <a href="@GetSafeLink(posterBlock.HomeBanner_ButtonUrl)">
                    @posterBlock.HomeBanner_ButtonText
                </a>
            }
        </div>
    </section>
}

<section class="store-products-section">
    <div class="store-section-header">
        <h2>@hitProductsTitle</h2>
        <a href="@hitProductsLink">@hitProductsLinkText</a>
    </div>

    @if (hitProducts.Count > 0)
    {
        <div class="store-product-grid">
            @foreach (var product in hitProducts)
            {
                <a class="store-product-card" href="@($"/catalog/product/{product.Product_Id}")">
                    <div class="store-product-image">
                        @if (!string.IsNullOrWhiteSpace(product.Product_ImagePath))
                        {
                            <img src="@product.Product_ImagePath" alt="@product.Product_Name" />
                        }
                        else
                        {
                            <span>Нет изображения</span>
                        }
                    </div>

                    <div class="store-product-info">
                        <h3>@product.Product_Name</h3>
                        <p>@product.Product_Price.ToString("N2") ₽</p>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <p class="store-muted">Товары для отображения пока отсутствуют.</p>
    }
</section>

@code {
    private readonly List<HeroSlide> heroSlides = new();
    private readonly List<Product> newProducts = new();
    private readonly List<Product> hitProducts = new();

    private HomeBanner? posterBlock;

    private string newProductsTitle = "Новинки";
    private string newProductsLinkText = "Смотреть всё";
    private string newProductsLink = "/catalog";

    private string hitProductsTitle = "Хиты";
    private string hitProductsLinkText = "В каталог";
    private string hitProductsLink = "/catalog";

    private int currentSlideIndex;
    private string slideDirectionClass = "slide-next";

    private PeriodicTimer? heroTimer;
    private CancellationTokenSource? heroTimerCancellation;

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        var homeBlocks = await context.HomeBanners
            .AsNoTracking()
            .Where(block => !block.HomeBanner_IsHidden)
            .OrderBy(block => block.HomeBanner_DisplayOrder)
            .ThenBy(block => block.HomeBanner_Id)
            .ToListAsync();

        var heroBlocks = homeBlocks
            .Where(block => block.HomeBanner_Type == "Hero")
            .Take(3)
            .ToList();

        foreach (var block in heroBlocks)
        {
            heroSlides.Add(new HeroSlide
            {
                Label = block.HomeBanner_Label ?? string.Empty,
                Title = block.HomeBanner_Title,
                Description = block.HomeBanner_Description ?? string.Empty,
                ImagePath = block.HomeBanner_ImagePath,
                Link = GetSafeLink(block.HomeBanner_ButtonUrl),
                ButtonText = string.IsNullOrWhiteSpace(block.HomeBanner_ButtonText)
                    ? "Смотреть каталог"
                    : block.HomeBanner_ButtonText
            });
        }

        posterBlock = homeBlocks
            .FirstOrDefault(block => block.HomeBanner_Type == "Poster");

        var newProductBlocks = homeBlocks
            .Where(block => block.HomeBanner_Type == "NewProducts")
            .Take(4)
            .ToList();

        var hitProductBlocks = homeBlocks
            .Where(block => block.HomeBanner_Type == "HitProducts")
            .Take(4)
            .ToList();

        var newProductsHeaderBlock = GetSectionHeaderBlock(newProductBlocks);
        var hitProductsHeaderBlock = GetSectionHeaderBlock(hitProductBlocks);

        ApplySectionHeader(
            newProductsHeaderBlock,
            defaultTitle: "Новинки",
            defaultLinkText: "Смотреть всё",
            ref newProductsTitle,
            ref newProductsLinkText,
            ref newProductsLink);

        ApplySectionHeader(
            hitProductsHeaderBlock,
            defaultTitle: "Хиты",
            defaultLinkText: "В каталог",
            ref hitProductsTitle,
            ref hitProductsLinkText,
            ref hitProductsLink);

        var latestProducts = await context.Products
            .AsNoTracking()
            .Where(product => !product.Product_IsHidden)
            .OrderByDescending(product => product.Product_Id)
            .Take(20)
            .ToListAsync();

        var popularProducts = await context.Products
            .AsNoTracking()
            .Where(product => !product.Product_IsHidden)
            .OrderByDescending(product => product.OrderItems.Sum(orderItem => orderItem.OrderItem_Quantity))
            .ThenByDescending(product => product.Product_Id)
            .Take(20)
            .ToListAsync();

        newProducts.AddRange(
            await BuildProductSectionAsync(
                context,
                newProductBlocks,
                latestProducts,
                maxCount: 4));

        hitProducts.AddRange(
            await BuildProductSectionAsync(
                context,
                hitProductBlocks,
                popularProducts,
                maxCount: 4));

        StartHeroTimer();
    }

    private static HomeBanner? GetSectionHeaderBlock(List<HomeBanner> blocks)
    {
        return blocks.FirstOrDefault(block =>
                   !TryGetProductIdFromUrl(block.HomeBanner_ButtonUrl, out _))
               ?? blocks.FirstOrDefault();
    }

    private static void ApplySectionHeader(
        HomeBanner? block,
        string defaultTitle,
        string defaultLinkText,
        ref string title,
        ref string linkText,
        ref string link)
    {
        if (block is null)
        {
            title = defaultTitle;
            linkText = defaultLinkText;
            link = "/catalog";
            return;
        }

        title = string.IsNullOrWhiteSpace(block.HomeBanner_Title)
            ? defaultTitle
            : block.HomeBanner_Title;

        linkText = string.IsNullOrWhiteSpace(block.HomeBanner_ButtonText)
            ? defaultLinkText
            : block.HomeBanner_ButtonText;

        link = GetSafeLink(block.HomeBanner_ButtonUrl);
    }

    private static async Task<List<Product>> BuildProductSectionAsync(
        ApplicationDbContext context,
        List<HomeBanner> sectionBlocks,
        List<Product> fallbackProducts,
        int maxCount)
    {
        var result = new List<Product>();

        var selectedProductIds = sectionBlocks
            .Select(block => TryGetProductIdFromUrl(block.HomeBanner_ButtonUrl, out var productId)
                ? productId
                : 0)
            .Where(productId => productId > 0)
            .Distinct()
            .ToList();

        if (selectedProductIds.Count > 0)
        {
            var selectedProducts = await context.Products
                .AsNoTracking()
                .Where(product =>
                    !product.Product_IsHidden &&
                    selectedProductIds.Contains(product.Product_Id))
                .ToDictionaryAsync(
                    product => product.Product_Id,
                    product => product);

            foreach (var productId in selectedProductIds)
            {
                if (selectedProducts.TryGetValue(productId, out var product))
                {
                    result.Add(product);
                }

                if (result.Count >= maxCount)
                {
                    return result;
                }
            }
        }

        foreach (var product in fallbackProducts)
        {
            if (result.Any(item => item.Product_Id == product.Product_Id))
            {
                continue;
            }

            result.Add(product);

            if (result.Count >= maxCount)
            {
                break;
            }
        }

        return result;
    }

    private static bool TryGetProductIdFromUrl(string? url, out int productId)
    {
        productId = 0;

        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        const string productUrlPrefix = "/catalog/product/";

        if (!url.StartsWith(productUrlPrefix, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var idText = url[productUrlPrefix.Length..];

        return int.TryParse(idText, out productId);
    }

    private static string GetSafeLink(string? url)
    {
        return string.IsNullOrWhiteSpace(url)
            ? "/catalog"
            : url;
    }

    private string GetPosterBackgroundStyle()
    {
        if (posterBlock is null || string.IsNullOrWhiteSpace(posterBlock.HomeBanner_ImagePath))
        {
            return string.Empty;
        }

        return $"background-image: linear-gradient(rgba(255,255,255,0.35), rgba(255,255,255,0.35)), url('{posterBlock.HomeBanner_ImagePath}');";
    }

    private void StartHeroTimer()
    {
        StopHeroTimer();

        if (heroSlides.Count <= 1)
        {
            return;
        }

        heroTimerCancellation = new CancellationTokenSource();
        heroTimer = new PeriodicTimer(TimeSpan.FromSeconds(25));

        _ = AutoSwitchSlidesAsync(heroTimerCancellation.Token);
    }

    private void StopHeroTimer()
    {
        heroTimerCancellation?.Cancel();
        heroTimerCancellation?.Dispose();
        heroTimerCancellation = null;

        heroTimer?.Dispose();
        heroTimer = null;
    }

    private async Task AutoSwitchSlidesAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (heroTimer is not null &&
                   await heroTimer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(() =>
                {
                    GoToNextSlide(resetTimer: false);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void PreviousSlide()
    {
        GoToPreviousSlide(resetTimer: true);
    }

    private void NextSlide()
    {
        GoToNextSlide(resetTimer: true);
    }

    private void GoToPreviousSlide(bool resetTimer)
    {
        if (heroSlides.Count == 0)
        {
            return;
        }

        slideDirectionClass = "slide-prev";
        currentSlideIndex--;

        if (currentSlideIndex < 0)
        {
            currentSlideIndex = heroSlides.Count - 1;
        }

        if (resetTimer)
        {
            StartHeroTimer();
        }
    }

    private void GoToNextSlide(bool resetTimer)
    {
        if (heroSlides.Count == 0)
        {
            return;
        }

        slideDirectionClass = "slide-next";
        currentSlideIndex++;

        if (currentSlideIndex >= heroSlides.Count)
        {
            currentSlideIndex = 0;
        }

        if (resetTimer)
        {
            StartHeroTimer();
        }
    }

    private void SetSlide(int slideIndex)
    {
        if (slideIndex < 0 ||
            slideIndex >= heroSlides.Count ||
            slideIndex == currentSlideIndex)
        {
            return;
        }

        slideDirectionClass = slideIndex > currentSlideIndex
            ? "slide-next"
            : "slide-prev";

        currentSlideIndex = slideIndex;

        StartHeroTimer();
    }

    public void Dispose()
    {
        StopHeroTimer();
    }

    private sealed class HeroSlide
    {
        public string Label { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string? ImagePath { get; set; }
        public string Link { get; set; } = "/catalog";
        public string ButtonText { get; set; } = "Смотреть каталог";
    }
}