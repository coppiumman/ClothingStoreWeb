@page "/sizes/create"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Добавление размера</PageTitle>

<div class="size-form-page">
    <div class="size-form-header">
        <h1>Добавление размера</h1>
        <p>
            Добавьте новый размер одежды. После добавления размер можно будет использовать
            при настройке складских остатков и оформлении товаров.
        </p>
    </div>

    @if (Size is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="size-form-card">
            <EditForm method="post" Model="Size" OnValidSubmit="AddSize" FormName="create" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="size-form-alert">
                        @errorMessage
                    </div>
                }

                <div class="size-form-group">
                    <label for="size_name">
                        Размер <span>*</span>
                    </label>

                    <InputText id="size_name"
                               @bind-Value="Size.Size_Name"
                               class="size-form-control"
                               aria-required="true"
                               placeholder="Например: 42, 44, S, M, L" />

                    <ValidationMessage For="() => Size.Size_Name" class="text-danger" />
                </div>

                <div class="size-form-actions">
                    <button type="submit" class="size-button size-button-primary">
                        Добавить размер
                    </button>

                    <a class="size-button" href="/sizes">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Size Size { get; set; } = new();

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanCreateAsync("Sizes"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        Size ??= new();
    }

    private async Task AddSize()
    {
        errorMessage = null;

        Size.Size_Name = Size.Size_Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(Size.Size_Name))
        {
            errorMessage = "Укажите размер.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var sizeExists = await context.Sizes
            .AnyAsync(size => size.Size_Name == Size.Size_Name);

        if (sizeExists)
        {
            errorMessage = "Размер с таким названием уже существует.";
            return;
        }

        context.Sizes.Add(Size);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/sizes");
    }
}