@page "/sizes/delete"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Удаление размера</PageTitle>

<div class="size-delete-page">
    <div class="size-delete-header">
        <h1>Удаление размера</h1>
        <p>
            Перед удалением проверьте выбранный размер. Если размер используется в складских
            остатках или позициях заказов, приложение не позволит удалить его из базы данных.
        </p>
    </div>

    @if (size is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="size-delete-card">
            <div class="size-delete-warning">
                Вы действительно хотите удалить этот размер?
            </div>

            <div class="size-delete-row">
                <span>Размер</span>
                <strong>@size.Size_Name</strong>
            </div>

            <div class="size-delete-row">
                <span>Складские записи</span>
                <strong>@stockUsageCount</strong>
            </div>

            <div class="size-delete-row">
                <span>Позиции заказов</span>
                <strong>@orderUsageCount</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="size-delete-blocked">
                    @errorMessage
                </div>
            }

            <EditForm method="post" Model="size" OnValidSubmit="DeleteSize" FormName="delete" Enhance>
                <div class="size-delete-actions">
                    <button type="submit"
                            class="size-button size-button-danger">
                        Удалить размер
                    </button>

                    <a class="size-button" href="/sizes">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Size? size;
    private int stockUsageCount;
    private int orderUsageCount;
    private string? errorMessage;

    private bool isUsed => stockUsageCount > 0 || orderUsageCount > 0;

    [SupplyParameterFromQuery]
    private int Size_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Sizes"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        size = await context.Sizes
            .FirstOrDefaultAsync(size => size.Size_Id == Size_Id);

        if (size is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        stockUsageCount = await context.Stocks
            .CountAsync(stock => stock.Size_Id == Size_Id);

        orderUsageCount = await context.OrderItems
            .CountAsync(orderItem => orderItem.Size_Id == Size_Id);
    }


    private async Task DeleteSize()
    {
        errorMessage = null;

        await using var context = await DbFactory.CreateDbContextAsync();

        var sizeToDelete = await context.Sizes
            .FirstOrDefaultAsync(size => size.Size_Id == Size_Id);

        if (sizeToDelete is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var sizeIsUsed = await context.Stocks.AnyAsync(stock => stock.Size_Id == Size_Id)
            || await context.OrderItems.AnyAsync(orderItem => orderItem.Size_Id == Size_Id);

        if (sizeIsUsed)
        {
            stockUsageCount = await context.Stocks.CountAsync(stock => stock.Size_Id == Size_Id);
            orderUsageCount = await context.OrderItems.CountAsync(orderItem => orderItem.Size_Id == Size_Id);

            errorMessage = "Размер используется в складских остатках или заказах, поэтому удалить его нельзя. Сначала необходимо удалить или изменить связанные записи.";
            return;
        }

        context.Sizes.Remove(sizeToDelete);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/sizes");
    }
}