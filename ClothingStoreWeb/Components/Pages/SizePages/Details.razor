@page "/sizes/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр</PageTitle>

<h1>Просмотр</h1>

<div>
    <h2>Размер</h2>
    <hr />
    @if (size is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Размер</dt>
            <dd class="col-sm-10">@size.Size_Name</dd>
        </dl>
        <div>
            @if (canEdit)
            {
                <a href="@($"/sizes/edit?size_id={size.Size_Id}")">Изменить</a>
                <span> | </span>
            }
            <a href="@($"/sizes")">Вернуться к списку</a>
        </div>
    }
</div>

@code {
    private Size? size;
    private bool canEdit;

    [SupplyParameterFromQuery]
    private int Size_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Sizes"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Sizes");

        using var context = DbFactory.CreateDbContext();
        size = await context.Sizes.FirstOrDefaultAsync(m => m.Size_Id == Size_Id);

        if (size is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
