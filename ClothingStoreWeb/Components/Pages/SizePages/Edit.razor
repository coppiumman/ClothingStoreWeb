@page "/sizes/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование</PageTitle>

<h1>Редактирование</h1>

<h2>Размер</h2>
<hr />
@if (Size is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Size" OnValidSubmit="UpdateSize" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Size.Size_Id" value="@Size.Size_Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="size_name" class="form-label">Размер:</label>
                    <InputText id="size_name" @bind-Value="Size.Size_Name" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Size.Size_Name" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/sizes">Вернуться к списку</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Size_Id { get; set; }

    [SupplyParameterFromForm]
    private Size? Size { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Sizes"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();
        Size ??= await context.Sizes.FirstOrDefaultAsync(m => m.Size_Id == Size_Id);

        if (Size is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateSize()
    {
        if (Size is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var sizeFromDb = await context.Sizes
            .FirstOrDefaultAsync(size => size.Size_Id == Size.Size_Id);

        if (sizeFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        sizeFromDb.Size_Name = Size.Size_Name;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!SizeExists(Size.Size_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo("/sizes");
    }

    private bool SizeExists(int size_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Sizes.Any(e => e.Size_Id == size_id);
    }
}
