@page "/sizes/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование размера</PageTitle>

<div class="size-form-page">
    <div class="size-form-header">
        <h1>Редактирование размера</h1>
        <p>
            Измените название размера. Изменение будет применено к справочнику размеров,
            складским остаткам и связанным позициям заказов.
        </p>
    </div>

    @if (Size is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="size-form-card">
            <EditForm method="post" Model="Size" OnValidSubmit="UpdateSize" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <input type="hidden" name="Size.Size_Id" value="@Size.Size_Id" />

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="size-form-alert">
                        @errorMessage
                    </div>
                }

                <div class="size-form-group">
                    <label for="size_name">
                        Размер <span>*</span>
                    </label>

                    <InputText id="size_name"
                               @bind-Value="Size.Size_Name"
                               class="size-form-control"
                               aria-required="true" />

                    <ValidationMessage For="() => Size.Size_Name" class="text-danger" />
                </div>

                <div class="size-form-actions">
                    <button type="submit" class="size-button size-button-primary">
                        Сохранить изменения
                    </button>

                    <a class="size-button" href="/sizes">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int Size_Id { get; set; }

    [SupplyParameterFromForm]
    private Size? Size { get; set; }

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Sizes"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        Size ??= await context.Sizes
            .FirstOrDefaultAsync(size => size.Size_Id == Size_Id);

        if (Size is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateSize()
    {
        if (Size is null)
        {
            return;
        }

        errorMessage = null;
        Size.Size_Name = Size.Size_Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(Size.Size_Name))
        {
            errorMessage = "Укажите размер.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var duplicateExists = await context.Sizes
            .AnyAsync(size =>
                size.Size_Id != Size.Size_Id &&
                size.Size_Name == Size.Size_Name);

        if (duplicateExists)
        {
            errorMessage = "Размер с таким названием уже существует.";
            return;
        }

        context.Attach(Size).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!await SizeExistsAsync(Size.Size_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo("/sizes");
    }

    private async Task<bool> SizeExistsAsync(int sizeId)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        return await context.Sizes.AnyAsync(size => size.Size_Id == sizeId);
    }
}