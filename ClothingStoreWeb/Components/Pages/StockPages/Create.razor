@page "/stocks/create"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Добавление запаса</PageTitle>

<div class="stock-form-page">
    <div class="stock-form-header">
        <h1>Добавление запаса</h1>
        <p>
            Добавьте складскую запись для выбранного товара и размера. Один и тот же товар
            не может иметь две одинаковые записи для одного размера.
        </p>
    </div>

    @if (SelectedCategory is not null)
    {
        <div class="stock-category-panel">
            <span>Выбранная категория</span>
            <strong>@SelectedCategory.Category_Name</strong>
        </div>
    }

    @if (Stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="stock-form-card">
            <EditForm method="post" Model="Stock" OnValidSubmit="AddStock" FormName="create" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                @if (!string.IsNullOrWhiteSpace(createError))
                {
                    <div class="stock-form-alert">
                        @createError
                    </div>
                }

                <div class="stock-form-group">
                    <label for="product_id">Товар <span>*</span></label>

                    <InputSelect id="product_id"
                                 @bind-Value="Stock.Product_Id"
                                 class="stock-form-control">
                        <option value="0">Выберите товар</option>
                        @foreach (var product in Products)
                        {
                            <option value="@product.Product_Id">@product.Product_Name</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => Stock.Product_Id" class="text-danger" />
                </div>

                <div class="stock-form-group">
                    <label for="size_id">Размер <span>*</span></label>

                    <InputSelect id="size_id"
                                 @bind-Value="Stock.Size_Id"
                                 class="stock-form-control">
                        <option value="0">Выберите размер</option>
                        @foreach (var size in Sizes)
                        {
                            <option value="@size.Size_Id">@size.Size_Name</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => Stock.Size_Id" class="text-danger" />
                </div>

                <div class="stock-form-group">
                    <label for="stock_quantity">Количество на складе <span>*</span></label>

                    <InputNumber id="stock_quantity"
                                 @bind-Value="Stock.Stock_Quantity"
                                 class="stock-form-control"
                                 min="0"
                                 ParsingErrorMessage="Введите корректное количество на складе" />

                    <ValidationMessage For="() => Stock.Stock_Quantity" class="text-danger" />
                </div>

                <div class="stock-form-actions">
                    <button type="submit" class="stock-button stock-button-primary">
                        Добавить запас
                    </button>

                    <a class="stock-button" href="@BackUrl">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Stock Stock { get; set; } = new();

    private List<Product> Products { get; set; } = new();
    private List<Size> Sizes { get; set; } = new();
    private string? createError;

    [SupplyParameterFromQuery]
    private int Category_Id { get; set; }

    private Category? SelectedCategory;

    private string BackUrl => Category_Id == 0
        ? "/stocks"
        : $"/stocks?category_id={Category_Id}";

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanCreateAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        Stock ??= new();

        if (Category_Id == 0)
        {
            NavigationManager.NavigateTo("/stocks");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        SelectedCategory = await context.Categories
            .AsNoTracking()
            .FirstOrDefaultAsync(category => category.Category_Id == Category_Id);

        if (SelectedCategory is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        Products = await context.Products
            .AsNoTracking()
            .Where(product => product.Category_Id == Category_Id)
            .OrderBy(product => product.Product_DisplayOrder)
            .ThenBy(product => product.Product_Name)
            .ToListAsync();

        Sizes = await context.Sizes
            .AsNoTracking()
            .OrderBy(size => size.Size_Name)
            .ToListAsync();
    }

    private async Task AddStock()
    {
        createError = null;

        if (Stock.Product_Id == 0)
        {
            createError = "Выберите товар.";
            return;
        }

        if (Stock.Size_Id == 0)
        {
            createError = "Выберите размер.";
            return;
        }

        if (Stock.Stock_Quantity < 0)
        {
            createError = "Количество на складе не может быть отрицательным.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var stockAlreadyExists = await context.Stocks.AnyAsync(stock =>
            stock.Product_Id == Stock.Product_Id &&
            stock.Size_Id == Stock.Size_Id);

        if (stockAlreadyExists)
        {
            createError = "Запас для выбранного товара и размера уже существует. Измените количество в существующей записи.";
            return;
        }

        context.Stocks.Add(Stock);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo(BackUrl);
    }
}