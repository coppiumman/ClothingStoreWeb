@page "/stocks/delete"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Удаление запаса</PageTitle>

<div class="stock-delete-page">
    <div class="stock-delete-header">
        <h1>Удаление запаса</h1>
        <p>
            Перед удалением проверьте складскую запись. Если товар и размер уже использовались
            в заказах, запись лучше не удалять, а установить количество на складе равным 0.
        </p>
    </div>

    @if (stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="stock-delete-card">
            <div class="stock-delete-warning">
                Вы действительно хотите удалить этот запас?
            </div>

            <div class="stock-delete-row">
                <span>Товар</span>
                <strong>@stock.Product?.Product_Name</strong>
            </div>

            <div class="stock-delete-row">
                <span>Размер</span>
                <strong>@stock.Size?.Size_Name</strong>
            </div>

            <div class="stock-delete-row">
                <span>Количество на складе</span>
                <strong>@stock.Stock_Quantity</strong>
            </div>

            <div class="stock-delete-row">
                <span>Позиции заказов</span>
                <strong>@orderUsageCount</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(deleteError))
            {
                <div class="stock-delete-blocked">
                    @deleteError
                </div>
            }

            <EditForm method="post" Model="stock" OnValidSubmit="DeleteStock" FormName="delete" Enhance>
                <div class="stock-delete-actions">
                    <button type="submit" class="stock-button stock-button-danger">
                        Удалить запас
                    </button>

                    <a class="stock-button" href="@BackUrl">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private Stock? stock;
    private int orderUsageCount;
    private string? deleteError;

    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    [SupplyParameterFromQuery]
    private int? Category_Id { get; set; }

    private string BackUrl => Category_Id is null or 0
        ? "/stocks"
        : $"/stocks?category_id={Category_Id}";

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        stock = await context.Stocks
            .Include(stock => stock.Product)
            .Include(stock => stock.Size)
            .FirstOrDefaultAsync(stock => stock.Stock_Id == Stock_Id);

        if (stock is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        orderUsageCount = await context.OrderItems.CountAsync(orderItem =>
            orderItem.Product_Id == stock.Product_Id &&
            orderItem.Size_Id == stock.Size_Id);
    }

    private async Task DeleteStock()
    {
        if (stock is null)
        {
            return;
        }

        deleteError = null;

        await using var context = await DbFactory.CreateDbContextAsync();

        var stockFromDb = await context.Stocks
            .FirstOrDefaultAsync(stock => stock.Stock_Id == stock.Stock_Id);

        if (stockFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var isUsedInOrders = await context.OrderItems.AnyAsync(orderItem =>
            orderItem.Product_Id == stockFromDb.Product_Id &&
            orderItem.Size_Id == stockFromDb.Size_Id);

        if (isUsedInOrders)
        {
            orderUsageCount = await context.OrderItems.CountAsync(orderItem =>
                orderItem.Product_Id == stockFromDb.Product_Id &&
                orderItem.Size_Id == stockFromDb.Size_Id);

            deleteError = "Удаление невозможно: данный товар и размер уже используются в заказах. Чтобы убрать товар из продажи, установите количество на складе равным 0.";
            return;
        }

        context.Stocks.Remove(stockFromDb);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo(BackUrl);
    }
}