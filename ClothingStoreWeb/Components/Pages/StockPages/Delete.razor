@page "/stocks/delete"
@attribute [Authorize(Roles = "Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Удаление</PageTitle>

<h1>Удаление</h1>

<p>Вы уверены, что хотите удалить этот элемент?</p>
<div>
    <h2>Запас</h2>
    <hr />
    @if (stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Товар</dt>
            <dd class="col-sm-10">@stock.Product?.Product_Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Размер</dt>
            <dd class="col-sm-10">@stock.Size?.Size_Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Количество на складе</dt>
            <dd class="col-sm-10">@stock.Stock_Quantity</dd>
        </dl>

        @if (!string.IsNullOrWhiteSpace(deleteError))
        {
            <div class="alert alert-danger">
                @deleteError
            </div>
        }

        <EditForm method="post" Model="stock" OnValidSubmit="DeleteStock" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(stock is null)">Удалить</button> |
            <a href="@BackUrl">Вернуться к списку</a>
        </EditForm>
    }
</div>

@code {
    private Stock? stock;
    private string? deleteError;

    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanDeleteAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();
        stock = await context.Stocks
        .Include(s => s.Product)
        .Include(s => s.Size)
        .FirstOrDefaultAsync(m => m.Stock_Id == Stock_Id);

        if (stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteStock()
    {
        if (stock is null)
        {
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var stockFromDb = await context.Stocks
            .FirstOrDefaultAsync(s => s.Stock_Id == stock.Stock_Id);

        if (stockFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var isUsedInOrders = await context.OrderItems.AnyAsync(orderItem =>
            orderItem.Product_Id == stockFromDb.Product_Id &&
            orderItem.Size_Id == stockFromDb.Size_Id);

        if (isUsedInOrders)
        {
            deleteError = "Удаление невозможно: данный товар и размер уже используются в заказах. Установите количество на складе равным 0.";
            return;
        }

        context.Stocks.Remove(stockFromDb);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo(BackUrl);
    }

    [SupplyParameterFromQuery]
    private int? Category_Id { get; set; }

    private string BackUrl => Category_Id is null or 0
        ? "/stocks"
        : $"/stocks?category_id={Category_Id}";
}
