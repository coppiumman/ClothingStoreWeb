@page "/stocks/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр запаса</PageTitle>

<div class="stock-details-page">
    <div class="stock-details-header">
        <h1>Просмотр запаса</h1>
        <p>
            На странице отображается выбранная складская запись: товар, размер,
            количество на складе и текущий статус наличия.
        </p>
    </div>

    @if (stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="stock-details-card">
            <div class="stock-details-row">
                <span>Товар</span>
                <strong>@stock.Product?.Product_Name</strong>
            </div>

            <div class="stock-details-row">
                <span>Размер</span>
                <strong>@stock.Size?.Size_Name</strong>
            </div>

            <div class="stock-details-row">
                <span>Количество на складе</span>
                <strong>@stock.Stock_Quantity</strong>
            </div>

            <div class="stock-details-row">
                <span>Статус</span>
                @if (stock.Stock_Quantity == 0)
                {
                    <strong class="stock-status stock-status-empty">Нет в наличии</strong>
                }
                else if (stock.Stock_Quantity <= 3)
                {
                    <strong class="stock-status stock-status-low">Мало</strong>
                }
                else
                {
                    <strong class="stock-status stock-status-normal">В наличии</strong>
                }
            </div>
        </div>

        <div class="stock-details-actions">
            @if (canEdit)
            {
                <a class="stock-button stock-button-primary"
                   href="@($"/stocks/edit?stock_id={stock.Stock_Id}&category_id={Category_Id}")">
                    Изменить
                </a>
            }

            <a class="stock-button" href="@BackUrl">
                Вернуться к списку
            </a>
        </div>
    }
</div>

@code {
    private Stock? stock;
    private bool canEdit;

    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    [SupplyParameterFromQuery]
    private int? Category_Id { get; set; }

    private string BackUrl => Category_Id is null or 0
        ? "/stocks"
        : $"/stocks?category_id={Category_Id}";

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Stocks");

        await using var context = await DbFactory.CreateDbContextAsync();

        stock = await context.Stocks
            .Include(stock => stock.Product)
            .Include(stock => stock.Size)
            .AsNoTracking()
            .FirstOrDefaultAsync(stock => stock.Stock_Id == Stock_Id);

        if (stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}