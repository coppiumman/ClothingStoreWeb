@page "/stocks/details"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Просмотр</PageTitle>

<h1>Просмотр</h1>

<div>
    <h2>Запас</h2>
    <hr />
    @if (stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Товар</dt>
            <dd class="col-sm-10">@stock.Product?.Product_Name</dd>
            <dt class="col-sm-2">Размер</dt>
            <dd class="col-sm-10">@stock.Size?.Size_Name</dd>
            <dt class="col-sm-2">Количество на складе</dt>
            <dd class="col-sm-10">@stock.Stock_Quantity</dd>
        </dl>
        <div>
            @if (canEdit)
            {
                <a href="@($"/stocks/edit?stock_id={stock.Stock_Id}")">Изменить</a>
                <span> | </span>
            }
            <a href="@($"/stocks")">Вернуться к списку</a>
        </div>
    }
</div>

@code {
    private Stock? stock;
    private bool canEdit;

    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        canEdit = await AccessService.CanEditAsync("Stocks");

        using var context = DbFactory.CreateDbContext();
        stock = await context.Stocks
        .Include(s => s.Product)
        .Include(s => s.Size)
        .FirstOrDefaultAsync(m => m.Stock_Id == Stock_Id);

        if (stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
