@page "/stocks/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование запаса</PageTitle>

<div class="stock-form-page">
    <div class="stock-form-header">
        <h1>Редактирование запаса</h1>
        <p>
            Измените количество товара на складе. Товар и размер не меняются на этой странице,
            так как они определяют уникальную складскую запись.
        </p>
    </div>

    @if (Stock is null)
    {
        <p><em>Загрузка...</em></p>
    }
    else
    {
        <div class="stock-form-card">
            <EditForm method="post" Model="Stock" OnValidSubmit="UpdateStock" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <input type="hidden" name="Stock.Stock_Id" value="@Stock.Stock_Id" />
                <input type="hidden" name="Stock.Product_Id" value="@Stock.Product_Id" />
                <input type="hidden" name="Stock.Size_Id" value="@Stock.Size_Id" />

                @if (!string.IsNullOrWhiteSpace(editError))
                {
                    <div class="stock-form-alert">
                        @editError
                    </div>
                }

                <div class="stock-form-info">
                    <div class="stock-form-info-row">
                        <span>Товар</span>
                        <strong>@Stock.Product?.Product_Name</strong>
                    </div>

                    <div class="stock-form-info-row">
                        <span>Размер</span>
                        <strong>@Stock.Size?.Size_Name</strong>
                    </div>
                </div>

                <div class="stock-form-group">
                    <label for="stock_quantity">Количество на складе <span>*</span></label>

                    <InputNumber id="stock_quantity"
                                 @bind-Value="Stock.Stock_Quantity"
                                 class="stock-form-control"
                                 min="0"
                                 ParsingErrorMessage="Введите корректное количество на складе" />

                    <ValidationMessage For="() => Stock.Stock_Quantity" class="text-danger" />
                </div>

                <div class="stock-form-actions">
                    <button type="submit" class="stock-button stock-button-primary">
                        Сохранить изменения
                    </button>

                    <a class="stock-button" href="@BackUrl">
                        Отмена
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    [SupplyParameterFromQuery]
    private int? Category_Id { get; set; }

    [SupplyParameterFromForm]
    private Stock? Stock { get; set; }

    private string? editError;

    private string BackUrl => Category_Id is null or 0
        ? "/stocks"
        : $"/stocks?category_id={Category_Id}";

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        Stock ??= await context.Stocks
            .Include(stock => stock.Product)
            .Include(stock => stock.Size)
            .FirstOrDefaultAsync(stock => stock.Stock_Id == Stock_Id);

        if (Stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateStock()
    {
        if (Stock is null)
        {
            return;
        }

        editError = null;

        if (Stock.Stock_Quantity < 0)
        {
            editError = "Количество на складе не может быть отрицательным.";
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();

        var stockFromDb = await context.Stocks
            .FirstOrDefaultAsync(stock => stock.Stock_Id == Stock.Stock_Id);

        if (stockFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        stockFromDb.Stock_Quantity = Stock.Stock_Quantity;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!await StockExistsAsync(Stock.Stock_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo(BackUrl);
    }

    private async Task<bool> StockExistsAsync(int stockId)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        return await context.Stocks.AnyAsync(stock => stock.Stock_Id == stockId);
    }
}