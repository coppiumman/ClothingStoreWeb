@page "/stocks/edit"
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Редактирование</PageTitle>

<h1>Редактирование</h1>

<h2>Запас</h2>
<hr />
@if (Stock is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Stock" OnValidSubmit="UpdateStock" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Stock.Stock_Id" value="@Stock.Stock_Id" />
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="product_id" class="form-label">Товар:</label>
                    <InputSelect id="product_id" @bind-Value="Stock.Product_Id" class="form-control" aria-required="true">
                        <option value="">Выберите товар</option>
                        @foreach (var product in Products)
                        {
                            <option value="@product.Product_Id">@product.Product_Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Stock.Product_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="size_id" class="form-label">Размер:</label>
                    <InputSelect id="size_id" @bind-Value="Stock.Size_Id" class="form-control" aria-required="true">
                        <option value="">Выберите размер</option>
                        @foreach (var size in Sizes)
                        {
                            <option value="@size.Size_Id">@size.Size_Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Stock.Size_Id" class="text-danger" />
                </div>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="stock_quantity" class="form-label">Количество на складе:</label>
                    <InputNumber id="stock_quantity" @bind-Value="Stock.Stock_Quantity" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Stock.Stock_Quantity" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/stocks">Вернуться к списку</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    [SupplyParameterFromForm]
    private Stock? Stock { get; set; }
    private List<Product> Products { get; set; } = new();
    private List<Size> Sizes { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        Products = await context.Products.ToListAsync();
        Sizes = await context.Sizes.ToListAsync();

        Stock ??= await context.Stocks.FirstOrDefaultAsync(m => m.Stock_Id == Stock_Id);

        if (Stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateStock()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Stock!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!StockExists(Stock!.Stock_Id))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/stocks");
    }

    private bool StockExists(int stock_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Stocks.Any(e => e.Stock_Id == stock_id);
    }
}
