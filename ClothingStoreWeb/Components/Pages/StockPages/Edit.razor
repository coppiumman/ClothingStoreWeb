@page "/stocks/edit"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using ClothingStoreWeb.Models
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование</PageTitle>

<h1>Редактирование</h1>

<h2>Запас</h2>
<hr />
@if (Stock is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Stock" OnValidSubmit="UpdateStock" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Stock.Stock_Id" value="@Stock.Stock_Id" />
                <dl class="row">
                    <dt class="col-sm-4">Товар</dt>
                    <dd class="col-sm-8">@Stock.Product?.Product_Name</dd>

                    <dt class="col-sm-4">Размер</dt>
                    <dd class="col-sm-8">@Stock.Size?.Size_Name</dd>
                </dl>
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="stock_quantity" class="form-label">Количество на складе:</label>
                    <InputNumber id="stock_quantity" @bind-Value="Stock.Stock_Quantity" class="form-control" aria-required="true" ParsingErrorMessage="Введите корректное количество на складе"/>
                    <ValidationMessage For="() => Stock.Stock_Quantity" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/stocks">Вернуться к списку</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Stock_Id { get; set; }

    [SupplyParameterFromForm]
    private Stock? Stock { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanEditAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        using var context = DbFactory.CreateDbContext();

        Stock ??= await context.Stocks
            .Include(s => s.Product)
            .Include(s => s.Size)
            .FirstOrDefaultAsync(m => m.Stock_Id == Stock_Id);

        if (Stock is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateStock()
    {
        if (Stock is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var stockFromDb = await context.Stocks
            .FirstOrDefaultAsync(s => s.Stock_Id == Stock.Stock_Id);

        if (stockFromDb is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        stockFromDb.Stock_Quantity = Stock.Stock_Quantity;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!StockExists(Stock.Stock_Id))
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }

            throw;
        }

        NavigationManager.NavigateTo("/stocks");
    }

    private bool StockExists(int stock_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Stocks.Any(e => e.Stock_Id == stock_id);
    }
}
