@page "/stocks"
@attribute [Authorize(Roles = "Сотрудник,Администратор")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClothingStoreWeb.Models
@using ClothingStoreWeb.Data
@using Microsoft.AspNetCore.Components.Authorization
@using ClosedXML.Excel
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IDbContextFactory<ClothingStoreWeb.Data.ApplicationDbContext> DbFactory
@inject EmployeeAccessService AccessService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime

<PageTitle>Запасы</PageTitle>

<div class="stocks-page">
    <div class="stocks-header">
        <div>
            <h1>Запасы</h1>

            @if (SelectedCategory is null)
            {
                <p>
                    В разделе отображаются складские остатки товаров по категориям, товарам и размерам.
                    Для начала выберите категорию, после чего можно будет просмотреть и изменить остатки
                    конкретных товаров.
                </p>
            }
            else
            {
                <p>
                    Управление складскими остатками выбранной категории. Здесь можно добавить новый запас,
                    изменить количество товара на складе, просмотреть подробности или удалить запись, если она
                    не используется в заказах.
                </p>
            }
        </div>

        <div class="stocks-header-actions">
            <button type="button"
                    class="stocks-button stocks-button-secondary"
                    @onclick="ExportStocksToExcelAsync">
                Экспорт в Excel
            </button>

            @if (SelectedCategory is not null && canCreate)
            {
                <a class="stocks-button stocks-button-primary"
                   href="@($"/stocks/create?category_id={SelectedCategory.Category_Id}")">
                    Добавить запас
                </a>
            }
        </div>
    </div>

    @if (SelectedCategory is null)
    {
        <div class="stocks-info">
            Выберите категорию, чтобы открыть список остатков товаров по размерам.
        </div>

        <div class="stocks-table-card">
            <QuickGrid Class="stocks-table" Items="categories">
                <PropertyColumn Property="category => category.Category_Name" Title="Категория" />
                <PropertyColumn Property="category => category.Category_Description" Title="Описание" />

                <TemplateColumn Title="Действия" Context="category">
                    <div class="stocks-actions">
                        <a class="stocks-action-button"
                           href="@($"/stocks?category_id={category.Category_Id}")">
                            Открыть запасы
                        </a>
                    </div>
                </TemplateColumn>
            </QuickGrid>
        </div>
    }
    else
    {
        <div class="stocks-category-panel">
            <div>
                <span>Выбранная категория</span>
                <strong>@SelectedCategory.Category_Name</strong>
            </div>

            <a class="stocks-button" href="/stocks">
                Вернуться к категориям
            </a>
        </div>

        @if (!stocks.Any())
        {
            <div class="stocks-info">
                Для выбранной категории пока нет складских записей.
            </div>
        }
        else
        {
            <div class="stocks-table-card">
                <QuickGrid Class="stocks-table" Items="stocks">
                    <TemplateColumn Title="Товар">
                        @context.Product?.Product_Name
                    </TemplateColumn>

                    <TemplateColumn Title="Размер">
                        @context.Size?.Size_Name
                    </TemplateColumn>

                    <PropertyColumn Property="stock => stock.Stock_Quantity" Title="Количество на складе" />

                    <TemplateColumn Title="Статус" Context="stock">
                        @if (stock.Stock_Quantity == 0)
                        {
                            <span class="stocks-status stocks-status-empty">Нет в наличии</span>
                        }
                        else if (stock.Stock_Quantity <= 3)
                        {
                            <span class="stocks-status stocks-status-low">Мало</span>
                        }
                        else
                        {
                            <span class="stocks-status stocks-status-normal">В наличии</span>
                        }
                    </TemplateColumn>

                    <TemplateColumn Title="Действия" Context="stock">
                        <div class="stocks-actions">
                            @if (canEdit)
                            {
                                <a class="stocks-action-button"
                                   href="@($"/stocks/edit?stock_id={stock.Stock_Id}&category_id={SelectedCategory.Category_Id}")">
                                    Изменить
                                </a>
                            }

                            <a class="stocks-action-button"
                               href="@($"/stocks/details?stock_id={stock.Stock_Id}&category_id={SelectedCategory.Category_Id}")">
                                Подробнее
                            </a>

                            @if (isAdmin && canDelete)
                            {
                                <a class="stocks-action-button stocks-action-danger"
                                   href="@($"/stocks/delete?stock_id={stock.Stock_Id}&category_id={SelectedCategory.Category_Id}")">
                                    Удалить
                                </a>
                            }
                        </div>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int? Category_Id { get; set; }

    private ApplicationDbContext? context;

    private IQueryable<Category> categories = Enumerable.Empty<Category>().AsQueryable();
    private IQueryable<Stock> stocks = Enumerable.Empty<Stock>().AsQueryable();

    private Category? SelectedCategory;

    private bool canCreate;
    private bool canEdit;
    private bool canDelete;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        if (!await AccessService.CanViewAsync("Stocks"))
        {
            NavigationManager.NavigateTo("/Account/AccessDenied");
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Администратор");

        canCreate = await AccessService.CanCreateAsync("Stocks");
        canEdit = await AccessService.CanEditAsync("Stocks");
        canDelete = isAdmin && await AccessService.CanDeleteAsync("Stocks");

        context = DbFactory.CreateDbContext();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (context is null)
        {
            return;
        }

        SelectedCategory = null;
        categories = Enumerable.Empty<Category>().AsQueryable();
        stocks = Enumerable.Empty<Stock>().AsQueryable();

        if (Category_Id is null or 0)
        {
            categories = context.Categories
                .AsNoTracking()
                .OrderBy(category => category.Category_DisplayOrder)
                .ThenBy(category => category.Category_Name);

            return;
        }

        SelectedCategory = await context.Categories
            .AsNoTracking()
            .FirstOrDefaultAsync(category => category.Category_Id == Category_Id);

        if (SelectedCategory is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        stocks = context.Stocks
            .Include(stock => stock.Product)
            .Include(stock => stock.Size)
            .AsNoTracking()
            .Where(stock => stock.Product != null && stock.Product.Category_Id == Category_Id)
            .OrderBy(stock => stock.Product != null ? stock.Product.Product_Name : "")
            .ThenBy(stock => stock.Size != null ? stock.Size.Size_Name : "");
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }

    private async Task DownloadExcelAsync(XLWorkbook workbook, string fileName)
    {
        using var stream = new MemoryStream();

        workbook.SaveAs(stream);

        var fileBytes = stream.ToArray();
        var base64 = Convert.ToBase64String(fileBytes);

        await JSRuntime.InvokeVoidAsync(
            "downloadFileFromBytes",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            base64);
    }

    private async Task ExportStocksToExcelAsync()
    {
        await using var dbContext = await DbFactory.CreateDbContextAsync();

        var stocksForExport = await dbContext.Stocks
            .Include(stock => stock.Product)
                .ThenInclude(product => product!.Category)
            .Include(stock => stock.Size)
            .AsNoTracking()
            .OrderBy(stock => stock.Product != null && stock.Product.Category != null
                ? stock.Product.Category.Category_DisplayOrder
                : 0)
            .ThenBy(stock => stock.Product != null && stock.Product.Category != null
                ? stock.Product.Category.Category_Name
                : "")
            .ThenBy(stock => stock.Product != null
                ? stock.Product.Product_DisplayOrder
                : 0)
            .ThenBy(stock => stock.Product != null
                ? stock.Product.Product_Name
                : "")
            .ThenBy(stock => stock.Size != null
                ? stock.Size.Size_Name
                : "")
            .ToListAsync();

        using var workbook = new XLWorkbook();
        var worksheet = workbook.Worksheets.Add("Запасы");

        worksheet.Cell(1, 1).Value = "Категория";
        worksheet.Cell(1, 2).Value = "Товар";
        worksheet.Cell(1, 3).Value = "Размер";
        worksheet.Cell(1, 4).Value = "Количество на складе";

        var headerRange = worksheet.Range(1, 1, 1, 4);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Fill.BackgroundColor = XLColor.LightGray;

        var row = 2;

        foreach (var stock in stocksForExport)
        {
            worksheet.Cell(row, 1).Value = stock.Product?.Category?.Category_Name ?? "";
            worksheet.Cell(row, 2).Value = stock.Product?.Product_Name ?? "";
            worksheet.Cell(row, 3).Value = stock.Size?.Size_Name ?? "";
            worksheet.Cell(row, 4).Value = stock.Stock_Quantity;

            row++;
        }

        worksheet.SheetView.FreezeRows(1);
        worksheet.Columns().AdjustToContents();

        await DownloadExcelAsync(workbook, "stocks.xlsx");
    }
}